@model List<Visit>
@{
    Layout = "UserLayout";
    ViewData["Title"] = "Visitor Analytics Report";
}

<div class="d-flex align-items-center justify-content-between flex-wrap gap-4 mb-4">
    <div class="d-flex align-items-center gap-3">
        <div style="width: 54px; height: 54px; background: linear-gradient(135deg, #6366f1, #4f46e5); color: white; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; shadow: 0 10px 20px rgba(99, 102, 241, 0.2);">
            <i class="fas fa-chart-line"></i>
        </div>
        <div>
            <h4 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">Analytics Report</h4>
            <p class="text-muted small mb-0 fw-600">Deep insights into visitor traffic and activity logs.</p>
        </div>
    </div>

    <div class="d-flex align-items-center gap-3">
        <!-- Premium Date Picker Trigger -->
        <div class="premium-datepicker-wrap" id="datePickerTrigger">
            <div class="datepicker-trigger">
                <i class="far fa-calendar-alt calendar-icon"></i>
                <span id="selectedRangeText">@(ViewBag.DateRangeLabel ?? "Select Date Range")</span>
                <i class="fas fa-chevron-down chevron-icon"></i>
            </div>

            <!-- The Dropdown Component -->
            <div class="datepicker-dropdown" id="datePickerDropdown">
                <div class="datepicker-container">
                    <!-- Left: Calendar Sidebar -->
                    <div class="datepicker-calendar-side">
                        <div class="calendar-header">
                            <span class="calendar-current-month" id="calendarMonthTitle">JUNE 2016</span>
                            <div class="calendar-nav">
                                <button type="button" class="nav-btn prev-month"><i class="fas fa-chevron-left"></i></button>
                                <button type="button" class="nav-btn next-month"><i class="fas fa-chevron-right"></i></button>
                            </div>
                        </div>
                        <div class="calendar-weekdays">
                            <span>M</span><span>T</span><span>W</span><span>T</span><span>F</span><span>S</span><span>S</span>
                        </div>
                        <div class="calendar-days" id="calendarDaysGrid">
                            <!-- Days populated by JS -->
                        </div>
                    </div>

                    <!-- Right: Quick Filters & Inputs -->
                    <div class="datepicker-controls-side">
                        <form id="reportFilterForm" method="get" action="/User/VisitReport">
                            <div class="date-input-group">
                                <div class="input-item">
                                    <span class="input-label">From</span>
                                    <input type="date" name="dateFrom" id="inputDateFrom" value="@ViewBag.DateFrom" class="date-raw-input">
                                </div>
                                <div class="input-item">
                                    <span class="input-label">To</span>
                                    <input type="date" name="dateTo" id="inputDateTo" value="@ViewBag.DateTo" class="date-raw-input">
                                </div>
                            </div>

                            <div class="quick-filters">
                                <button type="button" class="qf-btn" data-range="last7">Last 7 Days</button>
                                <button type="button" class="qf-btn" data-range="last30">Last 30 Days</button>
                                <button type="button" class="qf-btn" data-range="monthToDate">Month-To-Date</button>
                                <button type="button" class="qf-btn" data-range="lastMonth">Last Month</button>
                            </div>

                            <div class="datepicker-footer">
                                <button type="button" class="btn-cancel" id="btnCancelPicker">CANCEL</button>
                                <button type="submit" class="btn-apply">APPLY</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <button onclick="window.print()" class="premium-btn">
            <i class="fas fa-print me-2"></i>Export PDF
        </button>
    </div>
</div>

@if (Model != null && Model.Count > 0)
{
    var groupedByDay = Model.GroupBy(x => x.VisitDate.Date).OrderByDescending(x => x.Key);
    
    foreach (var day in groupedByDay)
    {
        <div class="section-card mb-5 animate-fade-up">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
                <div class="d-flex align-items-center gap-3">
                    <div style="width: 40px; height: 40px; background: #f8fafc; border-radius: 10px; display: flex; align-items: center; justify-content: center; color: #6366f1; border: 1px solid #e2e8f0;">
                        <i class="fas fa-calendar-day"></i>
                    </div>
                    <div>
                        <h6 class="fw-800 text-dark mb-0">@day.Key.ToString("dddd, dd MMMM yyyy")</h6>
                        <span class="text-muted small fw-600">@day.Count() Records recorded</span>
                    </div>
                </div>
                <span class="nexus-badge nexus-badge-success">DAILY SUMMARY</span>
            </div>

            <div class="nexus-table-wrapper">
                <div class="table-responsive">
                    <table class="nexus-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Visitor Details</th>
                                <th>Host / Department</th>
                                <th>Timing (In/Out)</th>
                                <th>Duration</th>
                                <th>Status</th>
                                <th class="text-end">Pass ID</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int ri = 1; }
                            @foreach (var v in day.OrderBy(x => x.CheckInTime))
                            {
                                string dur = "—";
                                if (v.CheckOutTime.HasValue) {
                                    int mins = (int)(v.CheckOutTime.Value - v.CheckInTime).TotalMinutes;
                                    dur = mins >= 60 ? $"{mins/60}h {mins%60}m" : $"{mins}m";
                                }
                                var (badge, text) = v.Status switch {
                                    "Active" => ("nexus-badge-success", "Inside"),
                                    "Pending" => ("nexus-badge-warning", "Pending"),
                                    _ => ("nexus-badge-danger", "Completed")
                                };

                                <tr class="hover-row">
                                    <td style="width: 50px;"><span class="text-muted small fw-800">@ri</span></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-800" style="width: 32px; height: 32px; font-size: 0.75rem;">
                                                @(string.IsNullOrEmpty(v.Visitor?.Name) ? "?" : v.Visitor?.Name?[0].ToString().ToUpper())
                                            </div>
                                            <div>
                                                <div class="fw-700 text-dark mb-0">@(v.Visitor?.Name ?? "UNKNOWN")</div>
                                                <small class="text-muted" style="font-size: 0.7rem;">@(v.Visitor?.Phone ?? "—")</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-700 text-primary mb-1">@(v.Employee?.Name ?? v.Visitor?.WhomeToMeet ?? "—")</div>
                                        <span class="nexus-badge nexus-badge-info" style="font-size: 0.6rem;">@(v.Employee?.Department?.DepartmentName ?? "General")</span>
                                    </td>
                                    <td>
                                        @if (v.Status != "Pending")
                                        {
                                            <div class="d-flex flex-column gap-1">
                                                <span class="text-success small fw-800"><i class="fas fa-sign-in-alt me-1"></i> @v.CheckInTime.ToString("hh:mm tt")</span>
                                                @if (v.CheckOutTime.HasValue)
                                                {
                                                    <span class="text-danger small fw-800"><i class="fas fa-sign-out-alt me-1"></i> @v.CheckOutTime.Value.ToString("hh:mm tt")</span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted fst-italic small">Pending Entry</span>
                                        }
                                    </td>
                                    <td><span class="fw-800 text-dark font-monospace">@dur</span></td>
                                    <td>
                                        <span class="nexus-badge @badge">@text</span>
                                    </td>
                                    <td class="text-end">
                                        <span class="font-monospace fw-800 text-muted" style="font-size: 0.8rem;">@v.PassNumber</span>
                                    </td>
                                </tr>
                                ri++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="section-card text-center py-5 animate-fade-up">
        <div class="opacity-25 mb-3"><i class="fas fa-folder-open fa-4x text-muted"></i></div>
        <h5 class="fw-800 text-dark">No Report Data Available</h5>
        <p class="text-muted small fw-600">Please adjust your filters or ensure visits have been recorded for the selected period.</p>
    </div>
}

@section Styles {
    <style>
        /* ══ Date Range Filter — Nexus Design System ══ */
        .premium-datepicker-wrap {
            position: relative;
            user-select: none;
        }

        .datepicker-trigger {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 10px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            transition: all 0.25s ease;
            min-width: 280px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }

        .datepicker-trigger:hover {
            border-color: #6366f1;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.12);
        }

        .datepicker-trigger .calendar-icon {
            color: #6366f1;
            font-size: 1.1rem;
        }

        .datepicker-trigger span {
            font-weight: 700;
            color: #1e293b;
            font-size: 0.88rem;
            flex: 1;
        }

        .datepicker-trigger .chevron-icon {
            color: #6366f1;
            font-size: 0.75rem;
            transition: transform 0.3s ease;
        }

        .premium-datepicker-wrap.active .chevron-icon {
            transform: rotate(180deg);
        }

        /* Dropdown Body */
        .datepicker-dropdown {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 20px 50px rgba(30, 30, 45, 0.18);
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transform: translateY(8px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            overflow: hidden;
            border: 1px solid #e2e8f0;
        }

        .premium-datepicker-wrap.active .datepicker-dropdown {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .datepicker-container {
            display: flex;
            width: 680px;
        }

        /* Left: Calendar side */
        .datepicker-calendar-side {
            width: 340px;
            padding: 28px;
            border-right: 1px solid #f1f5f9;
            background: #ffffff;
        }

        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 22px;
        }

        .calendar-current-month {
            font-weight: 800;
            color: #1e1e2d;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .calendar-nav {
            display: flex;
            gap: 8px;
        }

        .nav-btn {
            background: rgba(99, 102, 241, 0.08);
            border: none;
            color: #6366f1;
            cursor: pointer;
            padding: 6px 10px;
            font-size: 0.75rem;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .nav-btn:hover {
            background: rgba(99, 102, 241, 0.15);
        }

        .calendar-weekdays {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            text-align: center;
            margin-bottom: 12px;
        }

        .calendar-weekdays span {
            font-size: 0.65rem;
            font-weight: 800;
            color: #94a3b8;
            text-transform: uppercase;
        }

        .calendar-days {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 3px;
        }

        .calendar-day {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 600;
            color: #1e293b;
            cursor: pointer;
            border-radius: 50%;
            transition: all 0.2s;
        }

        .calendar-day:hover:not(.empty) {
            background: rgba(99, 102, 241, 0.08);
            color: #6366f1;
        }

        .calendar-day.selected {
            background: #6366f1;
            color: white;
            font-weight: 800;
        }

        .calendar-day.in-range {
            background: rgba(99, 102, 241, 0.08);
            color: #6366f1;
        }

        .calendar-day.today {
            border: 2px solid #6366f1;
        }

        .calendar-day.empty { cursor: default; }

        /* Right: Controls side */
        .datepicker-controls-side {
            width: 340px;
            padding: 28px;
            background: #f8fafc;
        }

        .date-input-group {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 22px;
        }

        .input-item {
            display: flex;
            align-items: center;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            overflow: hidden;
            background: white;
            transition: border-color 0.2s;
        }

        .input-item:focus-within {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.08);
        }

        .input-label {
            padding: 10px 14px;
            background: #f1f5f9;
            font-size: 0.72rem;
            font-weight: 800;
            color: #6366f1;
            border-right: 1px solid #e2e8f0;
            width: 65px;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .date-raw-input {
            border: none;
            padding: 10px 14px;
            font-size: 0.85rem;
            font-weight: 700;
            color: #1e293b;
            flex: 1;
            outline: none;
            background: transparent;
        }

        .quick-filters {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 24px;
        }

        .qf-btn {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 10px 16px;
            font-size: 0.8rem;
            font-weight: 700;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .qf-btn:hover {
            border-color: #6366f1;
            color: #6366f1;
            background: rgba(99, 102, 241, 0.03);
        }

        .qf-btn.active {
            border-color: #6366f1;
            color: #6366f1;
            background: rgba(99, 102, 241, 0.06);
            font-weight: 800;
        }

        .datepicker-footer {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 16px;
            padding-top: 4px;
        }

        .btn-cancel {
            background: none;
            border: 1px solid #e2e8f0;
            font-size: 0.78rem;
            font-weight: 800;
            color: #64748b;
            cursor: pointer;
            letter-spacing: 0.5px;
            padding: 9px 22px;
            border-radius: 10px;
            transition: all 0.2s;
        }

        .btn-cancel:hover {
            border-color: #cbd5e1;
            background: #f8fafc;
        }

        .btn-apply {
            background: #6366f1;
            color: white;
            border: none;
            padding: 9px 28px;
            border-radius: 10px;
            font-size: 0.78rem;
            font-weight: 800;
            cursor: pointer;
            letter-spacing: 0.5px;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
            transition: all 0.2s;
        }

        .btn-apply:hover {
            background: #4f46e5;
            box-shadow: 0 6px 18px rgba(99, 102, 241, 0.4);
        }

        @@media (max-width: 768px) {
            .datepicker-container {
                width: 320px;
                flex-direction: column;
            }
            .datepicker-calendar-side, .datepicker-controls-side {
                width: 100%;
            }
            .datepicker-calendar-side { border-right: none; border-bottom: 1px solid #f1f5f9; }
            .datepicker-trigger { min-width: 220px; }
        }

        @@media print {
            .premium-datepicker-wrap { display: none !important; }
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const wrap = document.getElementById('datePickerTrigger');
            const dropdown = document.getElementById('datePickerDropdown');
            const calendarDays = document.getElementById('calendarDaysGrid');
            const monthTitle = document.getElementById('calendarMonthTitle');
            const inputFrom = document.getElementById('inputDateFrom');
            const inputTo = document.getElementById('inputDateTo');
            const qfBtns = document.querySelectorAll('.qf-btn');

            let currentViewDate = new Date();
            let startDate = inputFrom.value ? new Date(inputFrom.value) : null;
            let endDate = inputTo.value ? new Date(inputTo.value) : null;

            // Toggle Dropdown
            wrap.addEventListener('click', function(e) {
                if (e.target.closest('.datepicker-trigger')) {
                    wrap.classList.toggle('active');
                }
            });

            // Close on outside click
            document.addEventListener('click', function(e) {
                if (!wrap.contains(e.target)) {
                    wrap.classList.remove('active');
                }
            });

            document.getElementById('btnCancelPicker').addEventListener('click', () => {
                wrap.classList.remove('active');
            });

            // Calendar Rendering
            function renderCalendar() {
                calendarDays.innerHTML = '';
                const year = currentViewDate.getFullYear();
                const month = currentViewDate.getMonth();
                
                const monthNames = ["JANUARY", "FEBRUARY", "MARCH", "APRIL", "MAY", "JUNE", "JULY", "AUGUST", "SEPTEMBER", "OCTOBER", "NOVEMBER", "DECEMBER"];
                monthTitle.textContent = `${monthNames[month]} ${year}`;

                const firstDay = new Date(year, month, 1).getDay();
                const daysInMonth = new Date(year, month + 1, 0).getDate();
                
                // Adjustment for Monday-start week
                let startOffset = firstDay === 0 ? 6 : firstDay - 1;

                for (let i = 0; i < startOffset; i++) {
                    const empty = document.createElement('div');
                    empty.className = 'calendar-day empty';
                    calendarDays.appendChild(empty);
                }

                for (let d = 1; d <= daysInMonth; d++) {
                    const dayEl = document.createElement('div');
                    dayEl.className = 'calendar-day';
                    dayEl.textContent = d;
                    
                    const thisDate = new Date(year, month, d);
                    
                    if (startDate && thisDate.toDateString() === startDate.toDateString()) dayEl.classList.add('selected');
                    if (endDate && thisDate.toDateString() === endDate.toDateString()) dayEl.classList.add('selected');
                    
                    if (startDate && endDate && thisDate > startDate && thisDate < endDate) {
                        dayEl.classList.add('in-range');
                    }

                    dayEl.addEventListener('click', (e) => {
                        e.stopPropagation();
                        selectDate(new Date(year, month, d));
                    });
                    
                    calendarDays.appendChild(dayEl);
                }
            }

            function selectDate(date) {
                if (!startDate || (startDate && endDate)) {
                    startDate = date;
                    endDate = null;
                } else if (date < startDate) {
                    startDate = date;
                } else {
                    endDate = date;
                }
                
                updateInputs();
                renderCalendar();
            }

            function updateInputs() {
                if (startDate) inputFrom.value = startDate.toLocaleDateString('en-CA');
                if (endDate) inputTo.value = endDate.toLocaleDateString('en-CA');
            }

            // Navigation
            document.querySelector('.prev-month').addEventListener('click', (e) => {
                e.stopPropagation();
                currentViewDate.setMonth(currentViewDate.getMonth() - 1);
                renderCalendar();
            });

            document.querySelector('.next-month').addEventListener('click', (e) => {
                e.stopPropagation();
                currentViewDate.setMonth(currentViewDate.getMonth() + 1);
                renderCalendar();
            });

            // Quick Filters
            qfBtns.forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const range = btn.dataset.range;
                    const today = new Date();
                    let from, to = today;

                    switch(range) {
                        case 'last7':
                            from = new Date(); from.setDate(today.getDate() - 7);
                            break;
                        case 'last30':
                            from = new Date(); from.setDate(today.getDate() - 30);
                            break;
                        case 'monthToDate':
                            from = new Date(today.getFullYear(), today.getMonth(), 1);
                            break;
                        case 'lastMonth':
                            from = new Date(today.getFullYear(), today.getMonth() - 1, 1);
                            to = new Date(today.getFullYear(), today.getMonth(), 0);
                            break;
                    }

                    startDate = from;
                    endDate = to;
                    currentViewDate = new Date(from);
                    updateInputs();
                    renderCalendar();
                    
                    qfBtns.forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                });
            });

            renderCalendar();
        });
    </script>
}

<style>
    @@media print {
        .top-navbar, .sidebar, .premium-btn, .secondary, a[href] { display: none !important; }
        .main-content { margin: 0 !important; padding: 0 !important; }
        .section-card { box-shadow: none !important; border: 1px solid #eee !important; margin-bottom: 20px !important; break-inside: avoid; }
        .nexus-table th { background: #eee !important; color: #000 !important; }
        body { background: #fff !important; }
    }
</style>


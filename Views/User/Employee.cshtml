@model List<VMSProject.Models.Employee>
@{
    Layout = "UserLayout";
    ViewData["Title"] = "Employee Directory";
    var departments = (List<VMSProject.Models.Department>)ViewBag.Departments;
}

<!-- Summary Header -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <p class="text-muted small mb-1">TOTAL EMPLOYEES</p>
                <h3>@Model?.Count</h3>
            </div>
            <div style="width: 48px; height: 48px; background: rgba(16, 185, 129, 0.1); color: #10B981; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                <i class="fas fa-id-badge"></i>
            </div>
        </div>
    </div>
</div>

<div class="section-card animate-fade-up">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h5 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">Employee List</h5>
            <p class="text-muted small mb-0">Manage internal staff members and their departments.</p>
        </div>
        
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="input-group" style="width: 280px;">
                <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px; border-color: #e2e8f0;"><i class="fas fa-search text-muted"></i></span>
                <input type="text" class="form-control bg-light border-start-0" id="tableSearchInput" placeholder="Quick search..." onkeyup="filterTable()" style="border-radius: 0 10px 10px 0; border-color: #e2e8f0; font-size: 0.9rem;">
            </div>
            <button type="button" onclick="openModal('addEmployeeModal')" class="premium-btn">
                <i class="fas fa-plus"></i> Add Employee
            </button>
        </div>
    </div>

    <div class="nexus-table-wrapper">
        <div class="table-responsive">
            <table class="nexus-table" id="standardTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Employee Details</th>
                        <th>Contact Info</th>
                        <th>Department</th>
                        <th>Designation</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        int i = 1;
                        foreach (var e in Model)
                        {
                            <tr class="hover-row" style="cursor: pointer;" onclick="if(!event.target.closest('.tool-btn')) { openViewEmployeeModal(@e.EmployeeId); }">
                                <td style="width: 60px;"><span class="nexus-badge nexus-badge-info">@i</span></td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-800" style="width: 42px; height: 42px; font-size: 0.9rem; border: 1px solid rgba(99, 102, 241, 0.1);">
                                            @if (!string.IsNullOrEmpty(e.PhotoPath))
                                            {
                                                <img src="@e.PhotoPath" alt="@e.Name" class="w-100 h-100 rounded-circle" style="object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <span>@(e.Name != null ? e.Name.Substring(0, 1).ToUpper() : "?")</span>
                                            }
                                        </div>
                                        <div>
                                            <div class="fw-700 text-dark lh-1 mb-1">@e.Name</div>
                                            <small class="text-muted" style="font-size: 0.75rem;">ID: EMP-100@e.EmployeeId</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-600 text-dark mb-1">@e.Email</div>
                                    <small class="text-muted">@e.Phone</small>
                                </td>
                                <td><span class="nexus-badge nexus-badge-success">@(e.Department?.DepartmentName ?? "—")</span></td>
                                <td><span class="fw-700 text-secondary small uppercase">@e.Designation</span></td>
                                <td class="text-end">
                                    <button type="button" class="tool-btn" style="color: #F59E0B;" title="Edit" onclick="openEditEmployeeModal(@e.EmployeeId)">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="opacity-25 mb-3"><i class="fas fa-user-slash fa-3x"></i></div>
                                <p class="text-muted fw-600">No employees found in the directory.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODALS -->
<!-- ADD EMPLOYEE -->
<div class="modal fade" id="addEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content nexus-modal-content">
            <div class="nexus-modal-header">
                <h5 class="fw-800 text-dark mb-0"><i class="fas fa-user-plus text-primary me-2"></i> Register New Employee</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/User/AddEmployee" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">FULL NAME <span class="text-danger">*</span></label>
                                <input type="text" name="Name" class="nexus-input" placeholder="Enter full name" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">PHONE NUMBER</label>
                                <input type="text" name="Phone" class="nexus-input" placeholder="Primary contact" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">EMAIL ADDRESS</label>
                                <input type="email" name="Email" class="nexus-input" placeholder="Work email" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">JOB TITLE / DESIGNATION</label>
                                <input type="text" name="Designation" class="nexus-input" placeholder="e.g. Lead Developer" />
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="nexus-form-group">
                                <label class="nexus-label">ASSIGN DEPARTMENT <span class="text-danger">*</span></label>
                                <select name="DepartmentId" class="nexus-input" required>
                                    <option value="">— Select Department —</option>
                                    @foreach (var d in departments)
                                    {
                                        <option value="@d.DepartmentId">@d.DepartmentName</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="nexus-form-group">
                                <label class="nexus-label">PROFILE PHOTO</label>
                                <input type="file" name="Photo" class="nexus-input" accept="image/*" />
                            </div>
                        </div>
                    </div>
                </div>
                <div class="nexus-modal-footer d-flex justify-content-end gap-3 bg-light bg-opacity-50">
                    <button type="button" class="premium-btn secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="premium-btn">Register Employee</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT EMPLOYEE -->
<div class="modal fade" id="editEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content nexus-modal-content">
            <div class="nexus-modal-header">
                <h5 class="fw-800 text-dark mb-0"><i class="fas fa-user-edit text-primary me-2"></i> Edit Employee Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editEmployeeForm" method="post" action="/User/EditEmployee" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" id="edit_EmployeeId" name="EmployeeId" />
                <div class="modal-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">FULL NAME</label>
                                <input type="text" id="edit_Name" name="Name" class="nexus-input" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">PHONE NUMBER</label>
                                <input type="text" id="edit_Phone" name="Phone" class="nexus-input" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">EMAIL ADDRESS</label>
                                <input type="email" id="edit_Email" name="Email" class="nexus-input" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">JOB TITLE</label>
                                <input type="text" id="edit_Designation" name="Designation" class="nexus-input" />
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="nexus-form-group">
                                <label class="nexus-label">DEPARTMENT</label>
                                <select id="edit_DepartmentId" name="DepartmentId" class="nexus-input" required>
                                    <option value="">Select Department</option>
                                    @foreach (var d in departments)
                                    {
                                        <option value="@d.DepartmentId">@d.DepartmentName</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="nexus-form-group">
                                <label class="nexus-label">UPDATE PHOTO</label>
                                <div class="d-flex align-items-center gap-3">
                                    <div id="edit_photo_preview_container" class="rounded-circle overflow-hidden border border-primary border-opacity-25 shadow-sm" style="width: 45px; height: 45px; display: none;">
                                        <img id="edit_photo_preview" src="" class="w-100 h-100 object-fit-cover" />
                                    </div>
                                    <input type="file" name="Photo" class="nexus-input" accept="image/*" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="nexus-modal-footer d-flex justify-content-end gap-3 bg-light bg-opacity-50">
                    <button type="button" class="premium-btn secondary" data-bs-dismiss="modal">Discard</button>
                    <button type="submit" class="premium-btn">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- VIEW EMPLOYEE -->
<div class="modal fade" id="viewEmployeeModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="true">
    <div class="modal-dialog modal-dialog-centered modal-view-lg">
        <div class="modal-content nexus-view-modal-content border-0">
            <div class="modal-body view-modal-body">
                <div class="view-modal-header">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" style="position: absolute; top: 18px; right: 20px; z-index: 10;"></button>
                </div>

                <div class="view-profile-overlap">
                    <div class="view-avatar-box">
                        <img id="view_photo" src="" class="w-100 h-100 object-fit-cover d-none" />
                        <span id="view_initial" class="fw-800 text-primary fs-2">?</span>
                    </div>
                    <div class="pb-2">
                        <h2 id="view_name" class="fw-800 text-dark mb-1" style="letter-spacing: -0.75px; font-size: 1.75rem;">Employee Name</h2>
                        <p id="view_designation" class="text-primary fw-800 uppercase letter-spacing-2 mb-0" style="font-size: 0.78rem;">DESIGNATION TITLE</p>
                    </div>
                </div>

                <div class="view-detail-grid">
                    <div class="view-info-card">
                        <label class="view-info-label">Department</label>
                        <div id="view_department" class="view-info-value"><i class="fas fa-building-user"></i><span>—</span></div>
                    </div>
                    <div class="view-info-card">
                        <label class="view-info-label">Employee ID</label>
                        <div id="view_id" class="view-info-value"><i class="fas fa-id-card-clip"></i><span>#—</span></div>
                    </div>
                    <div class="view-info-card">
                        <label class="view-info-label">Email Address</label>
                        <div id="view_email" class="view-info-value"><i class="fas fa-envelope"></i><span>—</span></div>
                    </div>
                    <div class="view-info-card">
                        <label class="view-info-label">Phone Number</label>
                        <div id="view_phone" class="view-info-value"><i class="fas fa-phone"></i><span>—</span></div>
                    </div>
                </div>
            </div>
            <div class="nexus-modal-footer">
                <button type="button" class="premium-btn secondary" data-bs-dismiss="modal" style="min-width: 160px;">Close Profile</button>
                <button type="button" id="view_edit_btn" class="premium-btn" style="min-width: 160px;">
                    <i class="fas fa-user-edit me-2"></i> Edit Profile
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="/js/User/EmployeeManagement.js"></script>
}

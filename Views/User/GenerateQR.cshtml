@model VMSProject.Models.Visitor
@{
    Layout = "UserLayout";
    ViewData["Title"] = "Generate Access Pass";
    var hasQR = !string.IsNullOrEmpty(Model.QRCode);
}

<div class="row justify-content-center">
    <div class="col-xl-6 col-lg-8">
        <div class="section-card p-0 overflow-hidden animate-fade-up shadow-lg">
            <!-- Nexus Premium Header -->
            <div class="p-5 text-center bg-primary text-white position-relative overflow-hidden">
                <div class="position-absolute top-0 start-0 w-100 h-100" style="background: linear-gradient(45deg, rgba(99, 102, 241, 0.4), transparent); opacity: 0.5;"></div>
                <div class="position-absolute top-0 start-0 w-100 h-100 opacity-10" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 20px 20px;"></div>
                
                <div class="position-relative z-1">
                    <h3 class="fw-800 mb-1" style="letter-spacing: -1px; font-size: 1.75rem;">Security Access Pass</h3>
                    <p class="opacity-75 small uppercase letter-spacing-2 fw-800">Visitor Identification Protocol</p>
                    
                    <div class="mt-5 position-relative d-inline-block">
                        <div class="rounded-circle border border-4 border-white border-opacity-30 p-1 shadow-lg mx-auto" style="width: 120px; height: 120px; background: rgba(255,255,255,0.1); backdrop-filter: blur(10px);">
                            <div class="rounded-circle overflow-hidden bg-white d-flex align-items-center justify-content-center w-100 h-100">
                                @if (!string.IsNullOrEmpty(Model.CapturePhoto))
                                {
                                    <img src="@Model.CapturePhoto" class="w-100 h-100 object-fit-cover" />
                                }
                                else
                                {
                                    <span class="fw-800 text-primary fs-1">@(Model.Name?[0].ToString().ToUpper() ?? "?")</span>
                                }
                            </div>
                        </div>
                    </div>
                    
                    <h4 class="mt-4 fw-800 mb-1" style="letter-spacing: -0.5px;">@Model.Name</h4>
                    <p class="small fw-700 opacity-80 uppercase letter-spacing-1">@(Model.CompanyName ?? "GUEST VISITOR")</p>
                </div>
            </div>

            <div class="p-5 text-center bg-white">
                @if (hasQR)
                {
                    <div class="qr-wrapper mb-4 p-4 bg-light rounded-4 d-inline-block shadow-sm border border-white" style="border-width: 3px !important;">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=300x300&color=000000&bgcolor=ffffff&qzone=1&data=@Uri.EscapeDataString(Model.QRCode!)"
                             width="220" height="220" class="rounded-3 shadow-sm" alt="Access QR" />
                    </div>
                    
                    <div class="mb-5">
                        <label class="d-block small fw-800 text-muted uppercase letter-spacing-2 mb-3">UNIQUE PASS IDENTIFIER</label>
                        <div class="nexus-badge nexus-badge-info font-monospace py-3 px-5 fw-800" style="font-size: 1.25rem; border: 1px dashed rgba(99, 102, 241, 0.4);">
                            @Model.QRCode
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <button onclick="window.print()" class="premium-btn w-100 py-3 shadow-lg fs-5">
                                <i class="fas fa-print me-2"></i> PRINT PHYSICAL PASS
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="premium-btn secondary w-100 py-3 fw-800">
                                <i class="fas fa-share-nodes me-2"></i> SHARE
                            </button>
                        </div>
                        <div class="col-6">
                            <a href="/User/VisitorManagement" class="premium-btn secondary w-100 py-3 fw-800" style="border-color: #10B981; color: #10B981;">
                                <i class="fas fa-check-circle me-2"></i> FINISHED
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <div class="py-5">
                        <div class="bg-light rounded-4 p-5 border-dashed border-2 border-primary border-opacity-20 mb-4">
                            <div class="opacity-25 mb-3"><i class="fas fa-qrcode fa-4x text-primary"></i></div>
                            <h5 class="fw-800 text-dark">No Active Pass Found</h5>
                            <p class="text-muted small fw-600">The system could not detect an active security pass for this visitor.</p>
                        </div>
                        
                        <form action="/User/GenerateVisitorQR" method="post">
                            <input type="hidden" name="id" value="@Model.VisitorId" />
                            <button type="submit" class="premium-btn py-3 px-5 shadow-lg">
                                GENERATE NEW PASS <i class="fas fa-bolt ms-2"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>
            
            <div class="p-4 text-center border-top border-light bg-light bg-opacity-30">
                <p class="mb-0 text-muted fw-800" style="font-size: 0.7rem; letter-spacing: 2px;">
                    <i class="fas fa-shield-halved me-2 opacity-50"></i>VALID FOR TODAY ONLY • SECURE ACCESS SYSTEM
                </p>
            </div>
        </div>
    </div>
</div>

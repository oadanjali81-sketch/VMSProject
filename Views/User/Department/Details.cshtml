@model VMSProject.Models.Department
@{
    Layout = "UserLayout";
    ViewData["Title"] = Model.DepartmentName;
}

<div class="row g-4 animate-fade-up">
    <!-- Left Column: Department Snapshot -->
    <div class="col-lg-4">
        <div class="section-card h-100 text-center position-relative overflow-hidden">
            <div class="position-absolute top-0 start-0 w-100" style="height: 120px; background: linear-gradient(135deg, var(--nexus-primary), #4f46e5);"></div>
            
            <div class="position-relative mt-5 pt-3">
                <div class="rounded-circle bg-white p-2 d-inline-block shadow-sm mb-3" style="border: 1px solid rgba(99, 102, 241, 0.1);">
                    <div class="rounded-circle overflow-hidden d-flex align-items-center justify-content-center bg-light text-primary" style="width: 120px; height: 120px;">
                        <i class="fas fa-building" style="font-size: 3rem;"></i>
                    </div>
                </div>
                
                <h3 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">@Model.DepartmentName</h3>
                <span class="nexus-badge nexus-badge-success mb-3">Organizational Unit</span>
                
                <div class="d-flex flex-column gap-2 mt-4">
                    <a href="/User/Department/Edit/@Model.DepartmentId" class="premium-btn w-100 py-2">
                        <i class="fas fa-edit me-2"></i> Edit Department
                    </a>
                    <a href="/User/Department" class="premium-btn secondary w-100 py-2">
                        <i class="fas fa-arrow-left me-2"></i> Back to Registry
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Detailed Information -->
    <div class="col-lg-8">
        <div class="section-card h-100">
            <h5 class="fw-800 text-dark mb-4 pb-3 border-bottom"><i class="fas fa-chart-pie text-primary me-2"></i> Department Analytics & Information</h5>
            
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="p-4 rounded-4" style="background: #f8fafc; border: 1px solid #f1f5f9;">
                        <div class="text-muted small fw-800 uppercase letter-spacing-1 mb-2">Total Personnel</div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="fas fa-users"></i>
                            </div>
                            <span class="fw-800 text-dark fs-5">@(ViewBag.EmployeeCount ?? 0) <span class="fs-6 text-muted fw-600">Active Members</span></span>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-12">
                    <div class="p-4 rounded-4" style="background: #f8fafc; border: 1px solid #f1f5f9;">
                        <div class="text-muted small fw-800 uppercase letter-spacing-1 mb-4">Department Personnel</div>
                        
                        <div class="d-flex flex-column gap-3">
                            @if (ViewBag.Employees != null && ((List<VMSProject.Models.Employee>)ViewBag.Employees).Count > 0)
                            {
                                foreach (var emp in (List<VMSProject.Models.Employee>)ViewBag.Employees)
                                {
                                    <div class="d-flex align-items-center justify-content-between p-3 bg-white rounded-4 shadow-sm border border-light animate-fade-up">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle overflow-hidden shadow-sm" style="width: 45px; height: 45px;">
                                                @if (!string.IsNullOrEmpty(emp.PhotoPath))
                                                {
                                                    <img src="@emp.PhotoPath" class="w-100 h-100" style="object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <div class="w-100 h-100 bg-primary bg-opacity-10 d-flex align-items-center justify-content-center text-primary fw-800">
                                                        @(emp.Name?.Substring(0, 1).ToUpper() ?? "?")
                                                    </div>
                                                }
                                            </div>
                                            <div>
                                                <div class="fw-800 text-dark mb-0">@emp.Name</div>
                                                <div class="small text-muted fw-600">@emp.Designation</div>
                                            </div>
                                        </div>
                                        <a href="/User/Employee/Details/@emp.EmployeeId" class="premium-btn secondary py-1 px-3 fs-7 shadow-none">
                                            View Profile
                                        </a>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-4">
                                    <i class="fas fa-users-slash text-muted opacity-25 fs-1 mb-2"></i>
                                    <p class="text-muted small fw-600 mb-0">No employees assigned to this department yet.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    Layout = "UserLayout";
    ViewData["Title"] = "Add Department";
}

<div class="animate-fade-up d-flex justify-content-center mt-3">
    <div class="section-card" style="max-width: 700px; width: 100%;">
        <!-- Header Section -->
        <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/User/Department" class="text-primary text-decoration-none fw-600">Departments</a></li>
                        <li class="breadcrumb-item active fw-600" aria-current="page">Add New Department</li>
                    </ol>
                </nav>
                <h4 class="fw-800 text-dark mb-0"><i class="fas fa-building-circle-plus text-primary me-2"></i>Add New Department</h4>
            </div>
            <a href="/User/Department" class="premium-btn secondary py-2">
                <i class="fas fa-times"></i>
            </a>
        </div>
        
        <form method="post" action="/User/AddDepartment">
            @Html.AntiForgeryToken()
            <div class="nexus-form-group mb-5">
                <label class="nexus-label">Department Name <span class="text-danger">*</span></label>
                <div class="position-relative">
                    <i class="fas fa-building position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                    <input type="text" name="DepartmentName" class="nexus-input ps-5" placeholder="e.g. Information Technology" required autofocus />
                </div>
            </div>


            <div class="d-flex gap-3">
                <button type="submit" class="premium-btn flex-grow-1 py-3">
                    <i class="fas fa-plus-circle me-2"></i>Add Department
                </button>
                <button type="reset" class="premium-btn secondary py-3 px-5 text-center">Reset</button>
            </div>
        </form>
    </div>
</div>


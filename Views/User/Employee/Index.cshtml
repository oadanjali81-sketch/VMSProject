@model List<VMSProject.Models.Employee>
@{
    Layout = "UserLayout";
    ViewData["Title"] = "Employee Directory";
}

<!-- Summary Header -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <p class="text-muted small mb-1">TOTAL EMPLOYEES</p>
                <h3>@Model?.Count</h3>
            </div>
            <div style="width: 48px; height: 48px; background: rgba(16, 185, 129, 0.1); color: #10B981; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                <i class="fas fa-id-badge"></i>
            </div>
        </div>
    </div>
</div>

<div class="section-card animate-fade-up">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h5 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">Employee List</h5>
            <p class="text-muted small mb-0">Manage internal staff members and their departments.</p>
        </div>
        
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="input-group" style="width: 280px;">
                <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px; border-color: #e2e8f0;"><i class="fas fa-search text-muted"></i></span>
                <input type="text" class="form-control bg-light border-start-0" id="tableSearchInput" placeholder="Quick search..." onkeyup="filterTable()" style="border-radius: 0 10px 10px 0; border-color: #e2e8f0; font-size: 0.9rem;">
            </div>
            <a href="/User/Employee/Add" class="premium-btn text-decoration-none">
                <i class="fas fa-plus"></i> Add Employee
            </a>
        </div>
    </div>

    <div class="nexus-table-wrapper">
        <div class="table-responsive">
            <table class="nexus-table" id="standardTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Employee Details</th>
                        <th>Contact Info</th>
                        <th>Department</th>
                        <th>Designation</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        int i = 1;
                        foreach (var e in Model)
                        {
                            <tr class="hover-row" style="cursor: pointer;" onclick="if(!event.target.closest('.tool-btn')) { window.location.href='/User/Employee/Details/@e.EmployeeId'; }">
                                <td style="width: 60px;"><span class="nexus-badge nexus-badge-info">@i</span></td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-800" style="width: 42px; height: 42px; font-size: 0.9rem; border: 1px solid rgba(99, 102, 241, 0.1);">
                                            @if (!string.IsNullOrEmpty(e.PhotoPath))
                                            {
                                                <img src="@e.PhotoPath" alt="@e.Name" class="w-100 h-100 rounded-circle" style="object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <span>@(e.Name != null ? e.Name.Substring(0, 1).ToUpper() : "?")</span>
                                            }
                                        </div>
                                        <div>
                                            <div class="fw-700 text-dark lh-1 mb-1">@e.Name</div>
                                            <small class="text-muted" style="font-size: 0.75rem;">ID: EMP-100@e.EmployeeId</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-600 text-dark mb-1">@e.Email</div>
                                    <small class="text-muted">@e.Phone</small>
                                </td>
                                <td><span class="nexus-badge nexus-badge-success">@(e.Department?.DepartmentName ?? "—")</span></td>
                                <td><span class="fw-700 text-secondary small uppercase">@e.Designation</span></td>
                                <td class="text-end">
                                    <a href="/User/Employee/Edit/@e.EmployeeId" class="tool-btn warning d-inline-flex align-items-center justify-content-center text-decoration-none" title="Edit">
                                        <i class="fas fa-pen"></i>
                                    </a>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="opacity-25 mb-3"><i class="fas fa-user-slash fa-3x"></i></div>
                                <p class="text-muted fw-600">No employees found in the directory.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.Pagination != null)
    {
        var pModel = (VMSProject.Models.PaginationViewModel)ViewBag.Pagination;
        @if (pModel.TotalPages > 0)
        {
            <div class="nexus-pagination-wrapper">
                <div class="nexus-page-info">
                    Showing @(((pModel.CurrentPage - 1) * pModel.PageSize) + 1) to @(Math.Min(pModel.CurrentPage * pModel.PageSize, pModel.TotalItems)) of @pModel.TotalItems entries
                </div>
                <div class="d-flex align-items-center gap-3">
                    <select class="nexus-page-size-select" onchange="updatePageSize(this.value)">
                        <option value="10" selected="@(pModel.PageSize == 10)">10 per page</option>
                        <option value="20" selected="@(pModel.PageSize == 20)">20 per page</option>
                        <option value="50" selected="@(pModel.PageSize == 50)">50 per page</option>
                        <option value="100" selected="@(pModel.PageSize == 100)">100 per page</option>
                    </select>
                    <nav>
                        <ul class="nexus-pagination">
                            @if (pModel.HasPreviousPage)
                            {
                                var prevVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = (pModel.CurrentPage - 1).ToString() };
                                <li class="page-item"><a href="@Url.Action(pModel.Action, pModel.Controller, prevVals)" class="page-link"><i class="fas fa-chevron-left"></i></a></li>
                            }
                            @for (int i = Math.Max(1, pModel.CurrentPage - 2); i <= Math.Min(pModel.TotalPages, pModel.CurrentPage + 2); i++)
                            {
                                var pageVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = i.ToString() };
                                <li class="page-item @(i == pModel.CurrentPage ? "active" : "")"><a href="@Url.Action(pModel.Action, pModel.Controller, pageVals)" class="page-link">@i</a></li>
                            }
                            @if (pModel.HasNextPage)
                            {
                                var nextVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = (pModel.CurrentPage + 1).ToString() };
                                <li class="page-item"><a href="@Url.Action(pModel.Action, pModel.Controller, nextVals)" class="page-link"><i class="fas fa-chevron-right"></i></a></li>
                            }
                        </ul>
                    </nav>
                </div>
            </div>
            <script>
                function updatePageSize(size) {
                    const url = new URL(window.location.href);
                    url.searchParams.set('pageSize', size);
                    url.searchParams.set('page', '1');
                    window.location.href = url.toString();
                }
            </script>
        }
    }
</div>

@section Scripts {
    <script>
        function filterTable() {
            const input = document.getElementById('tableSearchInput').value.toLowerCase();
            const rows = document.querySelectorAll('#standardTable tbody tr');
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(input) ? '' : 'none';
            });
        }
    </script>
}

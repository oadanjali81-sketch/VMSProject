@model List<VMSProject.Models.Department>
@{
    Layout = "UserLayout";
    ViewData["Title"] = "Departments";
}

<div class="section-card animate-fade-up">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h5 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">Department Registry</h5>
            <p class="text-muted small mb-0">Manage organizational units and employee distribution.</p>
        </div>
        
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="input-group" style="width: 280px;">
                <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px; border-color: #e2e8f0;"><i class="fas fa-search text-muted"></i></span>
                <input type="text" class="form-control bg-light border-start-0" id="tableSearchInput" placeholder="Quick search..." onkeyup="filterTable()" style="border-radius: 0 10px 10px 0; border-color: #e2e8f0; font-size: 0.9rem;">
            </div>
            <button type="button" data-bs-toggle="modal" data-bs-target="#addDepartmentModal" class="premium-btn">
                <i class="fas fa-plus"></i> Add Department
            </button>
        </div>
    </div>

    <div class="nexus-table-wrapper">
        <div class="table-responsive">
            <table class="nexus-table" id="standardTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Department Name</th>
                        <th>Employee Count</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        int i = 1;
                        foreach (var d in Model)
                        {
                            int empCount = 0;
                            if (ViewBag.EmpCounts != null)
                            {
                                var counts = ViewBag.EmpCounts as System.Collections.Generic.Dictionary<int, int>;
                                counts?.TryGetValue(d.DepartmentId, out empCount);
                            }
                            <tr class="hover-row" style="cursor: pointer;" onclick="if(!event.target.closest('.tool-btn')) { openViewDepartmentModal(@d.DepartmentId); }">
                                <td style="width: 60px;"><span class="nexus-badge nexus-badge-info">@i</span></td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-800" style="width: 40px; height: 40px; border: 1px solid rgba(99, 102, 241, 0.1);">
                                            <i class="fas fa-building small"></i>
                                        </div>
                                        <span class="fw-700 text-dark">@d.DepartmentName</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-800 text-primary">@empCount <span class="text-muted fw-600 small ms-1">Personnel</span></div>
                                </td>
                                <td>
                                    <span class="nexus-badge nexus-badge-success">Active</span>
                                </td>
                                <td class="text-end">
                                    <button type="button" class="tool-btn" style="color: #F59E0B;" title="Edit" onclick="openEditDepartmentModal(@d.DepartmentId)">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="opacity-25 mb-3"><i class="fas fa-sitemap fa-3x"></i></div>
                                <p class="text-muted fw-600">No departments registered yet.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- MODALS -->
<!-- ADD DEPARTMENT -->
<div class="modal fade" id="addDepartmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content nexus-modal-content">
            <div class="nexus-modal-header">
                <h5 class="fw-800 text-dark mb-0"><i class="fas fa-folder-plus text-primary me-2"></i> Add New Department</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/User/AddDepartment">
                @Html.AntiForgeryToken()
                <div class="modal-body p-4">
                    <div class="nexus-form-group">
                        <label class="nexus-label">DEPARTMENT NAME <span class="text-danger">*</span></label>
                        <input type="text" name="DepartmentName" class="nexus-input" placeholder="e.g. IT, HR, Marketing" required />
                    </div>
                </div>
                <div class="nexus-modal-footer d-flex justify-content-end gap-3 bg-light bg-opacity-50">
                    <button type="button" class="premium-btn secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="premium-btn">Create Unit</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- EDIT DEPARTMENT -->
<div class="modal fade" id="editDepartmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content nexus-modal-content">
            <div class="nexus-modal-header">
                <h5 class="fw-800 text-dark mb-0"><i class="fas fa-file-pen text-primary me-2"></i> Edit Department</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" action="/User/EditDepartment">
                @Html.AntiForgeryToken()
                <input type="hidden" id="edit_DeptId" name="DepartmentId" />
                <div class="modal-body p-4">
                    <div class="nexus-form-group">
                        <label class="nexus-label">DEPARTMENT NAME <span class="text-danger">*</span></label>
                        <input type="text" id="edit_DeptName" name="DepartmentName" class="nexus-input" required />
                    </div>
                </div>
                <div class="nexus-modal-footer d-flex justify-content-end gap-3 bg-light bg-opacity-50">
                    <button type="button" class="premium-btn secondary" data-bs-dismiss="modal">Discard</button>
                    <button type="submit" class="premium-btn">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- VIEW DEPARTMENT -->
<div class="modal fade" id="viewDepartmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content nexus-modal-content overflow-hidden">
            <div class="modal-body p-0">
                <div style="height: 120px; background: linear-gradient(135deg, #6366f1, #4f46e5); position: relative;">
                    <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-4" data-bs-dismiss="modal"></button>
                </div>
                <div class="px-4 pb-5 text-center">
                    <div class="rounded-circle bg-white shadow-lg d-flex align-items-center justify-content-center mx-auto" style="width: 100px; height: 100px; margin-top: -50px; position: relative; z-index: 5; border: 5px solid #fff;">
                        <i class="fas fa-building text-primary fs-1"></i>
                    </div>
                    <div class="mt-4">
                        <h3 id="view_DeptName" class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">Department Name</h3>
                        <p class="text-muted small fw-700 uppercase letter-spacing-2">Organizational Unit</p>
                    </div>
                    
                    <div class="p-4 bg-light rounded-4 border border-white mt-4">
                        <label class="text-muted small fw-800 uppercase letter-spacing-2 d-block mb-2" style="font-size: 0.65rem;">TOTAL EMPLOYEES</label>
                        <div class="fw-800 text-primary fs-2">
                            <i class="fas fa-users-gear me-2 opacity-50"></i>
                            <span id="view_DeptCount">0</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="nexus-modal-footer d-flex justify-content-center gap-3 bg-light bg-opacity-50">
                <button type="button" class="premium-btn secondary" data-bs-dismiss="modal" style="min-width: 160px;">Close</button>
                <button type="button" id="view_DeptEditBtn" class="premium-btn" style="min-width: 160px;">
                    <i class="fas fa-edit me-2"></i> Edit Dept
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>

        async function openEditDepartmentModal(id) {
            try {
                const response = await fetch(`/User/GetDepartment/${id}`);
                const data = await response.json();
                document.getElementById('edit_DeptId').value = data.id || data.DepartmentId || data.Id;
                document.getElementById('edit_DeptName').value = data.name || data.DepartmentName || data.Name;
                openModal('editDepartmentModal');
            } catch (err) { console.error(err); }
        }

        async function openViewDepartmentModal(id) {
            try {
                const response = await fetch(`/User/GetDepartment/${id}`);
                const data = await response.json();
                document.getElementById('view_DeptName').textContent = data.name || data.DepartmentName || data.Name;
                document.getElementById('view_DeptCount').textContent = data.employeeCount || data.EmployeeCount || 0;
                document.getElementById('view_DeptEditBtn').onclick = () => {
                    closeModal('viewDepartmentModal');
                    openEditDepartmentModal(id);
                };
                openModal('viewDepartmentModal');
            } catch (err) { console.error(err); }
        }

    </script>
}

@model List<VMSProject.Models.Department>
@{
    Layout = "UserLayout";
    ViewData["Title"] = "Departments";
    var mode = ViewBag.Mode as string ?? "List";
    var deptData = ViewBag.DepartmentData as VMSProject.Models.Department;
}

@if (mode == "Add")
{
    <div class="section-card animate-fade-up">
        <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/User/Department" class="text-decoration-none">Departments</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Add</li>
                    </ol>
                </nav>
                <h4 class="fw-800 text-dark mb-0"><i class="fas fa-folder-plus text-primary me-2"></i> Add New Department</h4>
            </div>
            <a href="/User/Department" class="premium-btn secondary"><i class="fas fa-arrow-left me-2"></i>Back</a>
        </div>
        
        <form method="post" action="/User/AddDepartment" class="mx-auto" style="max-width: 600px;">
            @Html.AntiForgeryToken()
            <div class="nexus-form-group mb-4">
                <label class="nexus-label">DEPARTMENT NAME <span class="text-danger">*</span></label>
                <input type="text" name="DepartmentName" class="nexus-input" placeholder="e.g. IT, HR, Marketing" required autofocus />
            </div>
            <div class="d-flex gap-3">
                <a href="/User/Department" class="premium-btn secondary w-50 text-center">Cancel</a>
                <button type="submit" class="premium-btn w-50">Create Unit</button>
            </div>
        </form>
    </div>
}
else if (mode == "Edit" && deptData != null)
{
    <div class="section-card animate-fade-up">
        <div class="d-flex align-items-center justify-content-between mb-4 pb-3 border-bottom">
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/User/Department" class="text-decoration-none">Departments</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Edit</li>
                    </ol>
                </nav>
                <h4 class="fw-800 text-dark mb-0"><i class="fas fa-file-pen text-primary me-2"></i> Edit Department</h4>
            </div>
            <a href="/User/Department" class="premium-btn secondary"><i class="fas fa-arrow-left me-2"></i>Back</a>
        </div>
        
        <form method="post" action="/User/EditDepartment" class="mx-auto" style="max-width: 600px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="DepartmentId" value="@deptData.DepartmentId" />
            <div class="nexus-form-group mb-4">
                <label class="nexus-label">DEPARTMENT NAME <span class="text-danger">*</span></label>
                <input type="text" name="DepartmentName" class="nexus-input" value="@deptData.DepartmentName" required autofocus />
            </div>
            <div class="d-flex gap-3">
                <a href="/User/Department" class="premium-btn secondary w-50 text-center">Discard</a>
                <button type="submit" class="premium-btn w-50">Save Changes</button>
            </div>
        </form>
    </div>
}
else if (mode == "Details" && deptData != null)
{
    <div class="section-card animate-fade-up p-0 overflow-hidden">
        <div class="view-modal-header d-flex justify-content-between p-4">
            <nav aria-label="breadcrumb" style="z-index: 10; position: relative;">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/User/Department" class="text-white text-decoration-none opacity-75 hover-opacity-100">Departments</a></li>
                    <li class="breadcrumb-item active text-white fw-bold" aria-current="page">Details</li>
                </ol>
            </nav>
            <a href="/User/Department" class="btn-close btn-close-white" style="position: relative; z-index: 10;"></a>
        </div>

        <div class="view-profile-overlap px-4">
            <div class="view-avatar-box">
                <i class="fas fa-building text-primary fs-2"></i>
            </div>
            <div class="pb-2">
                <h2 class="fw-800 text-dark mb-1" style="letter-spacing: -0.75px; font-size: 1.75rem;">@deptData.DepartmentName</h2>
                <p class="text-primary fw-800 uppercase letter-spacing-2 mb-0" style="font-size: 0.78rem;">ORGANIZATIONAL UNIT</p>
            </div>
        </div>

        <div class="view-detail-grid px-4 mt-4">
            <div class="view-info-card">
                <label class="view-info-label">Total Employees</label>
                <div class="view-info-value"><i class="fas fa-users-gear"></i><span>@(ViewBag.EmployeeCount ?? 0)</span></div>
            </div>
            <div class="view-info-card">
                <label class="view-info-label">Unit Status</label>
                <div class="view-info-value"><i class="fas fa-check-circle"></i><span>Active</span></div>
            </div>
        </div>
        
        <div class="p-4 bg-light border-top d-flex justify-content-end gap-3">
            <a href="/User/Department" class="premium-btn secondary" style="min-width: 160px; text-align:center;">Close</a>
            <a href="/User/Department/Edit/@deptData.DepartmentId" class="premium-btn" style="min-width: 160px; text-align:center;">
                <i class="fas fa-edit me-2"></i> Edit Dept
            </a>
        </div>
    </div>
}
else
{
    <div class="section-card animate-fade-up">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
            <div>
                <h5 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">Department Registry</h5>
                <p class="text-muted small mb-0">Manage organizational units and employee distribution.</p>
            </div>
            
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div class="input-group" style="width: 280px;">
                    <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px; border-color: #e2e8f0;"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" class="form-control bg-light border-start-0" id="tableSearchInput" placeholder="Quick search..." onkeyup="filterTable()" style="border-radius: 0 10px 10px 0; border-color: #e2e8f0; font-size: 0.9rem;">
                </div>
                <a href="/User/Department/Add" class="premium-btn text-decoration-none">
                    <i class="fas fa-plus"></i> Add Department
                </a>
            </div>
        </div>

        <div class="nexus-table-wrapper">
            <div class="table-responsive">
                <table class="nexus-table" id="standardTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Department Name</th>
                            <th>Employee Count</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            int i = 1;
                            foreach (var d in Model)
                            {
                                int empCount = 0;
                                if (ViewBag.EmpCounts != null)
                                {
                                    var counts = ViewBag.EmpCounts as System.Collections.Generic.Dictionary<int, int>;
                                    counts?.TryGetValue(d.DepartmentId, out empCount);
                                }
                                <tr class="hover-row" style="cursor: pointer;" onclick="if(!event.target.closest('.tool-btn')) { window.location.href='/User/Department/Details/@d.DepartmentId'; }">
                                    <td style="width: 60px;"><span class="nexus-badge nexus-badge-info">@i</span></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-800" style="width: 40px; height: 40px; border: 1px solid rgba(99, 102, 241, 0.1);">
                                                <i class="fas fa-building small"></i>
                                            </div>
                                            <span class="fw-700 text-dark">@d.DepartmentName</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="fw-800 text-primary">@empCount <span class="text-muted fw-600 small ms-1">Personnel</span></div>
                                    </td>
                                    <td>
                                        <span class="nexus-badge nexus-badge-success">Active</span>
                                    </td>
                                    <td class="text-end">
                                        <a href="/User/Department/Edit/@d.DepartmentId" class="tool-btn d-inline-flex align-items-center justify-content-center text-decoration-none" style="color: #F59E0B;" title="Edit">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                    </td>
                                </tr>
                                i++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="opacity-25 mb-3"><i class="fas fa-sitemap fa-3x"></i></div>
                                    <p class="text-muted fw-600">No departments registered yet.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@section Scripts {
    <!-- Modal logic completely removed per user request -->
}

@model List<VMSProject.Models.Visit>
@{
    Layout = "UserLayout";
    ViewData["Title"] = "Visit Logs";
}

<!-- Summary Stats -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <p class="text-muted small mb-1">TOTAL LOGS</p>
                <h3>@ViewBag.TotalVisits</h3>
            </div>
            <div style="width: 48px; height: 48px; background: rgba(99, 102, 241, 0.1); color: #6366f1; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                <i class="fas fa-database"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <p class="text-muted small mb-1">ACTIVE NOW</p>
                <h3>@ViewBag.ActiveVisits</h3>
            </div>
            <div style="width: 48px; height: 48px; background: rgba(16, 185, 129, 0.1); color: #10B981; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                <i class="fas fa-walking"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <p class="text-muted small mb-1">EXPECTED TODAY</p>
                <h3>@ViewBag.PendingVisits</h3>
            </div>
            <div style="width: 48px; height: 48px; background: rgba(245, 158, 11, 0.1); color: #F59E0B; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                <i class="fas fa-clock"></i>
            </div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="section-card mb-4">
    <form method="get" action="/User/Visit">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="nexus-label">SEARCH IDENTITY</label>
                <input type="text" name="search" value="@ViewBag.Search" class="nexus-input" placeholder="Name or phone...">
            </div>
            <div class="col-md-2">
                <label class="nexus-label">STATUS</label>
                <select name="status" class="nexus-input">
                    <option value="">All Statuses</option>
                    <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending")">Pending</option>
                    <option value="Active" selected="@(ViewBag.StatusFilter == "Active")">Checked In</option>
                    <option value="CheckedOut" selected="@(ViewBag.StatusFilter == "CheckedOut")">Completed</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="nexus-label">FROM DATE</label>
                <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="nexus-input">
            </div>
            <div class="col-md-2">
                <label class="nexus-label">TO DATE</label>
                <input type="date" name="dateTo" value="@ViewBag.DateTo" class="nexus-input">
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="premium-btn flex-grow-1">
                    <i class="fas fa-filter me-2"></i>Apply
                </button>
                <a href="/User/VisitReport" class="premium-btn secondary">
                    <i class="fas fa-file-export"></i>
                </a>
            </div>
        </div>
    </form>
</div>

<!-- Entry Logs Table -->
<div class="section-card animate-fade-up">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h5 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">Entry Logs</h5>
            <p class="text-muted small mb-0">Detailed history of all check-ins and check-outs.</p>
        </div>
        
        <div class="input-group" style="width: 280px;">
            <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px; border-color: #e2e8f0;"><i class="fas fa-search text-muted"></i></span>
            <input type="text" class="form-control bg-light border-start-0" id="tableSearchInput" placeholder="Quick search..." onkeyup="filterTable()" style="border-radius: 0 10px 10px 0; border-color: #e2e8f0; font-size: 0.9rem;">
        </div>
    </div>

    <div class="nexus-table-wrapper">
        <div class="table-responsive">
            <table class="nexus-table" id="standardTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Visitor Details</th>
                        <th>Host Details</th>
                        <th>Timing (In/Out)</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        int i = 1;
                        foreach (var v in Model)
                        {
                            string dur = "—";
                            if (v.CheckOutTime.HasValue)
                            {
                                int mins = (int)(v.CheckOutTime.Value - v.CheckInTime).TotalMinutes;
                                dur = mins >= 60 ? $"{mins / 60}h {mins % 60}m" : $"{mins}m";
                            }
                            <tr class="hover-row" style="cursor: pointer;" onclick="if(!event.target.closest('.tool-btn')) { window.location.href='/User/VisitDetail/@v.VisitId'; }">
                                <td style="width: 60px;"><span class="nexus-badge nexus-badge-info">@i</span></td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-800" style="width: 38px; height: 38px; font-size: 0.85rem; border: 1px solid rgba(99, 102, 241, 0.1);">
                                            @if (!string.IsNullOrEmpty(v.Visitor?.CapturePhoto))
                                            {
                                                <img src="@v.Visitor.CapturePhoto" class="w-100 h-100 rounded-circle" style="object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <span>@(v.Visitor?.Name != null && v.Visitor.Name.Length > 0 ? v.Visitor.Name[0].ToString().ToUpper() : "?")</span>
                                            }
                                        </div>
                                        <div>
                                            <div class="fw-700 text-dark mb-1">@(v.Visitor?.Name ?? "Unknown")</div>
                                            <small class="text-muted font-monospace" style="font-size: 0.7rem;">@v.PassNumber</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-700 text-primary mb-1">@(v.Employee?.Name ?? v.Visitor?.WhomeToMeet ?? "—")</div>
                                    <span class="nexus-badge nexus-badge-info" style="font-size: 0.6rem;">@(v.Employee?.Department?.DepartmentName ?? "General")</span>
                                </td>
                                <td>
                                    @if (v.Status != "Pending")
                                    {
                                        <div class="d-flex flex-column gap-1">
                                            <span class="text-success small fw-700"><i class="fas fa-sign-in-alt me-1"></i> @v.CheckInTime.ToString("dd MMM, HH:mm")</span>
                                            @if (v.CheckOutTime.HasValue)
                                            {
                                                <span class="text-danger small fw-700"><i class="fas fa-sign-out-alt me-1"></i> @v.CheckOutTime.Value.ToString("dd MMM, HH:mm")</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic small">Registry Pending</span>
                                    }
                                </td>
                                <td><span class="fw-800 text-dark font-monospace">@dur</span></td>
                                <td>
                                    @{
                                        var (statusBadge, statusText) = v.Status switch
                                        {
                                            "Active" => ("nexus-badge-success", "Inside"),
                                            "Pending" => ("nexus-badge-warning", "Pending"),
                                            _ => ("nexus-badge-danger", "Completed")
                                        };
                                    }
                                    <span class="nexus-badge @statusBadge">@statusText</span>
                                </td>
                                <td class="text-end">
                                    <a href="/User/ScanQR" class="tool-btn success" title="Scan QR">
                                        <i class="fas fa-qrcode"></i>
                                    </a>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="opacity-25 mb-3"><i class="fas fa-history fa-3x"></i></div>
                                <p class="text-muted fw-600">No activity logs found for the selected criteria.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.Pagination != null)
    {
        var pModel = (VMSProject.Models.PaginationViewModel)ViewBag.Pagination;
        @if (pModel.TotalPages > 0)
        {
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mt-4 px-2">
                <div class="text-muted small fw-600">
                    Showing @(((pModel.CurrentPage - 1) * pModel.PageSize) + 1) to @(Math.Min(pModel.CurrentPage * pModel.PageSize, pModel.TotalItems)) of @pModel.TotalItems entries
                </div>
                <div class="d-flex align-items-center gap-3">
                    <select class="form-select form-select-sm rounded-pill px-3" onchange="updatePageSize(this.value)" style="width: auto; border-color: #e2e8f0; font-weight: 600;">
                        <option value="15" selected="@(pModel.PageSize == 15)">15 per page</option>
                        <option value="30" selected="@(pModel.PageSize == 30)">30 per page</option>
                        <option value="50" selected="@(pModel.PageSize == 50)">50 per page</option>
                    </select>
                    <nav>
                        <ul class="pagination pagination-sm mb-0 gap-1">
                            @if (pModel.HasPreviousPage)
                            {
                                var prevVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = (pModel.CurrentPage - 1).ToString() };
                                <li class="page-item"><a href="@Url.Action(pModel.Action, pModel.Controller, prevVals)" class="page-link rounded-circle border-0 bg-light text-dark"><i class="fas fa-chevron-left"></i></a></li>
                            }
                            @for (int j = Math.Max(1, pModel.CurrentPage - 2); j <= Math.Min(pModel.TotalPages, pModel.CurrentPage + 2); j++)
                            {
                                var pageVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = j.ToString() };
                                <li class="page-item"><a href="@Url.Action(pModel.Action, pModel.Controller, pageVals)" class="page-link rounded-circle border-0 @(j == pModel.CurrentPage ? "bg-primary text-white shadow-sm" : "bg-light text-dark")" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-weight: 700;">@j</a></li>
                            }
                            @if (pModel.HasNextPage)
                            {
                                var nextVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = (pModel.CurrentPage + 1).ToString() };
                                <li class="page-item"><a href="@Url.Action(pModel.Action, pModel.Controller, nextVals)" class="page-link rounded-circle border-0 bg-light text-dark"><i class="fas fa-chevron-right"></i></a></li>
                            }
                        </ul>
                    </nav>
                </div>
            </div>
            <script>
                    function updatePageSize(size) {
                        const url = new URL(window.location.href);
                        url.searchParams.set('pageSize', size);
                        url.searchParams.set('page', '1');
                        window.location.href = url.toString();
                    }
            </script>
        }
    }
</div>

@section Scripts {
    <script>
    </script>
}

@model List<VMSProject.Models.Visit>
@{
    Layout = "UserLayout";
    ViewData["Title"] = "Visit Logs";
}

<div class="stat-card-row">
    <div class="user-stat-card">
        <div class="stat-info">
            <span class="stat-label">Total Logs</span>
            <span class="stat-value">@ViewBag.TotalVisits</span>
        </div>
        <div class="stat-icon" style="background: #3B82F6;"><i class="fas fa-database"></i></div>
    </div>
    <div class="user-stat-card">
        <div class="stat-info">
            <span class="stat-label">Active Now</span>
            <span class="stat-value">@ViewBag.ActiveVisits</span>
        </div>
        <div class="stat-icon" style="background: #10B981;"><i class="fas fa-walking"></i></div>
    </div>
    <div class="user-stat-card">
        <div class="stat-info">
            <span class="stat-label">Expected Today</span>
            <span class="stat-value">@ViewBag.PendingVisits</span>
        </div>
        <div class="stat-icon" style="background: #F59E0B;"><i class="fas fa-clock"></i></div>
    </div>
</div>

<!-- Standardized Filter Section -->
<form method="get" action="/User/Visit" class="filter-section">
    <div class="filter-grid">
        <div class="filter-group">
            <label>Search Identity</label>
            <input type="text" name="search" value="@ViewBag.Search" class="filter-control" placeholder="Visitor name or phone...">
        </div>
        <div class="filter-group">
            <label>Status</label>
            <select name="status" class="filter-control">
                <option value="">All Statuses</option>
                <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending")">Pending</option>
                <option value="Active" selected="@(ViewBag.StatusFilter == "Active")">Checked In</option>
                <option value="CheckedOut" selected="@(ViewBag.StatusFilter == "CheckedOut")">Completed</option>
            </select>
        </div>
        <div class="filter-group">
            <label>From Date</label>
            <input type="date" name="dateFrom" value="@ViewBag.DateFrom" class="filter-control">
        </div>
        <div class="filter-group">
            <label>To Date</label>
            <input type="date" name="dateTo" value="@ViewBag.DateTo" class="filter-control">
        </div>
        <div class="d-flex gap-2 align-items-end">
            <button type="submit" class="btn btn-primary fw-bold px-4 rounded-3 shadow-sm h-100"><i class="fas fa-filter me-2"></i>Filter</button>
            <a href="/User/VisitReport" class="btn btn-outline-primary fw-bold px-4 rounded-3 shadow-sm h-100 d-flex align-items-center"><i class="fas fa-chart-bar me-2"></i>Report</a>
        </div>
    </div>
</form>

<div class="table-section">
    <div class="table-header-title d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center">
            <i class="fas fa-calendar-check me-2 text-primary"></i>
            <span class="fw-800 text-dark" style="font-size: 1.1rem; letter-spacing: -0.5px;">Entry Logs</span>
        </div>
        
        <div class="d-flex align-items-center gap-2 flex-wrap ms-auto">
            <div class="input-group input-group-sm" style="width: 280px;">
                <span class="input-group-text bg-light border-end-0 border-light"><i class="fas fa-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0 ps-0 shadow-none bg-light border-light" id="tableSearchInput" placeholder="Search by visitor name or mobile..." onkeyup="filterTable()">
            </div>
        </div>
    </div>

    <div style="overflow-x: auto;">
        <table class="user-table" id="standardTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Visitor</th>
                    <th>Host Person</th>
                    <th>Check In / Out</th>
                    <th>Duration</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    int i = 1;
                    foreach (var v in Model)
                    {
                        string dur = "—";
                        if (v.CheckOutTime.HasValue)
                        {
                            int mins = (int)(v.CheckOutTime.Value - v.CheckInTime).TotalMinutes;
                            dur = mins >= 60 ? $"{mins/60}h {mins%60}m" : $"{mins}m";
                        }
                        <tr onclick="if(!event.target.closest('.acts-group')) { window.location.href='/User/VisitDetail/@v.VisitId'; }" style="cursor: pointer;" class="hover-row">
                            <td><span class="badge bg-light text-secondary border rounded-pill">@i</span></td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-bold me-3 shadow-sm overflow-hidden" style="width: 38px; height: 38px; border: 1px solid rgba(59, 130, 246, 0.2);">
                                        @if (!string.IsNullOrEmpty(v.Visitor?.CapturePhoto))
                                        {
                                            <img src="@v.Visitor.CapturePhoto" alt="" class="w-100 h-100" style="object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <span>@(v.Visitor?.Name != null && v.Visitor.Name.Length > 0 ? v.Visitor.Name[0].ToString().ToUpper() : "?")</span>
                                        }
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@(v.Visitor?.Name ?? "Unknown")</div>
                                        <small class="text-muted text-uppercase font-monospace">@v.PassNumber</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="fw-bold text-primary">@(v.Employee?.Name ?? v.Visitor?.WhomeToMeet ?? "—")</div>
                                <small class="text-muted">@(v.Employee?.Department?.DepartmentName ?? "General")</small>
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    @if (v.Status != "Pending")
                                    {
                                        <span class="text-success small fw-bold"><i class="fas fa-sign-in-alt me-1"></i> @v.CheckInTime.ToString("dd MMM · HH:mm")</span>
                                        if (v.CheckOutTime.HasValue)
                                        {
                                            <span class="text-danger small fw-bold"><i class="fas fa-sign-out-alt me-1"></i> @v.CheckOutTime.Value.ToString("dd MMM · HH:mm")</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic small">Registry Pending</span>
                                    }
                                </div>
                            </td>
                            <td><span class="fw-bold font-monospace">@dur</span></td>
                            <td>
                                @{
                                    var statusClass = v.Status switch {
                                        "Active" => "bg-success",
                                        "Pending" => "bg-warning",
                                        _ => "bg-secondary"
                                    };
                                    var statusText = v.Status == "Active" ? "Inside" : (v.Status == "CheckedOut" ? "Completed" : v.Status);
                                }
                                <span class="badge @statusClass px-3 py-2 rounded-pill shadow-sm" style="font-size: 0.7rem;">@statusText</span>
                            </td>
                            <td>
                                <div class="acts-group">
                                    <a href="/User/ScanQR" class="act-btn act-qr" title="Scan QR Code"><i class="fas fa-qrcode"></i></a>
                                </div>
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">No activity records found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.Pagination != null)
    {
        var pModel = (VMSProject.Models.PaginationViewModel)ViewBag.Pagination;
        @if (pModel.TotalPages > 0)
        {
            <div class="pagination-container">
                <div class="pagination-info">
                    Showing @(((pModel.CurrentPage - 1) * pModel.PageSize) + 1) to @(Math.Min(pModel.CurrentPage * pModel.PageSize, pModel.TotalItems)) of @pModel.TotalItems entries
                </div>
                <div class="pagination-controls">
                    <div class="page-size-selector">
                        <select class="page-size-select" onchange="updatePageSize(this.value)">
                            <option value="15" selected="@(pModel.PageSize == 15)">15</option>
                            <option value="30" selected="@(pModel.PageSize == 30)">30</option>
                            <option value="50" selected="@(pModel.PageSize == 50)">50</option>
                        </select>
                    </div>
                    <div class="custom-pagination">
                        @if (pModel.HasPreviousPage) {
                            var prevVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = (pModel.CurrentPage - 1).ToString() };
                            <a href="@Url.Action(pModel.Action, pModel.Controller, prevVals)" class="page-link-custom">Previous</a>
                        } else { <span class="page-link-custom disabled">Previous</span> }
                        @{
                            int startPage = Math.Max(1, pModel.CurrentPage - 2);
                            int endPage = Math.Min(pModel.TotalPages, startPage + 4);
                            if (endPage - startPage < 4) startPage = Math.Max(1, endPage - 4);
                        }
                        @for (int j = startPage; j <= endPage; j++) {
                            var pageVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = j.ToString() };
                            <a href="@Url.Action(pModel.Action, pModel.Controller, pageVals)" class="page-link-custom @(j == pModel.CurrentPage ? "active" : "")">@j</a>
                        }
                        @if (pModel.HasNextPage) {
                            var nextVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = (pModel.CurrentPage + 1).ToString() };
                            <a href="@Url.Action(pModel.Action, pModel.Controller, nextVals)" class="page-link-custom">Next</a>
                        } else { <span class="page-link-custom disabled">Next</span> }
                    </div>
                </div>
            </div>
            <script>
                function updatePageSize(size) {
                    const url = new URL(window.location.href);
                    url.searchParams.set('pageSize', size);
                    url.searchParams.set('page', '1');
                    window.location.href = url.toString();
                }
            </script>
        }
    }
</div>

@section Scripts {
    <script>
        function filterTable() {
            var input, filter, table, tr, td, i, j, txtValue, found;
            input = document.getElementById("tableSearchInput");
            filter = input.value.toUpperCase();
            table = document.getElementById("standardTable");
            tr = table.getElementsByTagName("tr");

            for (i = 1; i < tr.length; i++) {
                td = tr[i].getElementsByTagName("td");
                found = false;
                for (j = 0; j < td.length; j++) {
                    if (td[j]) {
                        txtValue = td[j].textContent || td[j].innerText;
                        if (txtValue.toUpperCase().indexOf(filter) > -1) {
                            found = true;
                            break;
                        }
                    }
                }
                if (found) { tr[i].style.display = ""; } else { tr[i].style.display = "none"; }
            }
        }
    </script>
}

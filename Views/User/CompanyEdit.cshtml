@model VMSProject.Models.CompanyModel
@{
    Layout = "UserLayout";
    ViewData["Title"] = "Edit Company Settings";
}

<div class="row justify-content-center">
    <div class="col-xl-9">
        <div class="table-section p-0 border-0 shadow-lg rounded-4 overflow-hidden bg-white">
            <div class="p-4 bg-primary text-white d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="bg-white bg-opacity-20 p-3 rounded-3 me-3">
                        <i class="fas fa-building-circle-gear fs-4"></i>
                    </div>
                    <div>
                        <h5 class="fw-800 mb-0">Company Settings</h5>
                        <p class="mb-0 small opacity-75">Update configuration for @Model.CompanyName</p>
                    </div>
                </div>
                <a href="/Company/Index" class="btn btn-light btn-sm fw-bold px-3 rounded-pill">
                    <i class="fas fa-arrow-left me-1"></i> Back to List
                </a>
            </div>

            <form asp-action="Edit" asp-controller="Company" method="post" enctype="multipart/form-data" class="p-5">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="CompanyId" />

                <!-- Corporate Identity -->
                <div class="mb-5">
                    <h6 class="text-primary fw-800 text-uppercase small letter-spacing-1 mb-4">
                        <i class="fas fa-id-card me-2"></i> Corporate Identity
                    </h6>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-700 text-muted small uppercase">Company Name</label>
                            <input asp-for="CompanyName" type="text" class="form-control py-3 px-4 rounded-3 border-light bg-light" placeholder="Legal Entity Name" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-700 text-muted small uppercase">Industry Type</label>
                            <select asp-for="Industry" class="form-select py-3 px-4 rounded-3 border-light bg-light" required>
                                <option value="IT & Software">IT & Software</option>
                                <option value="Manufacturing">Manufacturing</option>
                                <option value="Education">Education</option>
                                <option value="Consultancy">Consultancy</option>
                                <option value="Finance">Finance</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-700 text-muted small uppercase">Company Logo</label>
                            <div class="d-flex align-items-center gap-4 p-4 border border-light rounded-4 bg-light bg-opacity-50">
                                <div class="rounded-3 border bg-white p-1 shadow-sm overflow-hidden" style="width: 80px; height: 80px; min-width: 80px;">
                                    @if (!string.IsNullOrEmpty(Model.LogoPath)) {
                                        <img src="@Model.LogoPath" class="w-100 h-100 object-fit-cover" alt="Logo" />
                                    } else {
                                        <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary fw-800 fs-4">
                                            @(Model.CompanyName?[0].ToString().ToUpper() ?? "C")
                                        </div>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <input type="file" name="CompanyLogo" class="form-control border-0 bg-white shadow-sm rounded-pill py-2 px-4" accept="image/*" />
                                    <p class="text-muted small mt-2 mb-0 ms-2">Recommended: 512x512px, PNG/JPG</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-700 text-muted small uppercase">GST Number</label>
                            <input asp-for="GSTNumber" type="text" class="form-control py-3 px-4 rounded-3 border-light bg-light" placeholder="Official Reference" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-700 text-muted small uppercase">Official Email</label>
                            <input asp-for="OfficialEmail" type="email" class="form-control py-3 px-4 rounded-3 border-light bg-light" placeholder="corporate@entity.com" required />
                        </div>
                    </div>
                </div>

                <!-- Geographic Coordinates -->
                <div class="mb-5">
                    <h6 class="text-primary fw-800 text-uppercase small letter-spacing-1 mb-4">
                        <i class="fas fa-location-dot me-2"></i> Headquarters Address
                    </h6>
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="form-label fw-700 text-muted small uppercase">Full Address</label>
                            <input asp-for="Address" type="text" class="form-control py-3 px-4 rounded-3 border-light bg-light" placeholder="Primary physical location" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-700 text-muted small uppercase">City</label>
                            <input asp-for="City" class="form-control py-3 px-4 rounded-3 border-light bg-light" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-700 text-muted small uppercase">State</label>
                            <input asp-for="State" class="form-control py-3 px-4 rounded-3 border-light bg-light" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-700 text-muted small uppercase">Pincode</label>
                            <input asp-for="Pincode" class="form-control py-3 px-4 rounded-3 border-light bg-light" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-700 text-muted small uppercase">Contact Number</label>
                            <input asp-for="ContactNumber" class="form-control py-3 px-4 rounded-3 border-light bg-light" required />
                        </div>
                    </div>
                </div>

                <!-- Administrative Privilege -->
                <div class="mb-5">
                    <h6 class="text-primary fw-800 text-uppercase small letter-spacing-1 mb-4">
                        <i class="fas fa-user-shield me-2"></i> Administrator Settings
                    </h6>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label fw-700 text-muted small uppercase">Admin Name</label>
                            <input asp-for="AdminName" type="text" class="form-control py-3 px-4 rounded-3 border-light bg-light" placeholder="Lead Administrator" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-700 text-muted small uppercase">Admin Email</label>
                            <input asp-for="AdminEmail" type="email" class="form-control py-3 px-4 rounded-3 border-light bg-light" placeholder="admin@entity.com" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-700 text-muted small uppercase">Access Password</label>
                            <input asp-for="Password" type="password" class="form-control py-3 px-4 rounded-3 border-light bg-light" value="@Model.Password" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-700 text-muted small uppercase">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control py-3 px-4 rounded-3 border-light bg-light" value="@Model.Password" required />
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 pt-4 border-top">
                    <a href="/Company/Index" class="btn btn-light py-3 px-5 rounded-pill fw-bold border">Cancel</a>
                    <button type="submit" class="btn btn-primary py-3 px-5 rounded-pill fw-800 shadow-lg">
                        <i class="fas fa-check-double me-2"></i> SAVE ALL CHANGES
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            if ("@ViewBag.Success" === "True") {
                // Success message
                alert("✨ Company settings updated successfully.");
                window.location.href = "/Company/Index";
            }
        });
    </script>
}

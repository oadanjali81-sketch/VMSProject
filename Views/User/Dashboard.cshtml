@{
    Layout = "UserLayout";
    ViewData["Title"] = "Dashboard";
}


<!-- Statistics Grid -->
<div class="row g-4 mb-5">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card d-flex align-items-center justify-content-between">
            <div>
                <p class="section-title-sm mb-2" style="font-size: 0.65rem;">Total Visitors</p>
                <h3 class="mb-0">@ViewBag.TotalVisitors</h3>
            </div>
            <div style="width: 54px; height: 54px; background: rgba(99, 102, 241, 0.1); color: #6366f1; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                <i class="fas fa-users"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card d-flex align-items-center justify-content-between">
            <div>
                <p class="section-title-sm mb-2" style="font-size: 0.65rem;">Active Employees</p>
                <h3 class="mb-0">@ViewBag.TotalEmployees</h3>
            </div>
            <div style="width: 54px; height: 54px; background: rgba(16, 185, 129, 0.1); color: #10B981; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                <i class="fas fa-user-tie"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card d-flex align-items-center justify-content-between">
            <div>
                <p class="section-title-sm mb-2" style="font-size: 0.65rem;">Today's Entries</p>
                <h3 class="mb-0">@ViewBag.TodayVisits</h3>
            </div>
            <div style="width: 54px; height: 54px; background: rgba(245, 158, 11, 0.1); color: #F59E0B; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                <i class="fas fa-calendar-check"></i>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card d-flex align-items-center justify-content-between">
            <div>
                <p class="section-title-sm mb-2" style="font-size: 0.65rem;">Currently Inside</p>
                <h3 class="mb-0">@ViewBag.ActiveVisits</h3>
            </div>
            <div style="width: 54px; height: 54px; background: rgba(239, 68, 68, 0.1); color: #EF4444; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                <i class="fas fa-door-open"></i>
            </div>
        </div>
    </div>
</div>

<!-- Activity & Actions Grid -->
<div class="row g-4">
    <!-- Recent Activity Table -->
    <div class="col-xl-8">
        <div class="section-card h-100 p-0 border-0">
            <div class="px-4 py-4 d-flex justify-content-between align-items-center border-bottom">
                <h5 class="mb-0 text-dark fw-800">Recent Visitors Activity</h5>
                <a href="/User/Visit" class="premium-btn secondary px-3 py-2 uppercase" style="font-size: 0.7rem;">View Detailed Log</a>
            </div>
            <div class="p-0">
                <div class="table-responsive">
                    <table class="nexus-table mb-0">
                        <thead>
                            <tr>
                                <th>Visitor Name</th>
                                <th>Host Employee</th>
                                <th>Check-in Time</th>
                                <th class="text-center">Current Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentVisits != null)
                            {
                                var recentVisits = (IEnumerable<dynamic>)ViewBag.RecentVisits;
                                foreach (var visit in recentVisits.Take(3))
                                {
                                    bool isActive = visit.Status == "Active";
                                    string badgeClass = isActive ? "nexus-badge-success" : "nexus-badge-info";
                                    string icon = isActive ? "fa-circle-check" : "fa-clock-rotate-left";
                                    
                                    <tr class="hover-row">
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-800" style="width: 32px; height: 32px; font-size: 0.75rem;">
                                                    @(visit.VisitorName?[0].ToString().ToUpper() ?? "?")
                                                </div>
                                                <span class="fw-700 text-dark">@visit.VisitorName</span>
                                            </div>
                                        </td>
                                        <td><div class="text-muted fw-600">@visit.EmployeeName</div></td>
                                        <td><div class="text-muted small fw-500"><i class="far fa-clock me-1"></i> @visit.VisitDate.ToString("MMM dd, hh:mm tt")</div></td>
                                        <td class="text-center">
                                            <span class="nexus-badge @badgeClass">
                                                <i class="fas @icon me-1"></i> @visit.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5">
                                        <div class="opacity-25 mb-2"><i class="fas fa-folder-open fa-3x"></i></div>
                                        <p class="text-muted small fw-700 uppercase letter-spacing-1">No Visitation Records Found</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions Panel -->
    <div class="col-xl-4">
        <div class="section-card h-100 border-0">
            <div class="mb-4 pb-2 border-bottom">
                <h5 class="text-dark fw-800 mb-1">Quick Action</h5>
                <p class="text-muted small mb-0">Management shortcuts for quick access.</p>
            </div>
            
            <div class="d-flex flex-column gap-3">
                <a href="/User/ScanQR" class="premium-btn w-100 py-3 shadow-sm">
                    <i class="fas fa-qrcode fs-5"></i>
                    <span>Start Entry Scan</span>
                </a>
                
                <a href="/User/VisitorManagement" class="premium-btn secondary w-100 py-3" style="border-color: var(--nexus-primary); color: var(--nexus-primary);">
                    <i class="fas fa-user-plus fs-5"></i>
                    <span>Register New Visitor</span>
                </a>
                
                <a href="/User/AllQRCodes" class="premium-btn secondary w-100 py-3">
                    <i class="fas fa-id-card fs-5"></i>
                    <span>Manage Active Passes</span>
                </a>
                
                
            </div>
        </div>
    </div>
</div>

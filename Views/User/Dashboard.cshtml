@{
    Layout = "UserLayout";
    ViewData["Title"] = "User Dashboard";
}

<!-- Row 1: Primary Stats -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stat-card-nexus">
            <div>
                <p class="stat-card-label" style="color: #3B82F6;">TOTAL VISITORS</p>
                <h3 class="stat-card-value">@ViewBag.TotalVisitors</h3>
            </div>
            <div class="stat-card-icon" style="background: rgba(59,130,246,0.1); color: #3B82F6;">
                <i class="fas fa-users"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card-nexus">
            <div>
                <p class="stat-card-label" style="color: #10B981;">TOTAL EMPLOYEES</p>
                <h3 class="stat-card-value">@ViewBag.TotalEmployees</h3>
            </div>
            <div class="stat-card-icon" style="background: rgba(16,185,129,0.1); color: #10B981;">
                <i class="fas fa-user"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card-nexus">
            <div>
                <p class="stat-card-label" style="color: #F59E0B;">TODAY'S VISITS</p>
                <h3 class="stat-card-value">@ViewBag.TodayVisits</h3>
            </div>
            <div class="stat-card-icon" style="background: rgba(245,158,11,0.1); color: #F59E0B;">
                <i class="fas fa-calendar"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card-nexus">
            <div>
                <p class="stat-card-label" style="color: #EF4444;">ACTIVE INSIDE</p>
                <h3 class="stat-card-value">@ViewBag.ActiveVisits</h3>
            </div>
            <div class="stat-card-icon" style="background: rgba(239,68,68,0.1); color: #EF4444;">
                <i class="fas fa-door-open"></i>
            </div>
        </div>
    </div>
</div>

<!-- Row 2: Recent Visits + Quick Actions -->
<div class="row g-4">
    <div class="col-xl-8">
        <div class="section-card-nexus">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0 d-flex align-items-center" style="color: #1E293B; font-size: 1.1rem;">
                    <i class="fas fa-history me-2 text-primary"></i>Recent Visits
                </h5>
                <a href="/User/Visit" class="btn btn-sm btn-light border fw-bold px-3" style="border-radius: 8px;">View All</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead style="background: #1E293B; color: white;">
                        <tr>
                            <th style="padding: 15px; font-size: 0.75rem; text-transform: uppercase; font-weight: 700; border: none;">Visitor</th>
                            <th style="padding: 15px; font-size: 0.75rem; text-transform: uppercase; font-weight: 700; border: none;">Host</th>
                            <th style="padding: 15px; font-size: 0.75rem; text-transform: uppercase; font-weight: 700; border: none;">Date</th>
                            <th style="padding: 15px; font-size: 0.75rem; text-transform: uppercase; font-weight: 700; border: none;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.RecentVisits != null)
                        {
                            foreach (var visit in ViewBag.RecentVisits)
                            {
                                string statusBg = visit.Status == "Active" ? "#10B981" : "#64748B";
                                <tr>
                                    <td style="padding: 15px; font-weight: 600; color: #1E293B;">@visit.VisitorName</td>
                                    <td style="padding: 15px; color: #475569;">@visit.EmployeeName</td>
                                    <td style="padding: 15px; color: #64748B; font-size: 0.85rem;">@visit.VisitDate.ToString("MMM dd, hh:mm tt")</td>
                                    <td style="padding: 15px;">
                                        <span class="badge" style="background: @statusBg; color: white; padding: 6px 14px; border-radius: 6px; font-size: 0.7rem; font-weight: 700;">
                                            @visit.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center py-5 text-muted">No recent records found</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick Actions Panel -->
    <div class="col-xl-4">
        <div class="section-card-nexus">
            <div class="mb-4">
                <h5 class="fw-bold mb-0 d-flex align-items-center" style="color: #1E293B; font-size: 1.1rem;">
                    <i class="fas fa-bolt me-2 text-warning"></i>Quick Actions
                </h5>
            </div>
            <div class="d-flex flex-column gap-3">
                <a href="/User/ScanQR" class="btn btn-primary w-100 py-3 fw-bold d-flex align-items-center justify-content-center gap-2" style="border-radius: 10px; font-size: 0.95rem; background: #2563EB; border: none;">
                    <i class="fas fa-qrcode"></i> Scan QR Pass
                </a>
                <a href="/User/AddVisitor" class="btn btn-outline-primary w-100 py-3 fw-bold d-flex align-items-center justify-content-center gap-2" style="border-radius: 10px; font-size: 0.95rem; border: 2px solid #2563EB; color: #2563EB; background: white;">
                    <i class="fas fa-user-plus"></i> Register New Visitor
                </a>
                <a href="/User/AllQRCodes" class="btn btn-outline-secondary w-100 py-3 fw-bold d-flex align-items-center justify-content-center gap-2" style="border-radius: 10px; font-size: 0.95rem; border: 2px solid #E2E8F0; color: #475569; background: white;">
                    <i class="fas fa-id-card"></i> View All Passes
                </a>
                <a href="/User/Employee" class="btn btn-outline-success w-100 py-3 fw-bold d-flex align-items-center justify-content-center gap-2" style="border-radius: 10px; font-size: 0.95rem; border: 2px solid #10B981; color: #10B981; background: white;">
                    <i class="fas fa-plus-circle"></i> Add Employee
                </a>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* ═══ NEXUS DASHBOARD DESIGN SYSTEM ═══ */
        .stat-card-nexus {
            background: #FFFFFF;
            border-radius: 16px;
            padding: 22px 24px;
            border: 1px solid #E2E8F0;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .stat-card-nexus:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.06);
            border-color: #3B82F6;
        }
        .stat-card-label {
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 8px;
        }
        .stat-card-value {
            font-size: 1.75rem;
            font-weight: 800;
            color: #1E293B;
            margin: 0;
            line-height: 1;
        }
        .stat-card-icon {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.25rem;
        }

        .section-card-nexus {
            background: #FFFFFF;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 0;
            border: 1px solid #E2E8F0;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }
    </style>
}

@section Scripts {
}

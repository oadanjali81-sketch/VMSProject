@{
    Layout = "UserLayout";
    ViewData["Title"] = "QR Access Scanner";
}

<div class="row g-4">
    <!-- Live Scanner Console -->
    <div class="col-xl-8">
        <div class="section-card h-100 animate-fade-up">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
                <div>
                    <h5 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">Scanner Console</h5>
                    <p class="text-muted small mb-0">Live visitor check-in/out via QR pass verification.</p>
                </div>
                
                <div class="d-flex align-items-center gap-2">
                    <button id="switchCameraBtn" class="premium-btn secondary py-2 px-3" style="display:none;"><i class="fas fa-sync me-2"></i>Switch</button>
                    <button id="manualEntryBtn" class="premium-btn secondary py-2 px-3" onclick="toggleManualEntry()"><i class="fas fa-keyboard me-2"></i>Manual Entry</button>
                </div>
            </div>

            <div class="p-2 p-md-4 bg-light rounded-4 border border-white" style="background: rgba(248, 250, 252, 0.6) !important;">
                <div class="scanner-video-wrap shadow-lg mx-auto" style="max-width: 100%; position: relative; background: #000; border-radius: 24px; overflow: hidden; min-height: 480px; display: flex; align-items: center; justify-content: center; border: 4px solid #fff;">
                    <video id="scannerVideo" autoplay playsinline muted style="width: 100%; height: 100%; object-fit: cover;"></video>
                    <canvas id="scannerCanvas" style="display:none;"></canvas>
                    
                    <div class="scanner-overlay" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; pointer-events: none; display: flex; align-items: center; justify-content: center;">
                        <div class="scanner-frame" style="width: 280px; height: 280px; border: 2px solid rgba(255,255,255,0.4); border-radius: 32px; position: relative;">
                            <div class="scanner-line" style="position: absolute; width: 100%; height: 2px; background: var(--nexus-primary); box-shadow: 0 0 20px var(--nexus-primary); top: 0; animation: scanline 2.5s linear infinite;"></div>
                            <!-- Corner Accents -->
                            <div style="position: absolute; top: -5px; left: -5px; width: 30px; height: 30px; border-top: 5px solid var(--nexus-primary); border-left: 5px solid var(--nexus-primary); border-radius: 12px 0 0 0;"></div>
                            <div style="position: absolute; top: -5px; right: -5px; width: 30px; height: 30px; border-top: 5px solid var(--nexus-primary); border-right: 5px solid var(--nexus-primary); border-radius: 0 12px 0 0;"></div>
                            <div style="position: absolute; bottom: -5px; left: -5px; width: 30px; height: 30px; border-bottom: 5px solid var(--nexus-primary); border-left: 5px solid var(--nexus-primary); border-radius: 0 0 0 12px;"></div>
                            <div style="position: absolute; bottom: -5px; right: -5px; width: 30px; height: 30px; border-bottom: 5px solid var(--nexus-primary); border-right: 5px solid var(--nexus-primary); border-radius: 0 0 12px 0;"></div>
                        </div>
                    </div>
                    
                    <div id="scannerStatus" style="position: absolute; bottom: 30px; background: rgba(15, 23, 42, 0.85); color: #fff; padding: 10px 25px; border-radius: 50px; font-size: 0.85rem; backdrop-filter: blur(8px); font-weight: 600; border: 1px solid rgba(255,255,255,0.1);">
                        <i class="fas fa-circle-notch fa-spin me-2 text-primary"></i>Ready to Scan
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button id="startScanBtn" class="premium-btn py-3 px-5 rounded-pill shadow-lg" onclick="startScanner()" style="font-size: 1.1rem;">
                        <i class="fas fa-play-circle me-2"></i>START SCANNING
                    </button>
                    <button id="stopScanBtn" class="premium-btn py-3 px-5 rounded-pill shadow-lg bg-danger border-danger" onclick="stopScanner()" style="display:none; font-size: 1.1rem;">
                        <i class="fas fa-stop-circle me-2"></i>STOP SCANNER
                    </button>
                </div>

                <!-- Manual Entry Section -->
                <div id="manualEntryCard" class="mt-4" style="display:none; animation: fadeInUp 0.4s ease;">
                    <div class="d-flex justify-content-center">
                        <div class="input-group shadow-sm" style="max-width: 500px;">
                            <span class="input-group-text bg-white border-end-0 rounded-start-pill ps-4" style="border-color: #e2e8f0;"><i class="fas fa-id-card text-muted"></i></span>
                            <input type="text" id="manualPassInput" class="form-control border-start-0 border-end-0 py-3 ps-0 bg-white" placeholder="Type Pass ID (e.g. VIS-2026-X)..." style="border-color: #e2e8f0; font-weight: 600;">
                            <button onclick="processManualEntry()" class="premium-btn rounded-end-pill px-4" style="border-radius: 0 50px 50px 0;">VALIDATE</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Results and Activity Feed -->
    <div class="col-xl-4">
        <!-- Result Modal -->
        <div class="modal fade" id="scanResultModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                    <div id="modalHeader" class="px-4 py-4 text-center">
                        <div id="modalIcon" class="mb-3 text-white">
                            <!-- Icon injected by JS -->
                        </div>
                        <h4 class="fw-800 text-white mb-0" id="modalTitle">SCAN RESULT</h4>
                    </div>
                    <div class="modal-body p-4">
                        <div id="modalContent">
                            <!-- Content injected by JS -->
                        </div>
                    </div>
                    <div class="modal-footer border-top-0 px-4 pb-4 pt-0">
                        <button type="button" class="premium-btn secondary w-100 py-3 rounded-3 fw-800" data-bs-dismiss="modal">
                            <i class="fas fa-times me-2"></i> CLOSE OVERLAY
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hidden Audio for Beep -->
        <audio id="scanBeep" preload="auto">
            <source src="https://assets.mixkit.co/active_storage/sfx/2869/2869-preview.mp3" type="audio/mpeg">
        </audio>

        <!-- Activity Feed -->
        <div class="section-card h-100 p-0 overflow-hidden animate-fade-up" style="display: flex; flex-direction: column;">
            <div class="p-4 border-bottom d-flex align-items-center justify-content-between bg-light bg-opacity-50">
                <h6 class="fw-800 mb-0 text-dark"><i class="fas fa-clock-rotate-left me-2 text-primary"></i>Session Logs</h6>
                <button class="tool-btn danger" onclick="clearActivity()" title="Clear logs"><i class="fas fa-trash-alt"></i></button>
            </div>
            <div id="activityList" class="flex-grow-1 overflow-auto" style="max-height: 600px;">
                <div class="text-center py-5 text-muted activity-empty">
                    <div class="opacity-25 mb-3"><i class="fas fa-box-open fa-3x"></i></div>
                    <p class="small fw-600 mb-0">Waiting for first scan...</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes scanline { 0% { top: 0; } 50% { top: 100%; } 100% { top: 0; } }
    
    .activity-item { 
        padding: 20px; 
        border-bottom: 1px solid #f1f5f9; 
        transition: all 0.2s; 
        animation: fadeInUp 0.3s ease;
    }
    .activity-item:hover { background: #f8fafc; }
    
    .result-info { display: flex; flex-direction: column; gap: 15px; }
    .result-field { display: flex; flex-direction: column; gap: 4px; padding: 12px; background: #f8fafc; border-radius: 12px; border: 1px solid #f1f5f9; }
    .result-label { font-size: 0.65rem; color: #94a3b8; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
    .result-value { font-weight: 700; color: #1e293b; font-size: 0.95rem; }
</style>

@section Scripts {
    <script src="https://unpkg.com/jsqr@1.4.0/dist/jsQR.js"></script>
    <script src="/js/User/ScanQR.js"></script>
}

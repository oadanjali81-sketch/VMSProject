@{
    Layout = "UserLayout";
    ViewData["Title"] = "Visitor History";
}

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="section-card animate-fade-up">
            <div class="d-flex align-items-center gap-3">
                <div style="width: 50px; height: 50px; background: rgba(99, 102, 241, 0.1); color: #6366f1; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                    <i class="fas fa-history"></i>
                </div>
                <div>
                    <h5 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">@(Model.Visitor?.Name ?? "Visitor")'s History</h5>
                    <p class="text-muted small mb-0">Complete historical log of all visits by this individual.</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 d-flex align-items-center justify-content-end">
        <a href="/User/Visit" class="premium-btn secondary px-4">
            <i class="fas fa-arrow-left me-2"></i>Back to Entry Logs
        </a>
    </div>
</div>

<!-- Visitor History Table -->
@if (ViewBag.VisitorHistory != null)
{
    var history = (List<VMSProject.Models.Visit>)ViewBag.VisitorHistory;
    if (history.Count > 0)
    {
        <div class="section-card animate-fade-up">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h6 class="fw-800 text-dark mb-0 uppercase letter-spacing-1" style="font-size: 0.85rem;">
                    <i class="fas fa-list-ul me-2 text-primary"></i>Detailed Records
                </h6>
                <span class="nexus-badge nexus-badge-success">@history.Count TOTAL RECORDS</span>
            </div>

            <div class="nexus-table-wrapper">
                <div class="table-responsive">
                    <table class="nexus-table">
                        <thead>
                            <tr>
                                <th>Visit Date</th>
                                <th>Host Person</th>
                                <th>Purpose</th>
                                <th>Timing (In/Out)</th>
                                <th>Duration</th>
                                <th>Status</th>
                                <th class="text-end">Pass Number</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in history)
                            {
                                var hDur = "—";
                                if (h.CheckOutTime.HasValue)
                                {
                                    int mins = (int)(h.CheckOutTime.Value - h.CheckInTime).TotalMinutes;
                                    hDur = mins >= 60 ? $"{mins / 60}h {mins % 60}m" : $"{mins}m";
                                }
                                var (hBadge, hText) = h.Status switch
                                {
                                    "Active" => ("nexus-badge-success", "Inside"),
                                    "Pending" => ("nexus-badge-warning", "Pending"),
                                    _ => ("nexus-badge-danger", "Completed")
                                };

                                <tr class="hover-row">
                                    <td>
                                        <div class="fw-800 text-dark">@h.VisitDate.ToString("dd MMM, yyyy")</div>
                                    </td>
                                    <td>
                                        <div class="fw-800 text-primary mb-1">@(h.Employee?.Name ?? h.Visitor?.WhomeToMeet ?? "—")</div>
                                        <span class="nexus-badge nexus-badge-info" style="font-size: 0.6rem;">@(h.Employee?.Department?.DepartmentName ?? "General")</span>
                                    </td>
                                    <td>
                                        <div class="text-muted fw-600">@(h.Purpose ?? "—")</div>
                                    </td>
                                    <td>
                                        <div class="d-flex flex-column gap-1">
                                            @if (h.Status != "Pending")
                                            {
                                                <span class="text-success small fw-800"><i class="fas fa-sign-in-alt me-1"></i> @h.CheckInTime.ToString("hh:mm tt")</span>
                                                @if (h.CheckOutTime.HasValue)
                                                {
                                                    <span class="text-danger small fw-800"><i class="fas fa-sign-out-alt me-1"></i> @h.CheckOutTime.Value.ToString("hh:mm tt")</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted fst-italic small">Pending Check-in</span>
                                            }
                                        </div>
                                    </td>
                                    <td><span class="fw-800 text-dark font-monospace">@hDur</span></td>
                                    <td>
                                        <span class="nexus-badge @hBadge">@hText</span>
                                    </td>
                                    <td class="text-end">
                                        <div class="fw-800 font-monospace text-muted" style="font-size: 0.8rem;">@h.PassNumber</div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="section-card text-center py-5">
            <div class="opacity-25 mb-3"><i class="fas fa-history fa-3x"></i></div>
            <p class="text-muted fw-800">No historical records found for this visitor.</p>
        </div>
    }
}

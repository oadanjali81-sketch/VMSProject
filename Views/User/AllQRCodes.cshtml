@model List<VMSProject.Models.VisitorPassViewModel>
@{
    Layout = "UserLayout";
    ViewData["Title"] = "Visitor Passes";
    string? search = ViewBag.Search;
}

<div class="section-card mb-4 animate-fade-up">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div class="d-flex align-items-center gap-3">
            <div style="width: 50px; height: 50px; background: rgba(99, 102, 241, 0.1); color: #6366f1; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                <i class="fas fa-qrcode"></i>
            </div>
            <div>
                <h5 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">Visitor Passes</h5>
                <p class="text-muted small mb-0">Manage and distribute security access codes.</p>
            </div>
        </div>
        
        <div class="d-flex align-items-center gap-3">
            <span class="nexus-badge nexus-badge-success">
                <i class="fas fa-check-circle me-1"></i> @ViewBag.TotalWithQR ACTIVE PASSES
            </span>
        </div>
    </div>
</div>

<div class="section-card mb-4">
    <form method="get" action="/User/AllQRCodes">
        <input type="hidden" name="pageSize" value="@ViewBag.PageSize" />
        <div class="input-group" style="max-width: 500px;">
            <span class="input-group-text bg-light border-end-0" style="border-radius: 12px 0 0 12px; border-color: #e2e8f0;"><i class="fas fa-search text-muted"></i></span>
            <input type="text" name="search" value="@search" class="form-control bg-light border-start-0 py-2" placeholder="Search name, company or pass code..." style="border-color: #e2e8f0; font-weight: 600;">
            <button type="submit" class="premium-btn rounded-end-pill px-4" style="border-radius: 0 50px 50px 0;">Filter</button>
        </div>
    </form>
</div>

<div class="row g-4 animate-fade-up">
    @if (Model != null && Model.Count > 0)
    {
        foreach (var item in Model)
        {
            var v = item.Visitor;
            bool hasPass = !string.IsNullOrEmpty(item.LatestPassNumber);
            string qrUrl = hasPass
                ? $"https://api.qrserver.com/v1/create-qr-code/?size=220x220&color=000000&bgcolor=ffffff&qzone=1&data={Uri.EscapeDataString(item.LatestPassNumber!)}"
                : "";

            <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                <div class="section-card h-100 p-0 overflow-hidden pass-card-nexus @(hasPass ? "" : "opacity-75")">
                    <div class="p-4 text-center">
                        <div class="rounded-circle p-1 border border-primary border-opacity-10 d-inline-block mb-3 shadow-sm mx-auto">
                            <div class="rounded-circle overflow-hidden d-flex align-items-center justify-content-center bg-light" style="width: 70px; height: 70px;">
                                @if (!string.IsNullOrEmpty(v.CapturePhoto)) { 
                                    <img src="@v.CapturePhoto" alt="@v.Name" class="w-100 h-100" style="object-fit: cover;" /> 
                                } else { 
                                    <span class="fw-800 text-primary fs-3">@(v.Name?[0].ToString().ToUpper() ?? "?")</span> 
                                }
                            </div>
                        </div>

                        <h6 class="fw-800 text-dark mb-1" style="font-size: 1.1rem;">@v.Name</h6>
                        <p class="small text-muted mb-4 uppercase fw-800 letter-spacing-1" style="font-size: 0.65rem;">@(v.CompanyName ?? "INDIVIDUAL")</p>

                        @if (hasPass)
                        {
                            <div class="qr-container mb-3 p-3 bg-white border border-light rounded-4 shadow-sm d-inline-block">
                                <img src="@qrUrl" width="140" height="140" class="rounded-3" alt="QR" />
                            </div>
                            <div class="mb-4">
                                <span class="nexus-badge nexus-badge-info font-monospace py-2 px-3" style="font-size: 0.85rem; border: 1px dashed rgba(99, 102, 241, 0.3);">
                                    @item.LatestPassNumber
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="py-5 mb-3 bg-light rounded-4 border border-dashed border-2 opacity-50">
                                <i class="fas fa-qrcode fa-3x text-muted mb-2"></i>
                                <p class="small fw-800 text-muted mb-0 uppercase letter-spacing-1">No Pass Active</p>
                            </div>
                        }
                    </div>
                    
                    <div class="p-4 bg-light bg-opacity-50 border-top mt-auto">
                        <div class="d-flex gap-2">
                            @if (hasPass) {
                                <button class="premium-btn w-100 py-2" style="font-size: 0.8rem;" onclick="printPass('@v.Name', '@item.LatestPassNumber', '@qrUrl')">
                                    <i class="fas fa-print me-2"></i>PRINT
                                </button>
                                <button class="premium-btn secondary px-3 py-2" onclick="sharePass('@v.Name', '@item.LatestPassNumber', '@qrUrl')" title="Share">
                                    <i class="fas fa-share-nodes"></i>
                                </button>
                            } else {
                                <a href="/User/GenerateQR/@v.VisitorId" class="premium-btn w-100 py-2" style="font-size: 0.8rem;">
                                    <i class="fas fa-plus-circle me-2"></i>CREATE PASS
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="section-card text-center py-5">
                <div class="opacity-25 mb-3"><i class="fas fa-search fa-3x text-muted"></i></div>
                <p class="text-muted fw-800">No visitor passes found matching your search criteria.</p>
            </div>
        </div>
    }
</div>

@if (ViewBag.Pagination != null)
{
    var pModel = (VMSProject.Models.PaginationViewModel)ViewBag.Pagination;
    @if (pModel.TotalPages > 0)
    {
        <div class="section-card mt-4">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 px-2">
                <div class="text-muted small fw-600">
                    Showing @(((pModel.CurrentPage - 1) * pModel.PageSize) + 1) to @(Math.Min(pModel.CurrentPage * pModel.PageSize, pModel.TotalItems)) of @pModel.TotalItems entries
                </div>
                <div class="d-flex align-items-center gap-3">
                    <select class="form-select form-select-sm rounded-pill px-3" onchange="updatePageSize(this.value)" style="width: auto; border-color: #e2e8f0; font-weight: 600;">
                        <option value="12" selected="@(pModel.PageSize == 12)">12 per page</option>
                        <option value="24" selected="@(pModel.PageSize == 24)">24 per page</option>
                        <option value="48" selected="@(pModel.PageSize == 48)">48 per page</option>
                    </select>
                    <nav>
                        <ul class="pagination pagination-sm mb-0 gap-1">
                            @if (pModel.HasPreviousPage) {
                                var prevVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = (pModel.CurrentPage - 1).ToString() };
                                <li class="page-item"><a href="@Url.Action(pModel.Action, pModel.Controller, prevVals)" class="page-link rounded-circle border-0 bg-light text-dark"><i class="fas fa-chevron-left"></i></a></li>
                            }
                            @for (int i = Math.Max(1, pModel.CurrentPage - 2); i <= Math.Min(pModel.TotalPages, pModel.CurrentPage + 2); i++) {
                                var pageVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = i.ToString() };
                                <li class="page-item"><a href="@Url.Action(pModel.Action, pModel.Controller, pageVals)" class="page-link rounded-circle border-0 @(i == pModel.CurrentPage ? "bg-primary text-white shadow-sm" : "bg-light text-dark")" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; font-weight: 700;">@i</a></li>
                            }
                            @if (pModel.HasNextPage) {
                                var nextVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = (pModel.CurrentPage + 1).ToString() };
                                <li class="page-item"><a href="@Url.Action(pModel.Action, pModel.Controller, nextVals)" class="page-link rounded-circle border-0 bg-light text-dark"><i class="fas fa-chevron-right"></i></a></li>
                            }
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
        <script>
            function updatePageSize(size) {
                const url = new URL(window.location.href);
                url.searchParams.set('pageSize', size);
                url.searchParams.set('page', '1');
                window.location.href = url.toString();
            }
        </script>
    }
}

<style>
    .pass-card-nexus { transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1); border: 1px solid #e2e8f0 !important; }
    .pass-card-nexus:hover { transform: translateY(-8px); border-color: var(--nexus-primary) !important; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1) !important; }
    .qr-container { transition: all 0.3s ease; }
    .pass-card-nexus:hover .qr-container { border-color: var(--nexus-primary) !important; transform: scale(1.02); }
</style>

@section Scripts {
    <script>
        function printPass(name, code, qrUrl) {
            var w = window.open('', '_blank');
            var highResQr = qrUrl.replace('size=220x220', 'size=500x500');
            w.document.write('<html><head><title>Print Pass - ' + name + '<\/title>');
            w.document.write('<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">');
            w.document.write('<style>');
            w.document.write("body { font-family: 'Inter', sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; background: #f8fafc; }");
            w.document.write(".pass-card { border: 3px solid #6366f1; border-radius: 40px; padding: 50px; background: white; text-align: center; width: 400px; box-shadow: 0 30px 60px rgba(0, 0, 0, 0.15); }");
            w.document.write(".pass-header { color: #6366f1; font-weight: 800; text-transform: uppercase; letter-spacing: 3px; margin-bottom: 30px; font-size: 26px; }");
            w.document.write(".qr-img { border: 2px solid #f1f5f9; padding: 20px; border-radius: 24px; margin-bottom: 30px; }");
            w.document.write(".visitor-name { font-size: 24px; font-weight: 800; color: #1e293b; margin: 0 0 10px 0; letter-spacing: -0.5px; }");
            w.document.write(".pass-code { font-family: 'Courier New', monospace; font-size: 32px; font-weight: 800; letter-spacing: 4px; background: #f1f5f9; padding: 20px; border-radius: 20px; color: #6366f1; border: 1px dashed #6366f1; }");
            w.document.write(".footer { margin-top: 30px; font-size: 14px; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; }");
            w.document.write("<\/style><\/head><body>");
            w.document.write('<div class="pass-card">');
            w.document.write('<div class="pass-header"><i class="fas fa-qrcode me-3"><\/i>SECURITY PASS<\/div>');
            w.document.write('<img src="' + highResQr + '" width="240" height="240" class="qr-img" \/>');
            w.document.write('<h3 class="visitor-name">' + name + '<\/h3>');
            w.document.write('<div class="pass-code">' + code + '<\/div>');
            w.document.write('<div class="footer">VALID FOR ENTRY ACCESS ONLY<\/div>');
            w.document.write('<\/div><\/body><\/html>');
            w.document.close();
            setTimeout(function() { w.print(); w.close(); }, 800);
        }

        function sharePass(name, code, qrUrl) {
            var shareText = 'Visitor Pass: ' + name + '\nCode: ' + code + '\nPass QR: ' + qrUrl.replace('size=220x220', 'size=500x500');
            if (navigator.share) {
                navigator.share({ title: 'Security Access Pass', text: shareText });
            } else {
                navigator.clipboard.writeText(shareText).then(() => alert('Access details copied to clipboard!'));
            }
        }
    </script>
}

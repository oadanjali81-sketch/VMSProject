@model List<VMSProject.Models.VisitorListViewModel>
@{
    Layout = "UserLayout";
    var currentVisitor = ViewBag.Visitor as VMSProject.Models.Visitor;
    string pageTitle = "Visitor Management";
    
    if (ViewBag.Mode == "View" && currentVisitor != null) pageTitle = $"Visitors / {currentVisitor.Name}";
    else if (ViewBag.Mode == "Edit" && currentVisitor != null) pageTitle = $"Edit / {currentVisitor.Name}";
    else if (ViewBag.Mode == "Add") pageTitle = "New Registration";
    
    ViewData["Title"] = pageTitle;
}

@if (ViewBag.Mode == null)
{
<!-- Quick Stats Header -->
<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div>
                <p class="text-muted small mb-1">TOTAL VISITORS</p>
                <h3>@ViewBag.TotalVisitors</h3>
            </div>
            <div style="width: 48px; height: 48px; background: rgba(99, 102, 241, 0.1); color: #6366f1; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem;">
                <i class="fas fa-users"></i>
            </div>
        </div>
    </div>
</div>

<div class="section-card animate-fade-up">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h5 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">Visitor Directory</h5>
            <p class="text-muted small mb-0">Manage and track all registered visitors in the system.</p>
        </div>
        
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="input-group" style="width: 300px;">
                <span class="input-group-text bg-light border-end-0" style="border-radius: 10px 0 0 10px; border-color: #e2e8f0;"><i class="fas fa-search text-muted"></i></span>
                <input type="text" class="form-control bg-light border-start-0" id="tableSearchInput" placeholder="Search visitors..." onkeyup="filterTable()" style="border-radius: 0 10px 10px 0; border-color: #e2e8f0; font-size: 0.9rem;">
            </div>
            <a href="/User/AddVisitorPage" class="premium-btn">
                <i class="fas fa-plus"></i> New Visitor
            </a>
        </div>
    </div>

    <div class="nexus-table-wrapper">
        <div class="table-responsive">
            <table class="nexus-table" id="standardTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Visitor Details</th>
                        <th>Contact Info</th>
                        <th>Company</th>
                        <th>Host Details</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        int i = 1;
                        foreach (var v in Model)
                        {
                            <tr class="hover-row" style="cursor: pointer;" onclick="if(!event.target.closest('.tool-btn')) window.location.href='/User/ViewVisitor/@v.VisitorId'">
                                <td style="width: 60px;"><span class="nexus-badge nexus-badge-info">@i</span></td>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(v.CapturePhoto))
                                        {
                                            <div class="rounded-circle overflow-hidden shadow-sm" style="width: 42px; height: 42px; border: 2px solid #fff; outline: 1px solid #e2e8f0;">
                                                <img src="@v.CapturePhoto" class="w-100 h-100" style="object-fit: cover;" />
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center fw-800" style="width: 42px; height: 42px; font-size: 0.9rem; border: 1px solid rgba(99, 102, 241, 0.2);">
                                                @(string.IsNullOrEmpty(v.Name) ? "?" : v.Name!.Substring(0, 1).ToUpper())
                                            </div>
                                        }
                                        <div>
                                            <div class="fw-700 text-dark lh-1 mb-1">@(v.Name ?? "Anonymous")</div>
                                            <small class="text-muted" style="font-size: 0.75rem;">ID: #100@v.VisitorId</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-600 text-dark mb-1">@(v.Phone ?? "—")</div>
                                    <div class="text-muted small">@(v.Email ?? "—")</div>
                                </td>
                                <td><span class="fw-700 text-primary small uppercase letter-spacing-1">@(v.CompanyName ?? "INDIVIDUAL")</span></td>
                                <td>
                                    <div class="fw-700 text-dark mb-1">@(v.WhomeToMeet ?? "—")</div>
                                    <span class="nexus-badge nexus-badge-info" style="font-size: 0.65rem;">@(v.Department ?? "General")</span>
                                </td>
                                <td>
                                    <span class="nexus-badge nexus-badge-success">Registered</span>
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/User/EditVisitorPage/@v.VisitorId" class="tool-btn warning" title="Edit" onclick="event.stopPropagation();">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <a href="/User/GenerateQR/@v.VisitorId" class="tool-btn success" title="QR Pass" onclick="event.stopPropagation();">
                                            <i class="fas fa-qrcode"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="opacity-25 mb-3"><i class="fas fa-users-slash fa-3x"></i></div>
                                <p class="text-muted fw-600">No visitors found in the directory.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.Pagination != null)
    {
        var pModel = (VMSProject.Models.PaginationViewModel)ViewBag.Pagination;
        @if (pModel.TotalPages > 0)
        {
            <div class="nexus-pagination-wrapper">
                <div class="nexus-page-info">
                    Showing @(((pModel.CurrentPage - 1) * pModel.PageSize) + 1) to @(Math.Min(pModel.CurrentPage * pModel.PageSize, pModel.TotalItems)) of @pModel.TotalItems entries
                </div>
                <div class="d-flex align-items-center gap-3">
                    <select class="nexus-page-size-select" onchange="updatePageSize(this.value)">
                        <option value="10" selected="@(pModel.PageSize == 10)">10 per page</option>
                        <option value="20" selected="@(pModel.PageSize == 20)">20 per page</option>
                        <option value="50" selected="@(pModel.PageSize == 50)">50 per page</option>
                        <option value="100" selected="@(pModel.PageSize == 100)">100 per page</option>
                    </select>
                    <nav>
                        <ul class="nexus-pagination">
                            @if (pModel.HasPreviousPage)
                            {
                                var prevVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = (pModel.CurrentPage - 1).ToString() };
                                <li class="page-item">
                                    <a href="@Url.Action(pModel.Action, pModel.Controller, prevVals)" class="page-link">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                            }
                            @for (int i = Math.Max(1, pModel.CurrentPage - 2); i <= Math.Min(pModel.TotalPages, pModel.CurrentPage + 2); i++)
                            {
                                var pageVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = i.ToString() };
                                <li class="page-item @(i == pModel.CurrentPage ? "active" : "")">
                                    <a href="@Url.Action(pModel.Action, pModel.Controller, pageVals)" class="page-link">@i</a>
                                </li>
                            }
                            @if (pModel.HasNextPage)
                            {
                                var nextVals = new Dictionary<string, string>(pModel.RouteValues) { ["page"] = (pModel.CurrentPage + 1).ToString() };
                                <li class="page-item">
                                    <a href="@Url.Action(pModel.Action, pModel.Controller, nextVals)" class="page-link">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            </div>
            <script>
                    function updatePageSize(size) {
                        const url = new URL(window.location.href);
                        url.searchParams.set('pageSize', size);
                        url.searchParams.set('page', '1');
                        window.location.href = url.toString();
                    }
            </script>
        }
    }
</div>
}

@if (ViewBag.Mode == "Add")
{
    <!-- Add Visitor Section -->


    <div class="section-card animate-fade-up">
        <div class="d-flex align-items-center gap-3 mb-4 pb-3" style="border-bottom: 1px solid #f1f5f9;">
            <div style="width: 48px; height: 48px; background: linear-gradient(135deg, #6366f1, #4f46e5); color: white; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;">
                <i class="fas fa-user-plus"></i>
            </div>
            <div>
                <h5 class="fw-800 text-dark mb-0" style="letter-spacing: -0.5px;">Register New Visitor</h5>
                <p class="text-muted small mb-0">Fill in all the details below to add a new visitor to the system.</p>
            </div>
        </div>

        <form action="/User/AddVisitor" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-4">
                <div class="col-lg-3">
                    <div class="bg-light rounded-4 p-4 text-center">
                        <label class="nexus-label mb-3">VISITOR PHOTO</label>
                        <div class="position-relative d-inline-block mx-auto mb-3">
                            <div id="photo_preview" class="rounded-4 bg-white d-flex align-items-center justify-content-center overflow-hidden shadow-sm mx-auto" style="width: 140px; height: 140px; border: 2px dashed #e2e8f0;">
                                <i class="fas fa-camera fa-2x text-primary opacity-25"></i>
                                <video id="camera_feed" class="d-none w-100 h-100" style="object-fit: cover;" autoplay playsinline></video>
                            </div>
                            <canvas id="capture_canvas" class="d-none"></canvas>
                        </div>
                        <input type="file" name="PhotoFile" id="photoFile" class="d-none" accept="image/*" onchange="previewImage(this, 'photo_preview')">
                        
                        <div class="d-flex flex-column gap-2">
                            <button type="button" id="btn_start_camera" onclick="startCamera()" class="premium-btn w-100" style="font-size: 0.78rem; background: #6366f1;">
                                <i class="fas fa-video me-2"></i>Live Camera
                            </button>
                            <button type="button" id="btn_capture" onclick="capturePhoto()" class="premium-btn w-100 d-none" style="font-size: 0.78rem; background: #10b981;">
                                <i class="fas fa-camera me-2"></i>Capture Photo
                            </button>
                            <button type="button" onclick="document.getElementById('photoFile').click()" class="premium-btn secondary w-100" style="font-size: 0.78rem;">
                                <i class="fas fa-upload me-2"></i>Upload File
                            </button>
                        </div>
                        <hr class="my-4" style="border-color: #e2e8f0;">
                        <label class="nexus-label mb-3">ID DOCUMENT</label>
                        <input type="file" name="IdFile" id="idFile" class="d-none" accept="image/*,.pdf" onchange="showFileName(this, 'id_name')">
                        <button type="button" onclick="document.getElementById('idFile').click()" class="premium-btn secondary w-100" style="font-size: 0.78rem;">
                            <i class="fas fa-id-card me-2"></i>Upload ID
                        </button>
                        <p id="id_name" class="text-muted small mt-2 mb-0 text-truncate"></p>
                    </div>
                </div>

                <div class="col-lg-9">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">FULL NAME <span class="text-danger">*</span></label>
                                <input type="text" name="Name" class="nexus-input" placeholder="John Doe" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">PHONE NUMBER <span class="text-danger">*</span></label>
                                <input type="text" name="Phone" class="nexus-input" placeholder="+91 98765 43210" required>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">EMAIL ADDRESS</label>
                                <input type="email" name="Email" class="nexus-input" placeholder="john@example.com">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">VEHICLE NUMBER</label>
                                <input type="text" name="VehicleNumber" class="nexus-input" placeholder="MH 01 AB 1234">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">COMPANY NAME</label>
                                <input type="text" name="CompanyName" class="nexus-input" placeholder="Organization name">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">COMPANY ADDRESS</label>
                                <input type="text" name="CompanyAddress" class="nexus-input" placeholder="Company location">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">WHOM TO MEET <span class="text-danger">*</span></label>
                                <select name="WhomeToMeet" class="nexus-input" required>
                                    <option value="">Select Host</option>
                                    @if (ViewBag.Employees != null)
                                    {
                                        foreach (var e in (List<VMSProject.Models.Employee>)ViewBag.Employees!)
                                        {
                                            <option value="@e.Name">@e.Name (@e.Designation)</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">DEPARTMENT <span class="text-danger">*</span></label>
                                <select name="Department" class="nexus-input" required>
                                    <option value="">Select Department</option>
                                    @if (ViewBag.Departments != null)
                                    {
                                        foreach (var d in (List<VMSProject.Models.Department>)ViewBag.Departments!)
                                        {
                                            <option value="@d.DepartmentName">@d.DepartmentName</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="nexus-form-group">
                                <label class="nexus-label">PURPOSE OF VISIT</label>
                                <input type="text" name="PurposeOfVisit" class="nexus-input" placeholder="Reason for meeting">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-end gap-3 mt-4 pt-3" style="border-top: 1px solid #f1f5f9;">
                <a href="/User/VisitorManagement" class="premium-btn secondary"><i class="fas fa-times me-2"></i>Cancel</a>
                <button type="submit" class="premium-btn"><i class="fas fa-check me-2"></i>Register Visitor</button>
            </div>
        </form>
    </div>
}
else if (ViewBag.Mode == "View")
{
    var v = ViewBag.Visitor as VMSProject.Models.Visitor;
    var lastVisit = ViewBag.LastVisit as VMSProject.Models.Visit;
    
    


    <div class="section-card animate-fade-up mb-4">
        <div class="row align-items-center">
            <div class="col-auto">
                <div class="rounded-4 overflow-hidden shadow-sm" style="width: 100px; height: 100px; border: 3px solid #fff; outline: 2px solid #e2e8f0;">
                    @if (!string.IsNullOrEmpty(v?.CapturePhoto))
                    {
                        <img src="@v.CapturePhoto" class="w-100 h-100" style="object-fit: cover;" />
                    }
                    else
                    {
                        <div class="w-100 h-100 bg-primary bg-opacity-10 d-flex align-items-center justify-content-center">
                            <span class="fw-800 text-primary" style="font-size: 2.5rem;">@(string.IsNullOrEmpty(v?.Name) ? "?" : v.Name[0].ToString().ToUpper())</span>
                        </div>
                    }
                </div>
            </div>
            <div class="col">
                <h3 class="fw-800 text-dark mb-1" style="letter-spacing: -0.5px;">@(v?.Name ?? "Unknown Visitor")</h3>
                <p class="fw-800 text-primary mb-2" style="font-size: 0.8rem; letter-spacing: 1.5px;">@(v?.CompanyName?.ToUpper() ?? "INDIVIDUAL")</p>
                <div class="d-flex flex-wrap gap-2">
                    <span class="nexus-badge nexus-badge-success"><i class="fas fa-check-circle me-1"></i>Registered</span>
                    @if (!string.IsNullOrEmpty(v?.QRCode))
                    {
                        <span class="nexus-badge nexus-badge-info"><i class="fas fa-qrcode me-1"></i>Pass: @v?.QRCode</span>
                    }
                    <span class="nexus-badge nexus-badge-warning"><i class="fas fa-history me-1"></i>@ViewBag.VisitCount Visits</span>
                </div>
            </div>
            <div class="col-auto d-flex gap-2">
                <a href="/User/VisitorManagement" class="premium-btn secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back
                </a>
                <a href="/User/EditVisitorPage/@v?.VisitorId" class="premium-btn secondary">
                    <i class="fas fa-pen me-2"></i>Edit
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="section-card h-100">
                <h6 class="fw-800 text-dark mb-3 pb-2" style="border-bottom: 1px solid #f1f5f9;"><i class="fas fa-address-card text-primary me-2"></i>Contact Information</h6>
                <div class="row g-3">
                    <div class="col-6"><label class="nexus-label">FULL NAME</label><p class="fw-700 text-dark mb-0">@(v?.Name ?? "—")</p></div>
                    <div class="col-6"><label class="nexus-label">PHONE NUMBER</label><p class="fw-700 text-dark mb-0">@(v?.Phone ?? "—")</p></div>
                    <div class="col-6"><label class="nexus-label">EMAIL ADDRESS</label><p class="fw-700 text-dark mb-0">@(v?.Email ?? "—")</p></div>
                    <div class="col-6"><label class="nexus-label">VEHICLE NUMBER</label><p class="fw-700 text-dark mb-0">@(v?.VehicleNumber ?? "—")</p></div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="section-card h-100">
                <h6 class="fw-800 text-dark mb-3 pb-2" style="border-bottom: 1px solid #f1f5f9;"><i class="fas fa-building text-primary me-2"></i>Company Details</h6>
                <div class="row g-3">
                    <div class="col-6"><label class="nexus-label">COMPANY NAME</label><p class="fw-700 text-dark mb-0">@(v?.CompanyName ?? "—")</p></div>
                    <div class="col-6"><label class="nexus-label">COMPANY ADDRESS</label><p class="fw-700 text-dark mb-0">@(v?.CompanyAddress ?? "—")</p></div>
                    <div class="col-6"><label class="nexus-label">WHOM TO MEET</label><p class="fw-700 text-dark mb-0">@(v?.WhomeToMeet ?? "—")</p></div>
                    <div class="col-6"><label class="nexus-label">DEPARTMENT</label><p class="fw-700 text-dark mb-0">@(v?.Department ?? "—")</p></div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="section-card h-100">
                <h6 class="fw-800 text-dark mb-3 pb-2" style="border-bottom: 1px solid #f1f5f9;"><i class="fas fa-clipboard-check text-primary me-2"></i>Visit Information</h6>
                <div class="row g-3">
                    <div class="col-6"><label class="nexus-label">PURPOSE OF VISIT</label><p class="fw-700 text-dark mb-0">@(v?.PurposeOfVisit ?? "—")</p></div>
                    <div class="col-6"><label class="nexus-label">TOTAL VISITS</label><p class="fw-700 text-dark mb-0">@ViewBag.VisitCount</p></div>
                    <div class="col-6"><label class="nexus-label">LAST VISIT DATE</label><p class="fw-700 text-dark mb-0">@(lastVisit != null ? lastVisit.VisitDate.ToString("dd MMM yyyy") : "—")</p></div>
                    <div class="col-6"><label class="nexus-label">QR PASS CODE</label><p class="fw-700 text-primary font-monospace mb-0">@(v?.QRCode ?? "Not Generated")</p></div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="section-card h-100">
                <h6 class="fw-800 text-dark mb-3 pb-2" style="border-bottom: 1px solid #f1f5f9;"><i class="fas fa-id-badge text-primary me-2"></i>Documents & Identity</h6>
                <div class="row g-3">
                    <div class="col-6">
                        <label class="nexus-label">VISITOR PHOTO</label>
                        @if (!string.IsNullOrEmpty(v?.CapturePhoto)) { <div class="rounded-3 overflow-hidden shadow-sm mt-2" style="width: 80px; height: 80px;"><img src="@v.CapturePhoto" class="w-100 h-100" style="object-fit: cover;" /></div> } else { <p class="text-muted small mb-0">No photo</p> }
                    </div>
                    <div class="col-6">
                        <label class="nexus-label">ID DOCUMENT</label>
                        @if (!string.IsNullOrEmpty(v?.UploadId)) { <div class="mt-2"><a href="@v.UploadId" target="_blank" class="premium-btn secondary px-3 py-2" style="font-size: 0.7rem;"><i class="fas fa-external-link-alt me-1"></i>View ID</a></div> } else { <p class="text-muted small mb-0">No ID</p> }
                    </div>
                </div>
            </div>
        </div>

        <!-- Security Pass Section -->
        <div class="col-lg-12">
            <div class="section-card animate-fade-up">
                <h6 class="fw-800 text-dark mb-4 pb-2" style="border-bottom: 1px solid #f1f5f9;">
                    <i class="fas fa-id-card-alt text-primary me-2"></i>SECURITY PASS PREVIEW
                </h6>
                <div class="d-flex flex-column align-items-center justify-content-center py-5 bg-light bg-opacity-40 rounded-5 border-dashed border-2 border-primary border-opacity-10">
                    @if (!string.IsNullOrEmpty(v?.QRCode))
                    {
                        <div class="bg-white p-4 rounded-4 shadow-lg mb-4" style="border: 1px solid #e2e8f0;">
                            <img src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=@v?.QRCode" alt="QR Pass" style="filter: contrast(1.1);" />
                        </div>
                        <div class="text-center">
                            <div class="fw-800 text-dark fs-4 mb-2 tracking-tighter">@v?.QRCode</div>
                            <span class="nexus-badge nexus-badge-success px-3 py-2"><i class="fas fa-shield-alt me-2"></i>ACTIVE ACCESS TOKEN</span>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <div class="opacity-10 mb-3"><i class="fas fa-qrcode fa-5x"></i></div>
                            <h5 class="fw-800 text-muted mb-2">No Active Pass</h5>
                            <p class="text-muted small mb-4">This visitor does not have an active security pass assigned.</p>
                            <a href="/User/GenerateQR/@v?.VisitorId" class="premium-btn">
                                <i class="fas fa-plus-circle me-2"></i>Generate Security Pass
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
else if (ViewBag.Mode == "Edit")
{
    var v = ViewBag.Visitor as VMSProject.Models.Visitor;
    


    <div class="section-card animate-fade-up">
        <div class="d-flex align-items-center gap-3 mb-4 pb-3" style="border-bottom: 1px solid #f1f5f9;">
            <div style="width: 48px; height: 48px; background: linear-gradient(135deg, #F59E0B, #D97706); color: white; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;"><i class="fas fa-user-edit"></i></div>
            <div><h5 class="fw-800 text-dark mb-0" style="letter-spacing: -0.5px;">Edit Visitor Profile</h5><p class="text-muted small mb-0">Update the details for <strong class="text-primary">@(v?.Name ?? "this visitor")</strong>.</p></div>
        </div>

        <form action="/User/EditVisitor" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="VisitorId" value="@v?.VisitorId" />
            <div class="row g-4">
                <div class="col-lg-3">
                    <div class="bg-light rounded-4 p-4 text-center">
                        <label class="nexus-label mb-3">UPDATE PHOTO</label>
                        <div class="position-relative d-inline-block mx-auto mb-3">
                            <div id="photo_preview" class="rounded-4 bg-white d-flex align-items-center justify-content-center overflow-hidden shadow-sm mx-auto" style="width: 140px; height: 140px; border: 2px dashed #e2e8f0;">
                                @if (!string.IsNullOrEmpty(v?.CapturePhoto)) { <img src="@v.CapturePhoto" class="w-100 h-100" style="object-fit: cover;" /> } else { <i class="fas fa-camera fa-2x text-primary opacity-25"></i> }
                                <video id="camera_feed" class="d-none w-100 h-100" style="object-fit: cover;" autoplay playsinline></video>
                            </div>
                            <canvas id="capture_canvas" class="d-none"></canvas>
                        </div>
                        <input type="file" name="PhotoFile" id="photoFile" class="d-none" accept="image/*" onchange="previewImage(this, 'photo_preview')">
                        
                        <div class="d-flex flex-column gap-2">
                            <button type="button" id="btn_start_camera" onclick="startCamera()" class="premium-btn w-100" style="font-size: 0.78rem; background: #6366f1;">
                                <i class="fas fa-video me-2"></i>Live Camera
                            </button>
                            <button type="button" id="btn_capture" onclick="capturePhoto()" class="premium-btn w-100 d-none" style="font-size: 0.78rem; background: #10b981;">
                                <i class="fas fa-camera me-2"></i>Capture Photo
                            </button>
                            <button type="button" onclick="document.getElementById('photoFile').click()" class="premium-btn secondary w-100" style="font-size: 0.78rem;">
                                <i class="fas fa-upload me-2"></i>Upload New
                            </button>
                        </div>

                        <hr class="my-4" style="border-color: #e2e8f0;">
                        <label class="nexus-label mb-3">ID DOCUMENT</label>
                        <input type="file" name="IdFile" id="idFile" class="d-none" accept="image/*,.pdf" onchange="showFileName(this, 'id_name')">
                        <button type="button" onclick="document.getElementById('idFile').click()" class="premium-btn secondary w-100" style="font-size: 0.78rem;">
                            <i class="fas fa-id-card me-2"></i>Change ID
                        </button>
                        <p id="id_name" class="text-muted small mt-2 mb-0 text-truncate">@(!string.IsNullOrEmpty(v?.UploadId) ? "Current ID Uploaded" : "No ID provided")</p>
                    </div>
                </div>
                <div class="col-lg-9">
                    <div class="row g-3">
                        <div class="col-md-6"><div class="nexus-form-group"><label class="nexus-label">FULL NAME *</label><input type="text" name="Name" value="@v?.Name" class="nexus-input" required></div></div>
                        <div class="col-md-6"><div class="nexus-form-group"><label class="nexus-label">PHONE NUMBER *</label><input type="text" name="Phone" value="@v?.Phone" class="nexus-input" required></div></div>
                        <div class="col-md-6"><div class="nexus-form-group"><label class="nexus-label">EMAIL ADDRESS</label><input type="email" name="Email" value="@v?.Email" class="nexus-input"></div></div>
                        <div class="col-md-6"><div class="nexus-form-group"><label class="nexus-label">VEHICLE NUMBER</label><input type="text" name="VehicleNumber" value="@v?.VehicleNumber" class="nexus-input"></div></div>
                        <div class="col-md-6"><div class="nexus-form-group"><label class="nexus-label">COMPANY NAME</label><input type="text" name="CompanyName" value="@v?.CompanyName" class="nexus-input"></div></div>
                        <div class="col-md-6"><div class="nexus-form-group"><label class="nexus-label">COMPANY ADDRESS</label><input type="text" name="CompanyAddress" value="@v?.CompanyAddress" class="nexus-input"></div></div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">WHOM TO MEET</label>
                                <select name="WhomeToMeet" class="nexus-input">
                                    <option value="">Select Host</option>
                                    @if (ViewBag.Employees != null) { foreach (var e in (List<VMSProject.Models.Employee>)ViewBag.Employees!) { <option value="@e.Name" selected="@(v?.WhomeToMeet == e.Name)">@e.Name (@e.Designation)</option> } }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="nexus-form-group">
                                <label class="nexus-label">DEPARTMENT</label>
                                <select name="Department" class="nexus-input">
                                    <option value="">Select Department</option>
                                    @if (ViewBag.Departments != null) { foreach (var d in (List<VMSProject.Models.Department>)ViewBag.Departments!) { <option value="@d.DepartmentName" selected="@(v?.Department == d.DepartmentName)">@d.DepartmentName</option> } }
                                </select>
                            </div>
                        </div>
                        <div class="col-12"><div class="nexus-form-group"><label class="nexus-label">PURPOSE OF VISIT</label><input type="text" name="PurposeOfVisit" value="@v?.PurposeOfVisit" class="nexus-input"></div></div>
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-end gap-3 mt-4 pt-3" style="border-top: 1px solid #f1f5f9;">
                <a href="/User/ViewVisitor/@v?.VisitorId" class="premium-btn secondary"><i class="fas fa-times me-2"></i>Cancel</a>
                <button type="submit" class="premium-btn"><i class="fas fa-save me-2"></i>Save Changes</button>
            </div>
        </form>
    </div>
}

@section Scripts {
    <script>
        function filterTable() {
            const q = document.getElementById('tableSearchInput').value.toLowerCase();
            document.querySelectorAll('#standardTable tbody tr').forEach(r => {
                r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        }
        function updatePageSize(s) {
            const u = new URL(window.location.href);
            u.searchParams.set('pageSize', s); u.searchParams.set('page', '1');
            window.location.href = u.toString();
        }
        function previewImage(input, previewId) {
            const container = document.getElementById(previewId);
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    container.innerHTML = `<img src="${e.target.result}" class="w-100 h-100" style="object-fit: cover;" />`;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
        function showFileName(input, labelId) {
            if (input.files && input.files[0]) {
                document.getElementById(labelId).textContent = input.files[0].name;
            }
        }

        let stream = null;
        async function startCamera() {
            const video = document.getElementById('camera_feed');
            const preview = document.getElementById('photo_preview');
            const btnStart = document.getElementById('btn_start_camera');
            const btnCapture = document.getElementById('btn_capture');
            const icon = preview.querySelector('.fa-camera');

            try {
                stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'user' }, audio: false });
                video.srcObject = stream;
                video.classList.remove('d-none');
                if (icon) icon.classList.add('d-none');
                btnStart.classList.add('d-none');
                btnCapture.classList.remove('d-none');
            } catch (err) {
                alert('Camera access denied or not available.');
                console.error(err);
            }
        }

        function capturePhoto() {
            const video = document.getElementById('camera_feed');
            const canvas = document.getElementById('capture_canvas');
            const preview = document.getElementById('photo_preview');
            const btnStart = document.getElementById('btn_start_camera');
            const btnCapture = document.getElementById('btn_capture');
            const photoInput = document.getElementById('photoFile');

            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);

            const dataUrl = canvas.toDataURL('image/jpeg');
            preview.innerHTML = `<img src="${dataUrl}" class="w-100 h-100" style="object-fit: cover;" />`;
            
            // Stop stream
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
            }

            // Convert to file for the input
            fetch(dataUrl)
                .then(res => res.blob())
                .then(blob => {
                    const file = new File([blob], "captured_visitor.jpg", { type: "image/jpeg" });
                    const container = new DataTransfer();
                    container.items.add(file);
                    photoInput.files = container.files;
                });

            video.classList.add('d-none');
            btnStart.classList.remove('d-none');
            btnStart.innerHTML = '<i class="fas fa-redo me-2"></i>Retake Photo';
            btnCapture.classList.add('d-none');
        }
    </script>
}


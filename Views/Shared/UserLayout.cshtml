@using Microsoft.AspNetCore.Http
@{
    var adminName = (ViewBag.AdminName as object)?.ToString();
    if (string.IsNullOrEmpty(adminName)) { adminName = User.Identity?.Name ?? "Admin"; }
    var adminInitial = !string.IsNullOrEmpty(adminName) ? adminName.Substring(0, 1).ToUpper() : "A";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>VMS | @ViewData["Title"]</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Global Styles & Fonts -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- User Design System -->
    <link rel="stylesheet" href="/css/User/UserDesignSystem.css">
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Sidebar -->
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    }

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="tmb-sidebar-logo">
                <i class="fas fa-crown tmb-logo-icon"></i>
                <span class="nav-text">VISION<span class="tmb-logo-accent">|VMS</span></span>
            </div>
        </div>

        <div class="sidebar-nav">
            <div class="nav-section">
                <div class="section-title"><span>MAIN</span></div>
                <a href="/User/Dashboard" class="nav-item @(currentAction == "Dashboard" ? "active" : "")" data-title="Dashboard">
                    <i class="fas fa-chart-pie"></i>
                    <span class="nav-text">Dashboard</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="section-title"><span>VISITOR MANAGEMENT</span></div>
                @{
                    var isVisitorActive = currentAction == "VisitorManagement" || 
                                         currentAction == "AddVisitorPage" || 
                                         currentAction == "ViewVisitor" || 
                                         currentAction == "EditVisitorPage";
                }
                <a href="/User/VisitorManagement" class="nav-item @(isVisitorActive ? "active" : "")" data-title="Visitors">
                    <i class="fas fa-users"></i>
                    <span class="nav-text">Visitors</span>
                </a>
                <a href="/User/Visit" class="nav-item @(currentAction == "Visit" ? "active" : "")" data-title="Visits">
                    <i class="fas fa-history"></i>
                    <span class="nav-text">Visit Logs</span>
                </a>
                <a href="/User/ScanQR" class="nav-item @(currentAction == "ScanQR" ? "active" : "")" data-title="QR Scanner">
                    <i class="fas fa-qrcode"></i>
                    <span class="nav-text">QR Scanner</span>
                </a>
                <a href="/User/AllQRCodes" class="nav-item @(currentAction == "AllQRCodes" ? "active" : "")" data-title="Visitor Passes">
                    <i class="fas fa-id-badge"></i>
                    <span class="nav-text">Visitor Passes</span>
                </a>
            </div>

            <div class="nav-section">
                <div class="section-title"><span>EMPLOYEES</span></div>
                <a href="/User/Employee" class="nav-item @(currentAction == "Employee" ? "active" : "")" data-title="Employees">
                    <i class="fas fa-user-tie"></i>
                    <span class="nav-text">Employees</span>
                </a>
                <a href="/User/Department" class="nav-item @(currentAction == "Department" ? "active" : "")" data-title="Departments">
                    <i class="fas fa-building-user"></i>
                    <span class="nav-text">Departments</span>
                </a>
            </div>

            @if (string.Equals(Context.Session.GetString("UserRole"), "Superadmin", System.StringComparison.OrdinalIgnoreCase))
            {
                <div class="nav-section">
                    <div class="section-title"><span>ADMIN</span></div>
                    <a href="/SuperAdmin/Dashboard" class="nav-item text-danger" data-title="Super Admin">
                        <i class="fas fa-shield-alt text-danger"></i>
                        <span class="nav-text">Super Admin</span>
                    </a>
                </div>
            }
        </div>

        <div class="sidebar-footer">
            <a href="/Account/Logout" class="logout-btn">
                <i class="fas fa-sign-out-alt"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- Sidebar and Main Content styles are now centralized in UserDesignSystem.css -->
    <!-- Page Content Wrapper -->
    <div class="main-content" id="mainContent">
        <!-- Top Navbar -->
        <nav class="top-navbar d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <button class="toggle-btn" id="toggleSidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="page-title-section">
                    <h1 id="pageTitle">@ViewData["Title"]</h1>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="d-flex align-items-center gap-2 px-3 py-2 bg-light rounded-pill">
                    <div style="width: 32px; height: 32px; background: #6366f1; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.75rem;">@adminInitial</div>
                    <div class="d-none d-md-block text-end">
                        <div style="font-size: 0.85rem; font-weight: 700; color: #1e1e2d; line-height: 1;">@adminName</div>
                        <div style="font-size: 0.7rem; color: #64748b; font-weight: 600;">Company Admin</div>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Main Body Area -->
        <div class="container-fluid p-4" style="min-height: calc(100vh - 160px);">
            @RenderBody()
        </div>

        <!-- Footer -->
        <footer class="py-4 text-center" style="border-top: 1px solid rgba(0,0,0,0.05); color: #64748b; font-size: 0.85rem; font-weight: 500;">
            <p class="mb-0">&copy; @DateTime.Now.Year VISION VMS. All rights reserved.</p>
        </footer>
    </div>

    <!-- sidebar-overlay is declared once at the top of the body -->

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/Global/vision-global.js"></script>

    <script>
        /**
        * ── SIDEBAR CONTROL ──
        */
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.getElementById('mainContent');
        const overlay = document.getElementById('sidebarOverlay');
        const toggleBtn = document.getElementById('toggleSidebar');

        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                if (window.innerWidth <= 768) {
                    sidebar.classList.toggle('mobile-open');
                    overlay.classList.toggle('show');
                } else {
                    sidebar.classList.toggle('collapsed');
                    mainContent.classList.toggle('expanded');
                }
            });
        }

        if (overlay) {
            overlay.addEventListener('click', () => {
                sidebar.classList.remove('mobile-open');
                overlay.classList.remove('show');
            });
        }
    </script>
    
    <!-- Universal Structured Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-bottom px-4 py-3">
                    <h5 class="modal-title fw-800 text-dark" id="deleteModalTitle">Delete Confirmation</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" onclick="closeDeleteModal()"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="d-flex align-items-center gap-4">
                        <div class="flex-shrink-0 bg-danger bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="fas fa-trash-can text-danger fs-3"></i>
                        </div>
                        <div>
                            <p class="mb-1 fw-700 text-dark">Are you sure you want to delete this?</p>
                            <p class="text-muted mb-0 small">You are about to permanently remove <strong id="deleteItemName" class="text-primary">this item</strong>. This action cannot be reversed.</p>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top px-4 py-3 bg-light bg-opacity-50">
                    <button type="button" onclick="closeDeleteModal()" class="btn btn-secondary fw-700 rounded-3 px-4" data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i> Cancel
                    </button>
                    <button type="button" id="deleteConfirmBtn" onclick="confirmDelete()" class="btn btn-danger fw-700 rounded-3 px-4 shadow-sm">
                        <i class="fas fa-trash-can me-2"></i> Delete Now
                    </button>
                </div>
            </div>
        </div>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

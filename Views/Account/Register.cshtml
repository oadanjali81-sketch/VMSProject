@model VMSProject.Models.CompanyModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
    ViewData["Title"] = "VISION VMS | Register — Secure Setup";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Register | VISION VMS</title>
    <link rel="stylesheet" href="/css/Home/Landing.css">
    <!-- Google Fonts + Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Swiper CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Space Grotesk', 'Inter', sans-serif; background: var(--vision-bg); height: 100vh; margin: 0; overflow: hidden; color: var(--vision-text); }



        .page-container { display: flex; height: 100vh; width: 100%; }

        /* Left Side - Image Carousel Section */
        .carousel-side {
            flex: 1;
            position: relative;
            background: var(--vision-dark-gradient);
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .carousel-side::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(30,58,138,0.7), rgba(59,130,246,0.5));
            z-index: 1;
        }
        .swiper {
            width: 100%;
            height: 100%;
            position: relative;
            z-index: 2;
        }
        .swiper-slide {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: white;
            padding: 40px;
        }
        .swiper-slide img {
            width: 80%;
            max-width: 400px;
            border-radius: 32px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
            margin-bottom: 32px;
            object-fit: cover;
        }
        .slide-content h2 {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 16px;
        }
        .slide-content p {
            font-size: 1rem;
            opacity: 0.9;
            max-width: 400px;
            margin: 0 auto;
        }
        .swiper-pagination-bullet {
            background: white;
            opacity: 0.5;
        }
        .swiper-pagination-bullet-active {
            background: white;
            opacity: 1;
        }
        .swiper-button-next, .swiper-button-prev {
            color: white;
            background: rgba(255,255,255,0.2);
            width: 40px;
            height: 40px;
            border-radius: 50%;
            backdrop-filter: blur(4px);
        }
        .swiper-button-next:after, .swiper-button-prev:after {
            font-size: 18px;
        }

        /* Right Side: Form Area */
        .form-side { 
            flex: 1; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            background: var(--vision-bg); 
            padding: 40px; 
            height: 100vh;
            overflow-y: auto; 
        }
        .register-card { 
            max-width: 550px; 
            width: 100%; 
            padding: 40px; 
            background: var(--vision-card-bg); 
            border-radius: var(--vision-radius); 
            box-shadow: var(--vision-shadow);
            border: 1px solid var(--vision-border);
            margin: auto; /* Keeps it centered vertically when scrolling */
        }

        .logo { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
        .logo i { font-size: 2rem; background: var(--vision-gradient); -webkit-background-clip: text; background-clip: text; color: transparent; }
        .logo span { font-size: 1.5rem; font-weight: 800; background: var(--vision-dark-gradient); -webkit-background-clip: text; background-clip: text; color: transparent; }
        
        .welcome-text h1 { font-size: 1.8rem; font-weight: 700; margin-bottom: 5px; color: var(--vision-text); }
        .welcome-text p { color: var(--vision-text-muted); margin-bottom: 30px; font-size: 0.95rem; }

        .form-section-header { font-size: 1rem; font-weight: 800; color: var(--vision-text); margin: 25px 0 15px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid var(--vision-border); padding-bottom: 8px; }
        .form-section-header i { color: var(--vision-primary); }

        .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 20px; }
        .full-width { grid-column: 1 / -1; }

        .input-group { margin-bottom: 18px; }
        .input-label { display: block; font-size: 0.82rem; font-weight: 600; color: #475569; margin-bottom: 6px; }
        .input-wrapper { position: relative; }
        .input-wrapper i { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #94A3B8; font-size: 1rem; }
        
        .input-field { 
            width: 100%; 
            padding: 12px 16px 12px 46px; 
            border: 2px solid #F1F5F9; 
            border-radius: 28px; 
            font-size: 0.9rem; 
            font-family: inherit; 
            transition: 0.2s; 
            outline: none; 
            background: #FAFBFC;
        }
        .input-field:focus { border-color: var(--vision-primary); background: #fff; box-shadow: 0 0 0 4px rgba(59,130,246,0.05); }

        .toggle-password { position: absolute; right: 18px; left: auto !important; top: 50%; transform: translateY(-50%); color: #94A3B8; cursor: pointer; z-index: 10; font-size: 0.95rem; }

        .file-upload-box { border: 2px dashed #E2E8F0; border-radius: 20px; padding: 12px; text-align: center; cursor: pointer; background: #FAFBFC; font-size: 0.85rem; }
        .file-upload-box i { font-size: 1.2rem; color: var(--vision-primary); margin-bottom: 4px; display: block; }
        .file-upload-box:hover { border-color: var(--vision-primary); background: rgba(59,130,246,0.02); }

        .register-btn { 
            width: 100%; 
            margin-top: 25px; 
            padding: 14px; 
            background: var(--vision-gradient); 
            border: none; 
            border-radius: 40px; 
            color: white; 
            font-size: 1rem; 
            font-weight: 700; 
            cursor: pointer; 
            transition: all 0.2s; 
            box-shadow: 0 4px 15px rgba(59,130,246,0.3); 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            gap: 10px;
        }
        .register-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(59,130,246,0.4); }

        .login-link { text-align: center; margin-top: 20px; font-size: 0.85rem; color: #64748B; }
        .login-link a { color: var(--vision-primary); text-decoration: none; font-weight: 700; }

        /* Responsiveness and Overrides (Synchronized with Login) */
        @@media (max-width: 968px) {
            .page-container {
                flex-direction: column;
            }
            .carousel-side {
                min-height: 400px;
            }
            .swiper-slide img {
                width: 60%;
            }
            .slide-content h2 {
                font-size: 1.5rem;
            }
        }
            .login-card {
                padding: 32px 24px;
            }
        }
        @@media (max-width: 480px) {
            .options {
                flex-direction: column;
                gap: 12px;
                align-items: flex-start;
            }
        }
    </style>
</head>
<body data-success="@ViewBag.Success">



<div class="page-container">
    <!-- Left Side: Image Carousel (Identical to Login) -->
    <div class="carousel-side">
        <div class="swiper registerSwiper">
            <div class="swiper-wrapper">
                <div class="swiper-slide">
                    <img src="/images/login_illustration.png" alt="Welcome">
                    <div class="slide-content">
                        <h2>Welcome back</h2>
                        <p>Modern visitor management solutions for your workspace.</p>
                    </div>
                </div>
                <div class="swiper-slide">
                    <img src="/images/qr_illustration.png" alt="QR Access">
                    <div class="slide-content">
                        <h2>Contactless Check-in</h2>
                        <p>Secure QR code based entry system</p>
                    </div>
                </div>
                <div class="swiper-slide">
                    <img src="/images/analytics_illustration.png" alt="Analytics">
                    <div class="slide-content">
                        <h2>AI-Powered Analytics</h2>
                        <p>Real-time visitor insights</p>
                    </div>
                </div>
            </div>
            <div class="swiper-pagination"></div>

        </div>
    </div>

    <div class="form-side">
        <div class="register-card">
            <div class="logo">
                <i class="fas fa-crown"></i>
                <span>VISION VMS</span>
            </div>
            <div class="welcome-text">
                <h1>Join VISION</h1>
                <p>Register your organization to get started</p>
            </div>
            
            <form asp-action="Register" asp-controller="Account" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                
                @if (ViewBag.Errors != null)
                {
                    <div style="background: #FEE2E2; color: #991B1B; padding: 15px; border-radius: 12px; margin-bottom: 20px; font-size: 0.85rem; border: 1px solid #FCA5A5;">
                        <ul style="margin: 0; padding-left: 20px;">
                            @foreach (var err in ViewBag.Errors)
                            {
                                <li>@err</li>
                            }
                        </ul>
                    </div>
                }
                <div asp-validation-summary="ModelOnly" style="color: #EF4444; margin-bottom: 15px; font-size: 0.85rem;"></div>
                
                <h4 class="form-section-header"><i class="fas fa-building"></i> Organization Details</h4>
                <div class="form-grid">
                    <div class="input-group full-width">
                        <label class="input-label">Company Name</label>
                        <div class="input-wrapper">
                            <i class="fas fa-city"></i>
                            <input asp-for="CompanyName" class="input-field" placeholder="Legal Entity Name" required />
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Industry Sector</label>
                        <div class="input-wrapper">
                            <i class="fas fa-briefcase"></i>
                            <select asp-for="Industry" class="input-field" required>
                                <option value="" disabled selected>Select Sector...</option>
                                <option>IT & Software</option>
                                <option>Manufacturing</option>
                                <option>Healthcare</option>
                                <option>Finance</option>
                                <option>Education</option>
                            </select>
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">GST / Tax ID</label>
                        <div class="input-wrapper">
                            <i class="fas fa-fingerprint"></i>
                            <input asp-for="GSTNumber" class="input-field" placeholder="ID Number" required />
                        </div>
                    </div>
                    <div class="input-group full-width">
                        <label class="input-label">Headquarters Address</label>
                        <div class="input-wrapper">
                            <i class="fas fa-map-location-dot"></i>
                            <input asp-for="Address" class="input-field" placeholder="Full Street Address" required />
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">City</label>
                        <div class="input-wrapper">
                            <i class="fas fa-map-pin"></i>
                            <input asp-for="City" class="input-field" required />
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Pincode</label>
                        <div class="input-wrapper">
                            <i class="fas fa-envelope-open-text"></i>
                            <input asp-for="Pincode" class="input-field" required />
                        </div>
                    </div>
                    <div class="input-group full-width">
                        <label class="input-label">Company Logo</label>
                        <div class="file-upload-box" onclick="document.getElementById('logoInput').click()">
                            <i class="fas fa-cloud-arrow-up"></i>
                            <span id="fileLabel">Upload Logo Image</span>
                            <input type="file" id="logoInput" name="CompanyLogo" hidden onchange="handleFile(this)" />
                        </div>
                    </div>
                </div>

                <h4 class="form-section-header"><i class="fas fa-user-shield"></i> Administration Details</h4>
                <div class="form-grid">
                    <div class="input-group full-width">
                        <label class="input-label">Full Admin Name</label>
                        <div class="input-wrapper">
                            <i class="fas fa-user-tie"></i>
                            <input asp-for="AdminName" class="input-field" required />
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Work Email</label>
                        <div class="input-wrapper">
                            <i class="fas fa-at"></i>
                            <input asp-for="AdminEmail" type="email" class="input-field" placeholder="admin@domain.com" required />
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Mobile Number</label>
                        <div class="input-wrapper">
                            <i class="fas fa-phone"></i>
                            <input asp-for="AdminMobile" class="input-field" required />
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Password</label>
                        <div class="input-wrapper">
                            <i class="fas fa-key"></i>
                            <input asp-for="Password" type="password" id="p1" class="input-field" placeholder="••••••••" required />
                            <i class="fas fa-eye-slash toggle-password" onclick="togglePass('p1', this)"></i>
                        </div>
                    </div>
                    <div class="input-group">
                        <label class="input-label">Confirm Password</label>
                        <div class="input-wrapper">
                            <i class="fas fa-shield-check"></i>
                            <input asp-for="ConfirmPassword" type="password" id="p2" class="input-field" placeholder="••••••••" required />
                            <i class="fas fa-eye-slash toggle-password" onclick="togglePass('p2', this)"></i>
                        </div>
                    </div>
                </div>

                <button type="submit" class="register-btn">Submit Registration Request <i class="fas fa-paper-plane"></i></button>
                <div class="login-link">Already have an account? <a href="/Account/Login">Sign In</a></div>
            </form>
        </div>
    </div>
</div>

<div class="success-overlay" id="successOverlay">
    <div class="success-card">
        <i class="fas fa-clock" style="font-size: 60px; color: #F59E0B; margin-bottom: 20px;"></i>
        <h2>Request Submitted!</h2>
        <p style="margin: 15px 0 30px; color: #64748B;">Your registration request has been sent to our Super Admin for approval. You will be able to log in once your request is reviewed.</p>
        <button class="register-btn" onclick="window.location='/Account/Login'">Back to Login</button>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
<script>


    // Swiper
    const registerSwiper = new Swiper('.registerSwiper', { 
        loop: true, 
        autoplay: { delay: 5000, disableOnInteraction: false }, 
        pagination: { el: '.swiper-pagination', clickable: true },

        effect: 'fade', 
        fadeEffect: { crossFade: true },
        speed: 1000 
    });

    function togglePass(id, icon) {
        const p = document.getElementById(id);
        const type = p.getAttribute('type') === 'password' ? 'text' : 'password';
        p.setAttribute('type', type);
        icon.classList.toggle('fa-eye');
        icon.classList.toggle('fa-eye-slash');
    }

    function handleFile(input) {
        const label = document.getElementById('fileLabel');
        if (input.files && input.files[0]) label.innerText = input.files[0].name;
    }

    document.addEventListener('DOMContentLoaded', () => {
        if (document.body.dataset.success === 'True') {
            document.getElementById('successOverlay').classList.add('active');
        }
    });

    // Entrance Animations (Identical to Login)
    const carouselSide = document.querySelector('.carousel-side');
    if (carouselSide) carouselSide.style.animation = 'fadeIn 0.8s ease';
    
    const formSide = document.querySelector('.form-side');
    if (formSide) formSide.style.animation = 'slideInUp 0.6s ease';
    
    const fadeStyle = document.createElement('style');
    fadeStyle.textContent = `
        @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @@keyframes slideInUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
    `;
    document.head.appendChild(fadeStyle);
</script>
</body>
</html>

@model VMSProject.Models.CompanyModel
@{
    Layout = "SuperAdminLayout";
    ViewData["Title"] = $"Company Details - {Model.CompanyName ?? Model.AdminName}";
}

@section Styles {
    <style>
        .detail-header {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #FFFFFF;
            padding: 20px 24px;
            border-radius: 6px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            margin-bottom: 24px;
            border: 1px solid #e2e8f0;
        }

        .detail-header h3 {
            margin: 0;
            font-size: 1.15rem;
            font-weight: 700;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .info-card {
            background: #FFFFFF;
            border-radius: 6px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            margin-bottom: 24px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
        }

        .info-card-header {
            background: #f8fafc;
            padding: 16px 24px;
            border-bottom: 1px solid #e2e8f0;
            font-weight: 700;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.95rem;
        }

        .info-grid {
            padding: 30px 24px;
            display: grid;
            grid-template-columns: 1fr;
            gap: 18px;
        }

        .info-row {
            display: grid;
            grid-template-columns: 220px 1fr;
            align-items: baseline;
        }

        .info-label {
            font-weight: 700;
            color: #1e293b;
            font-size: 0.9rem;
        }

        .info-value {
            color: #475569;
            font-size: 0.9rem;
        }

        .info-link {
            color: #3B82F6;
            text-decoration: underline;
        }

        .info-link:hover {
            color: #2563EB;
        }

        /* Stats Section */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }

        .stats-card {
            background: #FFFFFF;
            border-radius: 6px;
            padding: 24px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .s-info { display: flex; flex-direction: column; gap: 8px; }
        .s-label { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
        .s-val { font-size: 1.5rem; font-weight: 700; color: #1e293b; line-height: 1; }
        
        .lbl-blue { color: #3B82F6; }
        .lbl-green { color: #10B981; }
        .lbl-cyan { color: #06B6D4; }
        .lbl-yellow { color: #F59E0B; }

        .s-icon { font-size: 2rem; color: #1e293b; }

        /* Recent Activity */
        .activity-card {
            background: #FFFFFF;
            border-radius: 6px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }

        .activity-header {
            padding: 16px 24px;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .activity-title {
            font-weight: 600;
            color: #3B82F6;
            margin: 0;
            font-size: 0.95rem;
        }

        .btn-view-all {
            background: #3B82F6;
            color: white;
            border: none;
            padding: 6px 16px;
            border-radius: 4px;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
        }
        
        .btn-view-all:hover {
            background: #2563EB;
        }

        .empty-activity {
            padding: 60px 20px;
            text-align: center;
            color: #64748b;
        }

        .empty-activity i {
            font-size: 3.5rem;
            color: #94a3b8;
            margin-bottom: 20px;
        }

        .empty-activity h4 {
            color: #475569;
            font-weight: 600;
            margin-bottom: 8px;
        }
    </style>
}

<div class="detail-header">
    <h3><i class="fas fa-building text-dark"></i> @(Model.CompanyName ?? Model.AdminName)</h3>
</div>

<div class="row">
    <!-- Using full width (col-12) to match standard Company Information panel sizing without the Subscription block next to it -->
    <div class="col-12">
        <div class="info-card">
            <div class="info-card-header">
                <i class="fas fa-info-circle text-dark"></i> Company Information
            </div>
            <div class="info-grid">
                <div class="info-row">
                    <div class="info-label">Company Name:</div>
                    <div class="info-value">@(Model.CompanyName ?? "Not Specified")</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Contact Person:</div>
                    <div class="info-value">@(Model.AdminName ?? "Not Specified")</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Contact Email:</div>
                    <div class="info-value"><a href="mailto:@Model.AdminEmail" class="info-link">@Model.AdminEmail</a></div>
                </div>
                <div class="info-row">
                    <div class="info-label">Phone Number:</div>
                    <div class="info-value"><a href="tel:@Model.ContactNumber" class="info-link">@Model.ContactNumber</a></div>
                </div>
                <div class="info-row">
                    <div class="info-label">Address:</div>
                    <div class="info-value">
                        @(!string.IsNullOrEmpty(Model.Address) ? Model.Address + ", " : "")
                        @(!string.IsNullOrEmpty(Model.City) ? Model.City + ", " : "")
                        @(!string.IsNullOrEmpty(Model.State) ? Model.State + ", " : "")
                        @(!string.IsNullOrEmpty(Model.Country) ? Model.Country : "Not Specified")
                        @(!string.IsNullOrEmpty(Model.Pincode) ? " - " + Model.Pincode : "")
                    </div>
                </div>
                <div class="info-row">
                    <div class="info-label">GST Number:</div>
                    <div class="info-value">@(string.IsNullOrEmpty(Model.GSTNumber) ? "N/A" : Model.GSTNumber)</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Official Email:</div>
                    <div class="info-value"><a href="mailto:@Model.OfficialEmail" class="info-link">@Model.OfficialEmail</a></div>
                </div>
                <div class="info-row">
                    <div class="info-label">Industry Type:</div>
                    <div class="info-value">@(Model.Industry ?? "Not specified")</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Created Date:</div>
                    <div class="info-value">@(Model.CreatedDate == DateTime.MinValue ? "N/A" : Model.CreatedDate.ToString("MMM dd, yyyy"))</div>
                </div>
                <div class="info-row">
                    <div class="info-label">Active Since:</div>
                    <div class="info-value">@(Model.CreatedDate == DateTime.MinValue ? "N/A" : Model.CreatedDate.ToString("MMM dd, yyyy"))</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="stats-grid">
    <div class="stats-card">
        <div class="s-info">
            <span class="s-label lbl-blue">TOTAL VISITORS</span>
            <span class="s-val">@(ViewBag.TotalVisitors ?? 0)</span>
        </div>
        <div class="s-icon" style="color: #3B82F6;"><i class="fas fa-user-check"></i></div>
    </div>
    
    <div class="stats-card">
        <div class="s-info">
            <span class="s-label lbl-green">TOTAL EMPLOYEES</span>
            <span class="s-val">@(ViewBag.TotalEmployees ?? 0)</span>
        </div>
        <div class="s-icon" style="color: #10B981;"><i class="fas fa-users"></i></div>
    </div>

    <div class="stats-card">
        <div class="s-info">
            <span class="s-label lbl-cyan">DEPARTMENTS</span>
            <span class="s-val">@(ViewBag.TotalDepartments ?? 0)</span>
        </div>
        <div class="s-icon" style="color: #06B6D4;"><i class="fas fa-sitemap"></i></div>
    </div>

    <div class="stats-card">
        <div class="s-info">
            <span class="s-label lbl-yellow">RECENT ACTIVITY</span>
            <span class="s-val">@(ViewBag.RecentActivityCount ?? 0)</span>
        </div>
        <div class="s-icon" style="color: #F59E0B;"><i class="fas fa-history"></i></div>
    </div>
</div>

<div class="activity-card">
    <div class="activity-header">
        <h4 class="activity-title">Recent System Activity</h4>
        <a href="/SuperAdmin/SystemUsage?companyId=@Model.CompanyId" class="btn-view-all text-decoration-none">View All Activity</a>
    </div>
    @if (ViewBag.RecentLogs != null && ((List<VMSProject.Models.UserActivityLog>)ViewBag.RecentLogs).Any())
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0" style="font-size: 0.85rem;">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3">Timestamp</th>
                        <th class="px-4 py-3">User</th>
                        <th class="px-4 py-3">Action</th>
                        <th class="px-4 py-3">Module</th>
                        <th class="px-4 py-3">Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in (List<VMSProject.Models.UserActivityLog>)ViewBag.RecentLogs)
                    {
                        <tr>
                            <td class="px-4 py-3 text-muted">@log.Timestamp.ToString("MMM dd, HH:mm")</td>
                            <td class="px-4 py-3 fw-bold">@log.UserName <br/><small class="text-muted fw-normal">@log.UserEmail</small></td>
                            <td class="px-4 py-3">@log.Action</td>
                            <td class="px-4 py-3"><span class="badge bg-secondary">@log.Module</span></td>
                            <td class="px-4 py-3">
                                <span class="badge @(log.Status == "Success" ? "bg-success" : "bg-danger")">@log.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-activity">
            <i class="fas fa-chart-line"></i>
            <h4>No Recent Activity</h4>
            <p>No system activity has been recorded for this company yet.</p>
        </div>
    }
</div>

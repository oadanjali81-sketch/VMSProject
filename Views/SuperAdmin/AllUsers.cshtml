@model List<VMSProject.Models.CompanyModel>
@{
    Layout = "SuperAdminLayout";
    ViewData["Title"] = "All Users";
}

@section Styles {
    <style>
        .filter-section {
            background: #FFFFFF;
            border-radius: 6px;
            padding: 24px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            margin-bottom: 24px;
        }

        .filter-grid {
            display: flex;
            gap: 20px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .filter-group {
            flex: 1;
            min-width: 200px;
        }

        .filter-group label {
            display: block;
            font-size: 0.8rem;
            color: #475569;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .filter-control {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            font-size: 0.85rem;
            outline: none;
            color: #334155;
            transition: all 0.2s;
        }

        .filter-control:focus {
            border-color: #3B82F6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        .filter-actions {
            display: flex;
            gap: 12px;
        }

        .btn-filter {
            padding: 10px 20px;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.2s;
        }

        .btn-search {
            background: #3B82F6;
            color: #FFFFFF;
        }
        
        .btn-search:hover { background: #2563EB; }

        .btn-clear {
            background: #fff;
            border: 1px solid #e2e8f0;
            padding: 10px 18px;
            border-radius: 12px;
            color: #475569;
            font-weight: 600;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 8px;
            white-space: nowrap;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-decoration: none;
        }
        .btn-clear:hover {
            background: rgba(100, 116, 139, 0.1);
            color: #475569;
            border-color: #cbd5e1;
        }

        /* Stats Cards */
        .stat-card-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }

        .users-stat-card {
            background: #FFFFFF;
            border-radius: 6px;
            padding: 20px 24px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .stat-info { display: flex; flex-direction: column; gap: 8px; }

        .stat-label {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .lbl-total { color: #3B82F6; }
        .lbl-active { color: #10B981; }
        .lbl-new { color: #F59E0B; }
        .lbl-inactive { color: #EF4444; }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1e293b;
            line-height: 1;
        }

        .stat-icon {
            width: 38px;
            height: 38px;
            background: #1e293b;
            color: #ffffff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        /* Table Section */
        .table-section {
            background: #FFFFFF;
            border-radius: 6px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .action-cell { display: flex; gap: 8px; justify-content: flex-end; }
        .tool-btn {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #e2e8f0;
            color: #64748b;
            background: white;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.85rem;
        }
        .tool-btn:hover {
            border-color: #6366f1;
            color: #6366f1;
            background: rgba(99, 102, 241, 0.1);
        }
        .tool-btn.danger:hover {
            border-color: #f43f5e;
            color: #f43f5e;
            background: rgba(244, 63, 94, 0.05);
        }

        .table-header-title {
            padding: 20px 24px;
            font-size: 1rem;
            font-weight: 600;
            color: #3B82F6;
            border-bottom: 1px solid #f1f5f9;
        }

        .users-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .users-table th {
            background: #1e293b;
            color: #f8fafc;
            padding: 14px 24px;
            font-weight: 600;
            text-align: left;
            white-space: nowrap;
            letter-spacing: 0.5px;
            font-size: 0.8rem;
        }
        
        .users-table th:not(:last-child) {
            border-right: 1px solid rgba(255, 255, 255, 0.1);
        }

        .users-table td {
            padding: 16px 24px;
            color: #334155;
            vertical-align: middle;
            border-bottom: 1px solid #e2e8f0;
        }
        
        .users-table td:not(:last-child) {
            border-right: 1px solid #e2e8f0;
        }

        .users-table tr.striped-row td {
            background: #f8fafc;
        }

        .users-table tr:hover td {
            background: #f1f5f9;
        }

        .user-name {
            font-weight: 700;
            color: #0f172a;
        }

        .contact-email {
            color: #3B82F6;
            text-decoration: none;
            font-weight: 500;
        }
        
        .contact-email:hover {
            text-decoration: underline;
        }

        .emp-badge {
            background: #06b6d4;
            color: white;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 700;
        }

        .status-badge {
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 700;
            color: white;
            display: inline-block;
        }

        .status-active { background: #10B981; }
        .status-inactive { background: #F59E0B; }

        .acts-group {
            display: flex;
            gap: 6px;
        }

        .act-btn {
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            border-radius: 4px;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.2s;
        }

        .act-view { border: 1px solid #3B82F6; color: #3B82F6; }
        .act-view:hover { background: #3B82F6; color: white; }

        .act-edit { border: 1px solid #F59E0B; color: #F59E0B; }
        .act-edit:hover { background: #F59E0B; color: white; }

        .act-stats { border: 1px solid #06b6d4; color: #06b6d4; }
        .act-stats:hover { background: #06b6d4; color: white; }
    </style>
}

<form method="get" action="/SuperAdmin/AllUsers" class="filter-section">
    <div class="filter-grid">
        <div class="filter-group">
            <label>Search Users</label>
            <input type="text" name="search" value="@ViewBag.Search" class="filter-control" placeholder="User name, email, or contact person">
        </div>
        <div class="filter-group">
            <label>Status</label>
            <select name="status" class="filter-control">
                <option value="">All Users</option>
                <option value="Active" selected="@(ViewBag.Status == "Active")">Active</option>
                <option value="Inactive" selected="@(ViewBag.Status == "Inactive")">Inactive</option>
            </select>
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn-filter btn-search"><i class="fas fa-search"></i> Search</button>
            <a href="/SuperAdmin/AllUsers" class="btn-filter btn-clear" style="text-decoration:none;"><i class="fas fa-times"></i> Clear</a>
        </div>
    </div>
</form>

<div class="stat-card-row">
    <div class="users-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-total">TOTAL USERS</span>
            <span class="stat-value">@(ViewBag.TotalUsers ?? 0)</span>
        </div>
        <div class="stat-icon"><i class="fas fa-building"></i></div>
    </div>
    
    <div class="users-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-active">ACTIVE USERS</span>
            <span class="stat-value">@(ViewBag.ActiveUsers ?? 0)</span>
        </div>
        <div class="stat-icon"><i class="fas fa-check"></i></div>
    </div>
    
    <div class="users-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-new">NEW USERS</span>
            <span class="stat-value">@(ViewBag.NewUsers ?? 0)</span>
        </div>
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
    </div>

    <div class="users-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-inactive">INACTIVE USERS</span>
            <span class="stat-value">@(ViewBag.InactiveUsers ?? 0)</span>
        </div>
        <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
    </div>
</div>

<div class="table-section">
    <div class="table-header-title">
        Users List
    </div>
    <div style="overflow-x: auto;">
        <table class="users-table">
            <thead>
                <tr>
                    <th>Company Name</th>
                    <th>Admin Name</th>
                    <th>Admin Email</th>
                    <th>Created Date</th>
                    <th>Roll</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    bool isEven = false;
                    foreach (var user in Model)
                    {
                        <tr class="@(isEven ? "striped-row" : "")">
                            <td><span class="user-name">@(user.CompanyName ?? "System User")</span></td>
                            <td><span class="admin-name" style="font-weight: 500;">@(user.AdminName ?? "Not Specified")</span></td>
                            <td><a href="mailto:@user.AdminEmail" class="contact-email">@user.AdminEmail</a></td>
                            <td>@(user.CreatedDate == DateTime.MinValue ? "N/A" : user.CreatedDate.ToString("MMM dd, yyyy"))</td>
                            <td><span class="emp-badge" style="background:#64748b;">@(string.IsNullOrEmpty(user.Role) ? "N/A" : user.Role)</span></td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="status-badge status-active">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">Inactive</span>
                                }
                            </td>
                            <td>
                                <div class="acts-group">
                                    <a href="/SuperAdmin/UserDetail?id=@user.CompanyId" class="act-btn act-view" title="View"><i class="fas fa-eye"></i></a>
                                    <a href="/SuperAdmin/SystemUsage" class="act-btn act-stats" title="View System Usage"><i class="fas fa-chart-line"></i></a>
                                </div>
                            </td>
                        </tr>
                        isEven = !isEven;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center py-4">No users found matching your criteria.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

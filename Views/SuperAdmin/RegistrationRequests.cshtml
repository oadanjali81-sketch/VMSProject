@using VMSProject.Models
@{
    Layout = "SuperAdminLayout";
    ViewData["Title"] = "Registration Requests";
    var requests = ViewBag.Requests as List<CompanyRegistrationRequest> ?? new List<CompanyRegistrationRequest>();
    var totalCount = (int)ViewBag.TotalCount;
    var pendingCount = (int)ViewBag.PendingCount;
    var approvedCount = (int)ViewBag.ApprovedCount;
    var rejectedCount = (int)ViewBag.RejectedCount;
}

@section Styles {
    <style>
        .filter-section {
            background: #FFFFFF;
            border-radius: 6px;
            padding: 24px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            margin-bottom: 24px;
        }

        .filter-grid {
            display: flex;
            gap: 20px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .filter-group {
            flex: 1;
            min-width: 200px;
        }

        .filter-group label {
            display: block;
            font-size: 0.8rem;
            color: #475569;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .filter-control {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            font-size: 0.85rem;
            outline: none;
            color: #334155;
            transition: all 0.2s;
        }

        .filter-control:focus {
            border-color: #3B82F6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        .filter-actions {
            display: flex;
            gap: 12px;
        }

        .btn-filter {
            padding: 10px 20px;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.2s;
            text-decoration: none;
        }

        .btn-search {
            background: #3B82F6;
            color: #FFFFFF;
        }
        .btn-search:hover { background: #2563EB; }

        .btn-clear {
            background: #fff;
            border: 1px solid #e2e8f0;
            color: #475569;
        }
        .btn-clear:hover { background: #f8fafc; }

        /* Stats Cards */
        .stat-card-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }

        .req-stat-card {
            background: #FFFFFF;
            border-radius: 6px;
            padding: 20px 24px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .stat-info { display: flex; flex-direction: column; gap: 8px; }
        .stat-label {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .lbl-pending { color: #F59E0B; }
        .lbl-approved { color: #10B981; }
        .lbl-rejected { color: #EF4444; }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1e293b;
            line-height: 1;
        }

        .stat-icon {
            width: 38px;
            height: 38px;
            background: #1e293b;
            color: #ffffff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        /* Table Section */
        .table-section {
            background: #FFFFFF;
            border-radius: 6px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .table-header-title {
            padding: 20px 24px;
            font-size: 1rem;
            font-weight: 600;
            color: #3B82F6;
            border-bottom: 1px solid #f1f5f9;
        }

        .req-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .req-table th {
            background: #1e293b;
            color: #f8fafc;
            padding: 14px 24px;
            font-weight: 600;
            text-align: left;
            white-space: nowrap;
            letter-spacing: 0.5px;
            font-size: 0.8rem;
        }
        
        .req-table th:not(:last-child) {
            border-right: 1px solid rgba(255, 255, 255, 0.1);
        }

        .req-table td {
            padding: 16px 24px;
            color: #334155;
            vertical-align: middle;
            border-bottom: 1px solid #e2e8f0;
        }
        
        .req-table td:not(:last-child) {
            border-right: 1px solid #e2e8f0;
        }

        .req-table tr.striped-row td {
            background: #f8fafc;
        }

        .req-table tr:hover td {
            background: #f1f5f9;
        }

        .company-name { font-weight: 700; color: #0f172a; }
        .contact-email { color: #3B82F6; font-size: 0.8rem; }

        .status-badge {
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 700;
            color: white;
            display: inline-block;
            text-transform: uppercase;
        }

        .status-pending { background: #F59E0B; }
        .status-approved { background: #10B981; }
        .status-rejected { background: #EF4444; }

        .acts-group { display: flex; gap: 6px; justify-content: flex-end; }
        .act-btn {
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            border-radius: 4px;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid #e2e8f0;
        }

        .btn-view { color: #3B82F6; border-color: #3B82F6; }
        .btn-view:hover { background: #3B82F6; color: white; }

        .btn-approve { color: #10B981; border-color: #10B981; }
        .btn-approve:hover { background: #10B981; color: white; }

        .btn-reject { color: #EF4444; border-color: #EF4444; }
        .btn-reject:hover { background: #EF4444; color: white; }

        .pagination-section { padding: 20px; display: flex; justify-content: space-between; align-items: center; background: #fff; border-top: 1px solid #f1f5f9; }
        .page-info { font-size: 0.85rem; color: #64748b; font-weight: 500; }
        .page-nav { display: flex; gap: 6px; }
        .page-link { padding: 8px 14px; border: 1px solid #e2e8f0; border-radius: 8px; text-decoration: none; color: #475569; font-weight: 600; font-size: 0.85rem; transition: 0.2s; }
        .page-link:hover { border-color: #3B82F6; color: #3B82F6; background: #f0f7ff; }
        .page-link.active { background: #3B82F6; color: white; border-color: #3B82F6; }
    </style>
}

<form method="get" action="/SuperAdmin/RegistrationRequests" class="filter-section">
    <div class="filter-grid">
        <div class="filter-group">
            <label>Search Request</label>
            <input type="text" name="search" value="@ViewBag.Search" class="filter-control" placeholder="Company, name or email...">
        </div>
        <div class="filter-group">
            <label>Status</label>
            <select name="status" class="filter-control">
                <option value="All" selected="@(ViewBag.Status == "All")">All Status</option>
                <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending</option>
                <option value="Approved" selected="@(ViewBag.Status == "Approved")">Approved</option>
                <option value="Rejected" selected="@(ViewBag.Status == "Rejected")">Rejected</option>
            </select>
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn-filter btn-search"><i class="fas fa-search"></i> Search</button>
            <a href="/SuperAdmin/RegistrationRequests" class="btn-filter btn-clear" style="text-decoration:none;"><i class="fas fa-times"></i> Clear</a>
        </div>
    </div>
</form>

<div class="stat-card-row">
    <div class="req-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-pending">PENDING</span>
            <span class="stat-value">@pendingCount</span>
        </div>
        <div class="stat-icon" style="background: #F59E0B;"><i class="fas fa-clock"></i></div>
    </div>
    <div class="req-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-approved">APPROVED</span>
            <span class="stat-value">@approvedCount</span>
        </div>
        <div class="stat-icon" style="background: #10B981;"><i class="fas fa-check-circle"></i></div>
    </div>
    <div class="req-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-rejected">REJECTED</span>
            <span class="stat-value">@rejectedCount</span>
        </div>
        <div class="stat-icon" style="background: #EF4444;"><i class="fas fa-times-circle"></i></div>
    </div>
</div>

<div class="table-section">
    <div class="table-header-title">
        Registration Requests List
    </div>
    <div style="overflow-x: auto;">
        <table class="req-table">
            <thead>
                <tr>
                    <th>Company Name</th>
                    <th>Contact Person</th>
                    <th>Phone</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th style="text-align: right;">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (requests.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center py-4">No registration requests found.</td>
                    </tr>
                }
                else
                {
                    bool isEven = false;
                    foreach (var req in requests)
                    {
                        <tr class="@(isEven ? "striped-row" : "")">
                            <td>
                                <div class="d-flex flex-column">
                                    <span class="company-name">@req.CompanyName</span>
                                    <span class="contact-email">@req.ContactEmail</span>
                                </div>
                            </td>
                            <td><span style="font-weight: 500;">@req.ContactPersonName</span></td>
                            <td><span style="font-family: monospace; font-weight: 600;">@req.ContactPhone</span></td>
                            <td>@req.RequestDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                <span class="status-badge status-@req.Status.ToLower()">@req.Status</span>
                            </td>
                            <td>
                                <div class="acts-group">
                                    <button class="act-btn btn-view" onclick="viewDetails(@req.Id)" title="View Details"><i class="fas fa-eye"></i></button>
                                    @if (req.Status == "Pending")
                                    {
                                        <button class="act-btn btn-approve" onclick="processRequest(@req.Id, 'Approve')" title="Approve"><i class="fas fa-check"></i></button>
                                        <button class="act-btn btn-reject" onclick="processRequest(@req.Id, 'Reject')" title="Reject"><i class="fas fa-times"></i></button>
                                    }
                                </div>
                            </td>
                        </tr>
                        isEven = !isEven;
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="pagination-section">
        <div class="page-info">Showing <b>@requests.Count</b> of <b>@totalCount</b> requests</div>
        <div class="page-nav">
            @if (ViewBag.TotalPages > 1)
            {
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="/SuperAdmin/RegistrationRequests?page=@i&search=@ViewBag.Search&status=@ViewBag.Status" class="page-link @(ViewBag.CurrentPage == i ? "active" : "")">@i</a>
                }
            }
        </div>
    </div>
</div>

<!-- Bootstrap Modal -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-labelledby="detailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content" style="border-radius: 20px; border: none; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);">
            <div class="modal-header" style="background: #f8fafc; border-bottom: 1px solid #f1f5f9; padding: 24px; border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="detailsModalLabel" style="color: #1e293b;">Request Intelligence Detail</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="modalContent" style="padding: 32px;">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-3 text-muted">Loading request data...</p>
                </div>
            </div>
            <div class="modal-footer" id="modalFooter" style="background: #f8fafc; border-top: 1px solid #f1f5f9; padding: 20px 32px; border-radius: 0 0 20px 20px;">
                <button type="button" class="btn btn-secondary px-4 py-2 fw-bold" data-bs-dismiss="modal" style="border-radius: 12px;">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    let bsModal = null;

    function viewDetails(id) {
        if (!bsModal) {
            bsModal = new bootstrap.Modal(document.getElementById('detailsModal'));
        }
        
        document.getElementById('modalContent').innerHTML = `
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3 text-muted">Loading request data...</p>
            </div>
        `;
        
        bsModal.show();

        fetch(`/SuperAdmin/GetRegistrationRequest?id=${id}`)
            .then(response => response.json())
            .then(res => {
                if (res.success) {
                    const data = res.data;
                    const companyName = data.companyName || data.CompanyName || '—';
                    const industry = data.industry || data.Industry || 'N/A';
                    const contactPerson = data.contactPersonName || data.ContactPersonName || '—';
                    const status = data.status || data.Status || 'Pending';
                    const email = data.contactEmail || data.ContactEmail || '—';
                    const phone = data.contactPhone || data.ContactPhone || '—';
                    const gst = data.gstNumber || data.GSTNumber || 'N/A';
                    const pincode = data.pincode || data.Pincode || 'N/A';
                    const address = data.companyAddress || data.CompanyAddress || 'N/A';
                    const city = data.city || data.City || '';
                    const adminNotes = data.adminNotes || data.AdminNotes || '';
                    const rawDate = data.requestDate || data.RequestDate;
                    
                    const dateStr = rawDate ? new Date(rawDate).toLocaleDateString('en-US', { 
                        month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' 
                    }) : '—';
                    
                    let content = `
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">Company Name</label>
                                <div class="fw-bold text-dark fs-5">${companyName}</div>
                            </div>
                            <div class="col-md-6">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">Industry</label>
                                <div class="fw-bold text-dark fs-5">${industry}</div>
                            </div>
                            <div class="col-md-6">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">Contact Person</label>
                                <div class="fw-bold text-dark fs-5">${contactPerson}</div>
                            </div>
                            <div class="col-md-6">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">Status</label>
                                <div><span class="badge rounded-pill text-bg-${status === 'Approved' ? 'success' : (status === 'Rejected' ? 'danger' : 'warning')} px-3">${status}</span></div>
                            </div>
                            <div class="col-md-6">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">Work Email</label>
                                <div class="fw-bold text-dark">${email}</div>
                            </div>
                            <div class="col-md-6">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">Contact Phone</label>
                                <div class="fw-bold text-dark">${phone}</div>
                            </div>
                            <div class="col-md-6">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">GST / Tax ID</label>
                                <div class="fw-bold text-dark">${gst}</div>
                            </div>
                            <div class="col-md-6">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">Pincode</label>
                                <div class="fw-bold text-dark">${pincode}</div>
                            </div>
                            <div class="col-12">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">Headquarters Address</label>
                                <div class="fw-bold text-dark">${address}, ${city}</div>
                            </div>
                            <div class="col-12">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">Submission Date</label>
                                <div class="fw-bold text-dark">${dateStr}</div>
                            </div>
                        </div>
                    `;

                    if (adminNotes) {
                        content += `
                            <div class="mt-4 p-3 bg-light rounded-3 border">
                                <label class="text-uppercase small fw-bold text-muted d-block mb-1">Admin/System Notes</label>
                                <div class="text-secondary small">${adminNotes}</div>
                            </div>
                        `;
                    }

                    document.getElementById('modalContent').innerHTML = content;

                    if (status === 'Pending') {
                        document.getElementById('modalFooter').innerHTML = `
                            <button class="btn btn-outline-danger px-4 py-2 fw-bold me-auto" style="border-radius:12px;" onclick="processRequest(${data.id || data.Id}, 'Reject')">Reject Request</button>
                            <button class="btn btn-success px-4 py-2 fw-bold" style="border-radius:12px;" onclick="processRequest(${data.id || data.Id}, 'Approve')">Approve & Setup</button>
                        `;
                    } else {
                        document.getElementById('modalFooter').innerHTML = `
                            <button type="button" class="btn btn-secondary px-4 py-2 fw-bold" data-bs-dismiss="modal" style="border-radius: 12px;">Close</button>
                        `;
                    }
                }
            })
            .catch(err => {
                document.getElementById('modalContent').innerHTML = `<div class="alert alert-danger">Error loading request data.</div>`;
            });
    }

    function processRequest(id, action) {
        if (bsModal) bsModal.hide();
        let msg = action === 'Approve' ? 'Are you sure you want to approve this company? An account will be automatically created.' : 'Enter reason for rejection:';
        
        if (action === 'Approve') {
            if (confirm(msg)) {
                $.post('/SuperAdmin/ApproveRequest', { id: id }, function(res) {
                    if (res.success) {
                        alert(res.message);
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                });
            }
        } else {
            let notes = prompt(msg);
            if (notes !== null) {
                $.post('/SuperAdmin/RejectRequest', { id: id, notes: notes }, function(res) {
                    if (res.success) {
                        alert(res.message);
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                });
            }
        }
    }
</script>

@model List<VMSProject.Models.Visit>
@{
    Layout = "_SuperAdminLayout";
    ViewData["Title"] = "Reports & Analytics";
}

@section Styles {
    <style>
        .filter-section {
            background: #FFFFFF;
            border-radius: 6px;
            padding: 24px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            margin-bottom: 24px;
        }

        .filter-grid {
            display: flex;
            gap: 20px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .filter-group {
            flex: 1;
            min-width: 200px;
        }

        .filter-group label {
            display: block;
            font-size: 0.8rem;
            color: #475569;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .filter-control {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #cbd5e1;
            border-radius: 6px;
            font-size: 0.85rem;
            outline: none;
            color: #334155;
            transition: all 0.2s;
        }

        .filter-actions {
            display: flex;
            gap: 12px;
        }

        .btn-filter {
            padding: 10px 20px;
            border-radius: 6px;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: 0.2s;
        }

        .btn-search { 
            background: #fff; 
            color: #3B82F6; 
            border: 1px solid #3B82F6; 
        }
        .btn-search:hover { background: #3B82F6; color: #fff; }
        
        .btn-export { 
            background: #fff; 
            color: #10B981; 
            border: 1px solid #10B981; 
            text-decoration: none; 
        }
        .btn-export:hover { background: #10B981; color: #fff; }

        /* Stats Cards - Matching All Users */
        .stat-card-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }

        .users-stat-card {
            background: #FFFFFF;
            border-radius: 6px;
            padding: 20px 24px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .stat-info { display: flex; flex-direction: column; gap: 8px; }

        .stat-label {
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .lbl-total { color: #3B82F6; }
        .lbl-active { color: #10B981; }
        .lbl-pending { color: #F59E0B; }
        .lbl-completed { color: #06b6d4; }

        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1e293b;
            line-height: 1;
        }

        .stat-icon {
            width: 38px;
            height: 38px;
            background: #1e293b;
            color: #ffffff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }

        /* Table Section - Matching All Users */
        .table-section {
            background: #FFFFFF;
            border-radius: 6px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .table-header-title {
            padding: 20px 24px;
            font-size: 1rem;
            font-weight: 600;
            color: #3B82F6;
            border-bottom: 1px solid #f1f5f9;
        }

        .users-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.85rem;
        }

        .users-table th {
            background: #1e293b;
            color: #f8fafc;
            padding: 14px 24px;
            font-weight: 600;
            text-align: left;
            white-space: nowrap;
            letter-spacing: 0.5px;
            font-size: 0.8rem;
        }
        
        .users-table th:not(:last-child) { border-right: 1px solid rgba(255, 255, 255, 0.1); }

        .users-table td {
            padding: 16px 24px;
            color: #334155;
            vertical-align: middle;
            border-bottom: 1px solid #e2e8f0;
        }
        
        .users-table td:not(:last-child) { border-right: 1px solid #e2e8f0; }
        .users-table tr.striped-row td { background: #f8fafc; }
        .users-table tr:hover td { background: #f1f5f9; }

        .status-badge {
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 700;
            color: white;
            display: inline-block;
        }
        .status-active { background: #10B981; }
        .status-checkedout { background: #06b6d4; }
        .status-pending { background: #F59E0B; }
    </style>
}

<!-- FILTERS -->
<form method="get" action="/SuperAdmin/Reports" class="filter-section">
    <div class="filter-grid">
        <div class="filter-group">
            <label>Company Filter</label>
            <select name="companyId" class="filter-control">
                <option value="">All Companies</option>
                @foreach (var company in (List<VMSProject.Models.CompanyModel>)ViewBag.Companies)
                {
                    <option value="@company.CompanyId" selected="@(ViewBag.SelectedCompanyId == company.CompanyId)">@company.CompanyName</option>
                }
            </select>
        </div>
        <div class="filter-group">
            <label>Report Type</label>
            <select name="type" class="filter-control">
                <option value="History" selected="@(ViewBag.ReportType == "History")">Full History</option>
                <option value="Daily" selected="@(ViewBag.ReportType == "Daily")">Daily Report</option>
                <option value="Weekly" selected="@(ViewBag.ReportType == "Weekly")">Weekly Report</option>
                <option value="Monthly" selected="@(ViewBag.ReportType == "Monthly")">Monthly Report</option>
            </select>
        </div>
        <div class="filter-group">
            <label>From Date</label>
            <input type="date" name="from" value="@ViewBag.FromDate" class="filter-control">
        </div>
        <div class="filter-group">
            <label>To Date</label>
            <input type="date" name="to" value="@ViewBag.ToDate" class="filter-control">
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn-filter btn-search"><i class="fas fa-filter"></i> Apply</button>
            <a href="/SuperAdmin/ExportVisitors" class="btn-filter btn-export"><i class="fas fa-file-csv"></i> Export</a>
        </div>
    </div>
</form>

<!-- STATS -->
<div class="stat-card-row">
    <div class="users-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-total">TOTAL VISITORS</span>
            <span class="stat-value">@(ViewBag.TotalVisitorsReport ?? 0)</span>
        </div>
        <div class="stat-icon"><i class="fas fa-users"></i></div>
    </div>
    <div class="users-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-active">ACTIVE INSIDE</span>
            <span class="stat-value">@(ViewBag.InsideNow ?? 0)</span>
        </div>
        <div class="stat-icon"><i class="fas fa-door-open"></i></div>
    </div>
    <div class="users-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-pending">PENDING VISITORS</span>
            <span class="stat-value">@(ViewBag.PendingVisits ?? 0)</span>
        </div>
        <div class="stat-icon"><i class="fas fa-clock"></i></div>
    </div>
    <div class="users-stat-card">
        <div class="stat-info">
            <span class="stat-label lbl-completed">COMPLETED VISITS</span>
            <span class="stat-value">@(ViewBag.CompletedVisits ?? 0)</span>
        </div>
        <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
    </div>
</div>

<!-- ANALYTICS CHARTS -->
<div class="row g-4 mb-4">
    <div class="col-md-8">
        <div class="table-section">
            <div class="table-header-title" style="color: #6366f1;">
                <i class="fas fa-chart-line me-2"></i>Weekly Visit Trend (Last 7 Days)
            </div>
            <div style="padding: 20px; height: 320px;">
                <canvas id="weeklyTrendChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="table-section">
            <div class="table-header-title" style="color: #10B981;">
                <i class="fas fa-chart-pie me-2"></i>Status Distribution
            </div>
            <div style="padding: 20px; height: 320px;">
                <canvas id="statusMixChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- DATA TABLE -->
<div class="table-section">
    <div class="table-header-title">
        Visitor Data Stream (Showing @(ViewBag.Pagination?.TotalItems ?? 0) Entries)
    </div>
    <div style="overflow-x: auto;">
        <table class="users-table">
            <thead>
                <tr>
                    <th>Visit Date</th>
                    <th>Visitor Information</th>
                    <th>Host Details</th>
                    <th>Purpose</th>
                    <th>Check-In/Out</th>
                    <th style="text-align: center;">Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    bool isEven = false;
                    foreach (var visit in Model)
                    {
                        <tr class="@(isEven ? "striped-row" : "")">
                            <td><span style="font-weight: 700;">@visit.VisitDate.ToString("dd MMM, yyyy")</span></td>
                            <td>
                                <div class="fw-bold" style="color: #0f172a;">@(visit.Visitor?.Name ?? "N/A")</div>
                                <div class="small text-muted">@(visit.Visitor?.Phone ?? "No Phone")</div>
                            </td>
                            <td><span style="font-weight: 600;">@(visit.Employee?.Name ?? "N/A")</span></td>
                            <td>@visit.Purpose</td>
                            <td>
                                <div class="small">
                                    <span class="text-success fw-bold">In:</span> @visit.CheckInTime.ToString("hh:mm tt")
                                    @if (visit.CheckOutTime.HasValue)
                                    {
                                        <br />
                                        <span class="text-danger fw-bold">Out:</span> @visit.CheckOutTime.Value.ToString("hh:mm tt")
                                    }
                                </div>
                            </td>
                            <td style="text-align: center;">
                                @if (visit.Status == "Active")
                                {
                                    <span class="status-badge status-active" style="background: #10B981;">Active</span>
                                }
                                else if (visit.Status == "Checked Out" || visit.Status == "Completed" || visit.Status == "CheckedOut")
                                {
                                    <span class="status-badge status-checkedout" style="background: #06b6d4;">@visit.Status</span>
                                }
                                else
                                {
                                    <span class="status-badge status-pending" style="background: #F59E0B;">@visit.Status</span>
                                }
                            </td>
                        </tr>
                        isEven = !isEven;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" style="text-align: center; padding: 60px; color: #94a3b8;">
                            <div style="font-size: 3rem; margin-bottom: 20px; opacity: 0.3;"><i class="fas fa-database"></i></div>
                            <h4 style="font-weight: 700;">No Visit Data Found</h4>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="table-footer px-4 py-3 bg-light border-top d-flex justify-content-between align-items-center">
        <div class="text-muted small fw-bold">
            Showing @(Model?.Count ?? 0) of @(ViewBag.Pagination?.TotalItems ?? 0) Records
        </div>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                @if (ViewBag.Pagination != null)
                {
                    var pag = (VMSProject.Models.PaginationViewModel)ViewBag.Pagination;
                    int totalPages = (int)Math.Ceiling((double)pag.TotalItems / (pag.PageSize > 0 ? pag.PageSize : 10));
                    
                    <li class="page-item @(pag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action(pag.Action, pag.Controller, new { page = pag.CurrentPage - 1, type = pag.RouteValues["type"], from = pag.RouteValues["from"], to = pag.RouteValues["to"], search = pag.RouteValues["search"], companyId = pag.RouteValues["companyId"] })">Previous</a>
                    </li>
                    
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == pag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action(pag.Action, pag.Controller, new { page = i, type = pag.RouteValues["type"], from = pag.RouteValues["from"], to = pag.RouteValues["to"], search = pag.RouteValues["search"], companyId = pag.RouteValues["companyId"] })">@i</a>
                        </li>
                    }
                    
                    <li class="page-item @(pag.CurrentPage == totalPages || totalPages == 0 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action(pag.Action, pag.Controller, new { page = pag.CurrentPage + 1, type = pag.RouteValues["type"], from = pag.RouteValues["from"], to = pag.RouteValues["to"], search = pag.RouteValues["search"], companyId = pag.RouteValues["companyId"] })">Next</a>
                    </li>
                }
            </ul>
        </nav>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Chart Defaults
            Chart.defaults.font.family = "'Inter', sans-serif";
            Chart.defaults.color = "#64748b";

            // 1. Weekly Trend Chart
            new Chart(document.getElementById('weeklyTrendChart').getContext('2d'), {
                type: 'line',
                data: {
                    labels: @Html.Raw(ViewBag.TrendLabels ?? "[]"),
                    datasets: [{
                        label: 'Visits',
                        data: @Html.Raw(ViewBag.TrendValues ?? "[]"),
                        borderColor: '#6366f1',
                        backgroundColor: 'rgba(99, 102, 241, 0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#6366f1'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { borderDash: [5, 5] } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // 2. Status Mix Chart
            new Chart(document.getElementById('statusMixChart').getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(ViewBag.StatusLabels ?? "[]"),
                    datasets: [{
                        data: @Html.Raw(ViewBag.StatusValues ?? "[]"),
                        backgroundColor: ['#10B981', '#06b6d4', '#F59E0B', '#6366f1', '#EF4444'],
                        borderWidth: 0,
                        weight: 0.5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 15, font: { size: 11 } } }
                    }
                }
            });
        });
    </script>
}

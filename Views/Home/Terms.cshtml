@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "Terms of Service | VISION VMS";
}

@section Styles {
    <style>
        /* ── Legal Page Layout ── */
        .legal-page-header {
            padding: 160px 80px 80px;
            background: linear-gradient(135deg, #EEF2FF 0%, #F8FAFF 60%);
            border-bottom: 1px solid #E2E8F0;
            text-align: center;
        }
        .legal-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(99, 102, 241, 0.1);
            color: #6366F1;
            padding: 8px 20px;
            border-radius: 50px;
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 24px;
        }
        .legal-page-header h1 {
            font-size: 3.2rem;
            font-weight: 800;
            color: #1E293B;
            margin-bottom: 16px;
            letter-spacing: -1.5px;
        }
        .legal-page-header p {
            font-size: 1.1rem;
            color: #64748B;
            max-width: 560px;
            margin: 0 auto;
            line-height: 1.7;
        }

        /* ── Main Two-Column Layout ── */
        .legal-body {
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 80px 100px;
            display: grid;
            grid-template-columns: 240px 1fr;
            gap: 60px;
            align-items: start;
        }

        /* ── Sidebar TOC ── */
        .legal-sidebar {
            position: sticky;
            top: 100px;
        }
        .toc-label {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #94A3B8;
            margin-bottom: 16px;
        }
        .toc-nav {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .toc-link {
            display: block;
            padding: 10px 14px;
            color: #64748B;
            text-decoration: none;
            border-radius: 10px;
            transition: all 0.2s;
            font-weight: 500;
            font-size: 0.9rem;
            border-left: 2px solid transparent;
        }
        .toc-link:hover {
            background: #EEF2FF;
            color: #6366F1;
            border-left-color: #6366F1;
        }
        .toc-link.active {
            background: #EEF2FF;
            color: #6366F1;
            border-left-color: #6366F1;
            font-weight: 600;
        }
        .toc-date {
            margin-top: 24px;
            padding: 12px 14px;
            background: #F8FAFF;
            border-radius: 10px;
            border: 1px solid #E2E8F0;
            font-size: 0.82rem;
            color: #64748B;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .toc-date i { color: #6366F1; }

        /* ── Article Content ── */
        .legal-article section {
            margin-bottom: 48px;
            padding-bottom: 48px;
            border-bottom: 1px solid #F1F5F9;
        }
        .legal-article section:last-child {
            border-bottom: none;
        }
        .legal-article h2 {
            font-size: 1.5rem;
            font-weight: 800;
            color: #1E293B;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .section-marker {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            background: rgba(99, 102, 241, 0.1);
            color: #6366F1;
            border-radius: 10px;
            font-weight: 800;
            font-size: 0.95rem;
            flex-shrink: 0;
        }
        .legal-article p {
            line-height: 1.85;
            color: #475569;
            margin-bottom: 1.25rem;
            font-size: 1rem;
        }
        .legal-article ul {
            margin: 16px 0 20px 0;
            padding-left: 0;
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .legal-article ul li {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            color: #475569;
            line-height: 1.7;
            font-size: 0.97rem;
        }
        .legal-article ul li::before {
            content: '';
            width: 8px;
            height: 8px;
            background: #6366F1;
            border-radius: 50%;
            flex-shrink: 0;
            margin-top: 8px;
        }

        /* ── Restriction Card (red accent) ── */
        .restriction-card {
            background: #FFF8F8;
            border: 1px solid #FEE2E2;
            border-left: 4px solid #EF4444;
            border-radius: 16px;
            padding: 24px 28px;
            margin: 24px 0;
        }
        .restriction-card ul {
            margin: 0;
            gap: 12px;
        }
        .restriction-card ul li {
            padding: 8px 0;
            border-bottom: 1px solid #FEE2E2;
        }
        .restriction-card ul li:last-child {
            border-bottom: none;
            padding-bottom: 0;
        }
        .restriction-card ul li::before {
            background: #EF4444;
            margin-top: 9px;
        }

        /* ── CTA Buttons ── */
        .legal-cta {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            margin-top: 28px;
        }
        .btn-legal-primary {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: var(--vision-gradient);
            color: white;
            padding: 14px 28px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.9rem;
            text-decoration: none;
            transition: all 0.3s;
            box-shadow: 0 8px 20px rgba(99, 102, 241, 0.25);
        }
        .btn-legal-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(99, 102, 241, 0.35);
        }
        .btn-legal-outline {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: transparent;
            color: #6366F1;
            padding: 14px 28px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.9rem;
            text-decoration: none;
            border: 2px solid #6366F1;
            transition: all 0.3s;
        }
        .btn-legal-outline:hover {
            background: #EEF2FF;
            transform: translateY(-2px);
        }

        /* ── Responsive ── */
        @@media (max-width: 1024px) {
            .legal-body {
                grid-template-columns: 1fr;
                padding: 40px 40px 80px;
            }
            .legal-sidebar {
                position: static;
                display: flex;
                flex-wrap: wrap;
                align-items: center;
                gap: 16px;
            }
            .toc-label { margin: 0; }
            .toc-nav { flex-direction: row; flex-wrap: wrap; }
            .toc-date { margin-top: 0; }
        }
        @@media (max-width: 640px) {
            .legal-page-header {
                padding: 140px 24px 60px;
            }
            .legal-page-header h1 { font-size: 2.2rem; }
            .legal-body { padding: 32px 24px 60px; }
        }
    </style>
}

<!-- Page Header -->
<header class="legal-page-header">
    <div class="legal-badge">
        <i class="fas fa-file-contract"></i> Legal Document
    </div>
    <h1>Terms of Service</h1>
    <p>Please read these terms carefully before using the VISION VMS platform</p>
</header>

<!-- Main Content -->
<div class="legal-body">

    <!-- Sidebar TOC -->
    <aside class="legal-sidebar">
        <div class="toc-label">On this page</div>
        <nav class="toc-nav">
            <a href="#acceptance" class="toc-link">1. Acceptance</a>
            <a href="#license" class="toc-link">2. Use License</a>
            <a href="#liability" class="toc-link">3. Liability</a>
            <a href="#conduct" class="toc-link">4. User Conduct</a>
            <a href="#contact" class="toc-link">5. Contact Us</a>
        </nav>
        <div class="toc-date">
            <i class="far fa-calendar-alt"></i>
            Last updated: April 16, 2026
        </div>
    </aside>

    <!-- Article -->
    <article class="legal-article">

        <section id="acceptance">
            <h2><span class="section-marker">1</span> Acceptance of Terms</h2>
            <p>By accessing or using the VISION VMS platform, you agree to be bound by these Terms of Service and all applicable laws and regulations. If you do not agree with any of these terms, you are prohibited from using or accessing this site.</p>
        </section>

        <section id="license">
            <h2><span class="section-marker">2</span> Use License</h2>
            <p>We grant you a temporary, non-exclusive, non-transferable license to use the VISION VMS platform for authorized visitor management purposes within your organization. This license shall automatically terminate if you violate any of these restrictions:</p>
            <div class="restriction-card">
                <ul>
                    <li>You may not reverse engineer or copy the software.</li>
                    <li>You may not use the platform for illegal activities.</li>
                    <li>You may not transfer your license to third parties without consent.</li>
                </ul>
            </div>
        </section>

        <section id="liability">
            <h2><span class="section-marker">3</span> Liability</h2>
            <p>VISION VMS provides the software platform for visitor management; however, physical security and visitor verification at the site remain the sole responsibility of the host organization. VISION VMS shall not be held liable for any incidental, consequential, or indirect damages arising out of the use of the platform.</p>
        </section>

        <section id="conduct">
            <h2><span class="section-marker">4</span> User Conduct</h2>
            <p>Users must provide accurate information and respect the privacy of others. Any attempt to bypass security measures, unauthorized access to data, or interference with the platform's operation will lead to immediate termination of access and potential legal action.</p>
        </section>

        <section id="contact">
            <h2><span class="section-marker">5</span> Contact Us</h2>
            <p>For legal inquiries or clarifications regarding these terms, please contact our legal department.</p>
            <div class="legal-cta">
                <a href="mailto:legal@visionvms.com" class="btn-legal-primary">
                    <i class="fas fa-balance-scale"></i> Email Legal Department
                </a>
                <a href="/Home/Contact" class="btn-legal-outline">
                    <i class="fas fa-arrow-right"></i> Visit Contact Page
                </a>
            </div>
        </section>

    </article>

</div>

@section Scripts {
    <script>
        // Highlight active TOC link on scroll
        const sections = document.querySelectorAll('.legal-article section');
        const tocLinks = document.querySelectorAll('.toc-link');

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    tocLinks.forEach(link => link.classList.remove('active'));
                    const active = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
                    if (active) active.classList.add('active');
                }
            });
        }, { rootMargin: '-20% 0px -70% 0px' });

        sections.forEach(s => observer.observe(s));
    </script>
}

@{
    Layout = "_LandingLayout";
    ViewData["Title"] = "About Us | VISION VMS";
}

@section Styles {
    <style>
        .page-header {
            padding: 180px 80px 80px;
            background: linear-gradient(135deg, #EEF2FF 0%, #F8FAFF 60%);
            text-align: center;
        }
        .page-header h1 {
            font-size: 3.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #3730A3, #6366F1);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 20px;
        }
        .content-section {
            padding: 80px 80px;
            max-width: 1000px;
            margin: 0 auto;
            line-height: 1.8;
            color: #475569;
        }
        .content-section h2 {
            color: #1E293B;
            margin: 40px 0 20px;
        }
    </style>
}

<header class="page-header">
    <h1>Our Story</h1>
    <p>Building the future of secure workplace access</p>
</header>

<main class="content-section">
    <h2>Who We Are</h2>
    <p>VISION VMS is a leading provider of next-generation visitor management solutions. Founded in 2026, we recognized the need for a more secure, efficient, and professional way to handle workplace entry in an increasingly digital world.</p>
    
    <h2>Our Mission</h2>
    <p>To provide organizations with seamless, bank-grade security solutions that enhance safety while creating a welcoming experience for every visitor.</p>
    
    <h2>Core Values</h2>
    <ul>
        <li><strong>Security First:</strong> We never compromise on the safety of your data or your premises.</li>
        <li><strong>Innovation:</strong> Constantly evolving with QR, Biometrics, and AI to stay ahead.</li>
        <li><strong>Simplicity:</strong> Complex technology made remarkably easy to use.</li>
    </ul>
</main>

